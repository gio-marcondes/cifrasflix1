        if (param === 'level') nodes.gainNode.gain.setValueAtTime(value, currentTime);
      }
    }

    function rebuildSignalChains() {
      rebuildMonitorSignalChains();
      
      if (!isPlaying) return;
      
      const delta = audioCtx.currentTime - playbackStartTime;
      const currentPos = timelinePosition + delta;

      stopActiveSources();
      activeTrackChains = {};

      timelinePosition = currentPos;
      playbackStartTime = audioCtx.currentTime;

      const temSolo = tracks.some(t => t.soloed);

      tracks.forEach(track => {
        if (track.muted) return;
        if (temSolo && !track.soloed) return;

        const trackGain = audioCtx.createGain();
        trackGain.gain.value = track.volume / 100;

        const trackPanner = audioCtx.createStereoPanner();
        trackPanner.pan.value = track.pan / 100;

        trackGain.connect(trackPanner);

        const chain = buildTrackSignalChain(track, trackPanner, audioCtx, eqLow);
        activeTrackChains[track.id] = chain;

        // Aplicar taxa de reprodução global (BPM) e afinação (Tom)
        const playbackRate = getPlaybackRate();
        const pitchRate = getPitchShiftRate('C'); // Assumindo que todos os samples estão em C
        const finalRate = playbackRate * pitchRate;

        track.regions.forEach(region => {
          if (!region.buffer) return;

          const clipEndTime = region.startTime + region.duration;
          
          if (clipEndTime > timelinePosition) {
            const source = audioCtx.createBufferSource();
            source.buffer = region.buffer;
            source.playbackRate.value = finalRate;

            const clipGainNode = audioCtx.createGain();
            const finalGain = region.gain !== undefined ? region.gain : 1.0;
            const fadeInTime = region.fadeIn || 0.0;
            const fadeOutTime = region.fadeOut || 0.0;

            let delay = region.startTime - timelinePosition;
            let offset = region.offset || 0;
            let durationToPlay = region.duration;

            if (delay < 0) {
              offset += Math.abs(delay);
              durationToPlay -= Math.abs(delay);
              delay = 0;
            }

            const startTime = audioCtx.currentTime + delay;
            const endTime = startTime + durationToPlay;

            // Configuração da Automação de Fades e Ganho
            clipGainNode.gain.setValueAtTime(0, audioCtx.currentTime); // silêncio inicial

            const clipOffsetInPlay = offset - (region.offset || 0);

            if (clipOffsetInPlay < fadeInTime && fadeInTime > 0) {
              const startFadeGain = (clipOffsetInPlay / fadeInTime) * finalGain;
              clipGainNode.gain.setValueAtTime(startFadeGain, startTime);
              clipGainNode.gain.linearRampToValueAtTime(finalGain, startTime + (fadeInTime - clipOffsetInPlay));
            } else {
              clipGainNode.gain.setValueAtTime(finalGain, startTime);
            }

            if (fadeOutTime > 0) {
              const fadeOutStartOffsetFromClipStart = region.duration - fadeOutTime;
              const fadeOutStartTimeOnTimeline = region.startTime + fadeOutStartOffsetFromClipStart;
              let delayToFadeOut = fadeOutStartTimeOnTimeline - timelinePosition;

              if (delayToFadeOut < 0) {
                const timeInFadeOut = Math.abs(delayToFadeOut);
                const currentFadeOutGain = finalGain * (1 - (timeInFadeOut / fadeOutTime));
                clipGainNode.gain.setValueAtTime(currentFadeOutGain, startTime);
                clipGainNode.gain.linearRampToValueAtTime(0, endTime);
              } else {
                clipGainNode.gain.setValueAtTime(finalGain, startTime + delayToFadeOut);
                clipGainNode.gain.linearRampToValueAtTime(0, endTime);
              }
            }

            source.connect(clipGainNode);
            clipGainNode.connect(trackGain);

            source.start(startTime, offset, durationToPlay);
            activeNodes.push({ source, trackGain, trackPanner, trackId: track.id, clipGainNode });
          }
        });
      });
    }


    });

    document.getElementById('btnConfirmAddTrack').addEventListener('click', () => {
      const name = document.getElementById('newTrackName').value.trim() || `Trilha ${tracks.length + 1}`;
      const color = document.getElementById('newTrackColor').value;
      saveHistory();
      addTrack(name, 'audio', color);
      fecharModal('modalAddTrack');
    });

    document.getElementById('newTrackName').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('btnConfirmAddTrack').click();
      }
    });

    document.getElementById('btnUndo').addEventListener('click', undoAction);
    document.getElementById('btnRedo').addEventListener('click', redoAction);

    // =========================================================================
    // 🚀 STARTUP & INITIALIZATION
    // =========================================================================

    // Adiciona uma trilha vazia por padrão
    addTrack("Voz", "audio", "#ff5555");
    addTrack("Violão", "audio", "#8b5cf6");
    // Desenha régua e inicializa
    updateTimelineLayout();
    renderDAW();
    atualizarTransporteMasterDAW(0);

    // Inicialização do Espectro DAW
    makeDraggable('panelSpectrum', 'panelSpectrumHeader');
    bindSpectrumDAWListeners();
    atualizarFFTDAW();

    // Atalhos do teclado (Deletar clipe, Play/Pause com Espaço, Ctrl+Z para desfazer, Setas para mover cursor)
    window.addEventListener('keydown', (e) => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) {
        return;
      }

      // Ctrl+S para Salvar
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's') {
        e.preventDefault();
        salvarConfiguracoes();
        return;
      }

      // Ctrl+Z para Desfazer

      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z' && !e.shiftKey) {
        e.preventDefault();
        undoAction();
        return;
      }

      // Ctrl+Shift+Z para Refazer
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key.toLowerCase() === 'z') {
        e.preventDefault();
        redoAction();
        return;
      }

      // Ctrl+C para Copiar Região
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'c') {
        e.preventDefault();
        copiarRegiaoSelecionada();
        return;
      }

      // Ctrl+V para Colar Região
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'v') {
        e.preventDefault();
        colarRegiao();
        return;
      }

      // Ctrl+X para Recortar Região
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'x') {
        e.preventDefault();
        recortarRegiaoSelecionada();
        return;
      }

      // Espaço para Play/Pause
      if (e.key === ' ' || e.code === 'Space') {
        e.preventDefault();
        playDAW();
        return;
      }

      // Tecla T para Adicionar Nova Trilha
      if (e.key.toLowerCase() === 't') {
        e.preventDefault();
        abrirModalNovaTrilha();
        return;
      }

      // Tecla V ou 1 para ativar ferramenta Seleção / Ponteiro
      if (e.key.toLowerCase() === 'v' || e.key === '1') {
        e.preventDefault();
        const btnPointer = document.getElementById('btnPointerMode');
        if (btnPointer) btnPointer.click();
        return;
      }

      // Tecla R para alternar ferramenta Região
      if (e.key.toLowerCase() === 'r') {
        e.preventDefault();
        const btnReg = document.getElementById('btnRegionMode');
        if (btnReg) btnReg.click();
        return;
      }

      // Tecla C ou 3 para alternar ferramenta Corte
      if (e.key.toLowerCase() === 'c' || e.key === '3') {
        e.preventDefault();
        const btnCut = document.getElementById('btnCutMode');
        if (btnCut) btnCut.click();
        return;
      }

      // Tecla * para Gravar na Trilha Selecionada
      if (e.key === '*') {
        e.preventDefault();
        if (activeRecordTrackId) {
          toggleRecord(activeRecordTrackId);
        } else if (selectedTrackId) {
          toggleRecord(selectedTrackId);
        } else if (tracks.length > 0) {
          toggleRecord(tracks[0].id);
        }
        return;
      }

      // Setas para esquerda e direita para mover o cursor vermelho
      if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        e.preventDefault();
        const step = e.shiftKey ? 5 : 1;
        let currentPos = timelinePosition;
        if (isPlaying) {
          const delta = audioCtx.currentTime - playbackStartTime;
          currentPos = timelinePosition + delta;
        }
        
        if (e.key === 'ArrowLeft') {
          timelinePosition = Math.max(0, currentPos - step);
        } else {
          timelinePosition = currentPos + step;
        }

        const posPx = timelinePosition * PX_PER_SECOND;
        document.getElementById('playheadLine').style.left = `${posPx}px`;
        const playheadM = document.getElementById('playheadMarker');
        if (playheadM) playheadM.style.left = `${posPx}px`;
        document.getElementById('displayTime').textContent = formatDigitalTime(timelinePosition);

        if (isPlaying) {
          stopActiveSources();
          playbackStartTime = audioCtx.currentTime;
          isPlaying = false;
          playDAW();
        }
        return;
      }

      // Deletar clipe selecionado com tecla DEL ou Backspace, ou apagar seleção de região
      if (e.key === 'Delete' || e.key === 'Backspace' || e.key === 'Del') {
        if (regionMode && regionSelectionActive && selectionStart !== null && selectionEnd !== null) {
          e.preventDefault();
          apagarTrechoSelecionado();
          return;
        }
        if (selectedRegionIds.size > 0 || (selectedRegionId && selectedRegionTrackId)) {
          saveHistory();
          if (selectedRegionId) selectedRegionIds.add(selectedRegionId);
          tracks.forEach(track => {
            track.regions = track.regions.filter(r => !selectedRegionIds.has(r.id));
          });
          selectedRegionIds.clear();
          selectedRegionId = null;
          selectedRegionTrackId = null;
          renderDAW();
          if (isPlaying) {
            stopActiveSources();
            playDAW();
          }
        }
      }

      // Tecla F5 para alternar visualização do menu de efeitos lateral e rodapé
      if (e.key === 'F5') {
        e.preventDefault();
        toggleEffectsPanel();
        return;
      }
    });

    function toggleEffectsPanel() {
      const panel = document.querySelector('.master-effects-panel');
      const footer = document.querySelector('footer');
      const tab = document.getElementById('btnShowEffectsTab');
      if (!panel) return;
      
      const isHidden = window.getComputedStyle(panel).display === 'none';
      if (isHidden) {
        panel.style.display = 'flex';
        if (footer) footer.style.display = 'flex';
        if (tab) tab.style.display = 'none';
      } else {
        panel.style.display = 'none';
        if (footer) footer.style.display = 'none';
        if (tab) tab.style.display = 'block';
      }
    }

    // =========================================================================
    // 📊 ESPECTRO DE FREQUÊNCIA DA DAW
    // =========================================================================
    let spectrumActive = false;
    let spectrumAnimFrame = null;
    let modoEspectroDAWAtivo = 'bars';
    let dawPeakHoldArray = [];
    let dawWaterfallCanvasAux = null;

    function toggleSpectrumPanel() {
      const panel = document.getElementById('panelSpectrum');
      const btn = document.getElementById('btnToggleSpectrum');
      if (!panel) return;

      if (panel.style.display === 'none') {
        panel.style.display = 'flex';
        btn.classList.add('active');
        spectrumActive = true;
        startDAWSpectrum();
      } else {
        panel.style.display = 'none';
        btn.classList.remove('active');
        spectrumActive = false;
        if (spectrumAnimFrame) {
          cancelAnimationFrame(spectrumAnimFrame);
          spectrumAnimFrame = null;
        }
      }
    }

    function mudarModoEspectroDAW(modo) {
      modoEspectroDAWAtivo = modo;
      
      const buttons = ['bars', 'line', 'spectrogram', 'waterfall'];
      buttons.forEach(b => {
        const btn = document.getElementById('btnSpecMode' + b.charAt(0).toUpperCase() + b.slice(1));
        if (btn) {
          btn.classList.toggle('active', b === modo);
        }
      });

      const barsGroup = document.getElementById('dawSettingBarsCountGroup');
      if (barsGroup) {
        barsGroup.style.display = (modo === 'bars' || modo === 'spectrogram') ? 'flex' : 'none';
      }
    }

    function atualizarFFTDAW() {
      const fftSelect = document.getElementById('dawSettingFftSize');
      const hzBadge = document.getElementById('dawHzBinBadge');
      if (!fftSelect || !hzBadge) return;

      const currentSize = parseInt(fftSelect.value);
      dawSpectrumAnalyser.fftSize = currentSize;

      const sampleRate = audioCtx.sampleRate;
      const hzPerBin = sampleRate / currentSize;
      hzBadge.textContent = hzPerBin.toFixed(1) + ' Hz/bin';

      const smoothingSlider = document.getElementById('dawSettingSmoothing');
      if (smoothingSlider) {
        dawSpectrumAnalyser.smoothingTimeConstant = parseFloat(smoothingSlider.value);
      }
    }

    function bindSpectrumDAWListeners() {
      const fftSelect = document.getElementById('dawSettingFftSize');
      const smoothingSlider = document.getElementById('dawSettingSmoothing');
      const smoothingBadge = document.getElementById('dawSmoothingValueBadge');
      const barsCountSlider = document.getElementById('dawSettingBarsCount');
      const barsCountBadge = document.getElementById('dawBarsCountBadge');

      if (fftSelect) {
        fftSelect.addEventListener('change', atualizarFFTDAW);
      }

      if (smoothingSlider) {
        smoothingSlider.addEventListener('input', () => {
          const val = parseFloat(smoothingSlider.value);
          if (smoothingBadge) smoothingBadge.textContent = val.toFixed(2);
          dawSpectrumAnalyser.smoothingTimeConstant = val;
        });
      }

      if (barsCountSlider) {
        barsCountSlider.addEventListener('input', () => {
          const val = parseInt(barsCountSlider.value);
          if (barsCountBadge) barsCountBadge.textContent = val;
        });
      }
    }

    function makeDraggable(elementId, headerId) {
      const element = document.getElementById(elementId);
      const header = document.getElementById(headerId);
      if (!element || !header) return;

      let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
      header.onmousedown = dragMouseDown;

      function dragMouseDown(e) {
        e = e || window.event;
        if (e.target.closest('.floating-panel-close')) return;
        e.preventDefault();
        pos3 = e.clientX;
        pos4 = e.clientY;
        document.onmouseup = closeDragElement;
        document.onmousemove = elementDrag;
      }

      function elementDrag(e) {
        e = e || window.event;
        e.preventDefault();
        pos1 = pos3 - e.clientX;
        pos2 = pos4 - e.clientY;
        pos3 = e.clientX;
        pos4 = e.clientY;
        element.style.top = (element.offsetTop - pos2) + "px";
        element.style.left = (element.offsetLeft - pos1) + "px";
      }

      function closeDragElement() {
        document.onmouseup = null;
        document.onmousemove = null;
      }
    }

    function startDAWSpectrum() {
      const canvas = document.getElementById('dawSpectrumCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const tooltip = document.getElementById('dawSpectrumTooltip');

      dawWaterfallCanvasAux = document.createElement('canvas');
      dawWaterfallCanvasAux.width = canvas.width;
      dawWaterfallCanvasAux.height = canvas.height;
      const ctxAux = dawWaterfallCanvasAux.getContext('2d');

      const dbLines = [0, -20, -40, -60, -80];
      const freqLinesLog = [20, 50, 100, 200, 500, 1000, 2000, 5000, 10000, 20000];

      function drawGrid() {
        ctx.lineWidth = 1;
        ctx.font = '10px monospace';

        dbLines.forEach(db => {
          const y = ctx.lineWidth + ((db / -100) * (canvas.height - 25));
          
          ctx.strokeStyle = 'rgba(148, 163, 184, 0.08)';
          ctx.beginPath();
          ctx.moveTo(40, y);
          ctx.lineTo(canvas.width, y);
          ctx.stroke();

          ctx.fillStyle = '#8fa5b7';
          ctx.fillText(db + ' dB', 5, y + 3);
        });

        freqLinesLog.forEach(freq => {
          const logMin = Math.log10(20);
          const logMax = Math.log10(20000);
          const percent = (Math.log10(freq) - logMin) / (logMax - logMin);
          const x = 40 + percent * (canvas.width - 50);

          if (x >= 40 && x <= canvas.width) {
            ctx.strokeStyle = 'rgba(148, 163, 184, 0.08)';
            ctx.beginPath();
            ctx.moveTo(x, 0);
            ctx.lineTo(x, canvas.height - 20);
            ctx.stroke();

            const label = freq >= 1000 ? (freq / 1000) + 'k' : freq;
            ctx.fillStyle = '#8fa5b7';
            ctx.fillText(label, x - 8, canvas.height - 5);
          }
        });
        
        ctx.strokeStyle = 'rgba(139, 92, 246, 0.2)';
        ctx.beginPath();
        ctx.moveTo(40, 0);
        ctx.lineTo(40, canvas.height - 20);
        ctx.lineTo(canvas.width, canvas.height - 20);
        ctx.stroke();
      }

      canvas.onmousemove = (e) => {
        if (!spectrumActive) return;

        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        const mouseX = (e.clientX - rect.left) * scaleX;
        const mouseY = (e.clientY - rect.top) * scaleY;

        if (mouseX < 40 || mouseX > canvas.width || mouseY > canvas.height - 20) {
          tooltip.style.display = 'none';
          return;
        }

        const logMin = Math.log10(20);
        const logMax = Math.log10(20000);
        const percent = (mouseX - 40) / (canvas.width - 50);
        const freq = Math.pow(10, logMin + percent * (logMax - logMin));
        const dbVal = -((mouseY / (canvas.height - 25)) * 100);

        if (freq > 0 && freq <= 22000) {
          tooltip.style.display = 'block';
          tooltip.style.left = (e.clientX - rect.left + 15) + 'px';
          tooltip.style.top = (e.clientY - rect.top - 15) + 'px';
          
          const freqText = freq >= 1000 ? (freq / 1000).toFixed(2) + ' kHz' : Math.floor(freq) + ' Hz';
          tooltip.innerHTML = `<strong>${freqText}</strong><br><span style="color:#a78bfa">${dbVal.toFixed(1)} dBFS</span>`;
        }
      };

      canvas.onmouseleave = () => {
        tooltip.style.display = 'none';
      };

      function draw() {
        if (!spectrumActive) return;
        spectrumAnimFrame = requestAnimationFrame(draw);

        const bufferLength = dawSpectrumAnalyser.frequencyBinCount;
        const dataArray = new Uint8Array(bufferLength);
        dawSpectrumAnalyser.getByteFrequencyData(dataArray);

        const graphWidth = canvas.width - 50;
        const logMin = Math.log10(20);
        const logMax = Math.log10(20000);
        const sampleRate = audioCtx.sampleRate;

        const totalBars = parseInt(document.getElementById('dawSettingBarsCount').value) || 45;
        if (dawPeakHoldArray.length !== totalBars) {
          dawPeakHoldArray = new Float32Array(totalBars).fill(0);
        }

        if (modoEspectroDAWAtivo === 'bars') {
          ctx.fillStyle = '#05070a';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          drawGrid();

          const barWidth = graphWidth / totalBars;

          for (let i = 0; i < totalBars; i++) {
            const percent = i / totalBars;
            const freq = Math.pow(10, logMin + percent * (logMax - logMin));
            
            const sampleIndex = Math.floor((freq / (sampleRate / 2)) * bufferLength);
            const value = dataArray[Math.min(sampleIndex, bufferLength - 1)];
            
            if (value > dawPeakHoldArray[i]) {
              dawPeakHoldArray[i] = value;
            } else {
              dawPeakHoldArray[i] -= 0.4;
            }

            const barHeight = (value / 255) * (canvas.height - 25);
            const xPos = 40 + (i * barWidth);

            if (barHeight > 0) {
              const gradient = ctx.createLinearGradient(0, canvas.height - 20, 0, canvas.height - 20 - barHeight);
              gradient.addColorStop(0, '#a78bfa');
              if (value > 210) {
                gradient.addColorStop(0.6, '#ffaa00');
                gradient.addColorStop(1, '#ff1a1a');
              } else {
                gradient.addColorStop(1, '#06b6d4');
              }
              
              ctx.fillStyle = gradient;
              ctx.beginPath();
              ctx.roundRect(xPos, canvas.height - 20 - barHeight, barWidth - 3, barHeight, [2, 2, 0, 0]);
              ctx.fill();
            }

            const peakHeight = (Math.max(0, dawPeakHoldArray[i]) / 255) * (canvas.height - 25);
            ctx.fillStyle = 'rgba(255, 30, 30, 0.8)';
            ctx.fillRect(xPos, canvas.height - 20 - peakHeight, barWidth - 3, 1.5);
          }
        } else if (modoEspectroDAWAtivo === 'line') {
          ctx.fillStyle = '#05070a';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          drawGrid();

          ctx.lineWidth = 2.5;
          const gradientLine = ctx.createLinearGradient(40, 0, canvas.width, 0);
          gradientLine.addColorStop(0, '#06b6d4');
          gradientLine.addColorStop(0.5, '#a78bfa');
          gradientLine.addColorStop(1, '#f43f5e');
          ctx.strokeStyle = gradientLine;
          
          ctx.beginPath();
          
          for (let x = 0; x < graphWidth; x++) {
            const percent = x / graphWidth;
            const freq = Math.pow(10, logMin + percent * (logMax - logMin));
            const bin = Math.floor((freq / (sampleRate / 2)) * bufferLength);
            const value = dataArray[Math.min(bin, bufferLength - 1)];

            const y = (canvas.height - 20) - ((value / 255) * (canvas.height - 25));
            const xPos = 40 + x;

            if (x === 0) ctx.moveTo(xPos, y);
            else ctx.lineTo(xPos, y);
          }
          ctx.stroke();
        } else if (modoEspectroDAWAtivo === 'spectrogram') {
          ctx.fillStyle = '#05070a';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          drawGrid();
          
          const bandWidth = graphWidth / totalBars;
          const numSegments = 14;
          const segmentHeight = (canvas.height - 25) / numSegments;

          for (let i = 0; i < totalBars; i++) {
            const percent = i / totalBars;
            const freq = Math.pow(10, logMin + percent * (logMax - logMin));
            
            const sampleIndex = Math.floor((freq / (sampleRate / 2)) * bufferLength);
            const value = dataArray[Math.min(sampleIndex, bufferLength - 1)];
            const activeSegments = Math.floor((value / 255) * numSegments);
            const xPos = 40 + (i * bandWidth);

            for (let j = 0; j < activeSegments; j++) {
              const yPos = (canvas.height - 20) - (j * segmentHeight) - segmentHeight;
              
              if (j > numSegments * 0.8) ctx.fillStyle = '#f43f5e';
              else if (j > numSegments * 0.5) ctx.fillStyle = '#eab308';
              else ctx.fillStyle = '#06b6d4';

              ctx.fillRect(xPos + 1, yPos + 1, bandWidth - 2, segmentHeight - 2);
            }
          }
        } else if (modoEspectroDAWAtivo === 'waterfall') {
          ctxAux.clearRect(0, 0, canvas.width, canvas.height);
          ctxAux.drawImage(canvas, 0, 0);
          
          ctx.fillStyle = '#05070a';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          ctx.drawImage(dawWaterfallCanvasAux, 0, 1.2); 

          const imgData = ctx.createImageData(graphWidth, 1);

          for (let x = 0; x < graphWidth; x++) {
            const percent = x / graphWidth;
            const freq = Math.pow(10, logMin + percent * (logMax - logMin));
            const bin = Math.floor((freq / (sampleRate / 2)) * bufferLength);
            const value = dataArray[Math.min(bin, bufferLength - 1)];

            let r = 0, g = 0, b = 0;
            if (value > 0) {
              const v = value / 255;
              r = Math.floor(Math.max(0, Math.min(255, (v * 1.6) * 255)));
              g = Math.floor(Math.max(0, Math.min(255, (v * v * 1.3) * 255)));
              b = Math.floor(Math.max(0, Math.min(255, Math.sin(v * Math.PI) * 190)));
            }

            const pixelIdx = x * 4;
            imgData.data[pixelIdx] = r;
            imgData.data[pixelIdx + 1] = g;
            imgData.data[pixelIdx + 2] = b;
            imgData.data[pixelIdx + 3] = value > 10 ? 255 : value * 25;
          }
          ctx.putImageData(imgData, 40, 0);
          drawGrid();
        }
      }

      draw();
    }
  </script>


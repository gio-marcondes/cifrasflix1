        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
          e.preventDefault();
          const file = e.dataTransfer.files[0];
          if (!file.type.startsWith('audio/')) {
            mostrarStatus("⚠️ Por favor, arraste apenas arquivos de áudio!", 4000);
            return;
          }

          // Calcular tempo do drop relativo à timeline

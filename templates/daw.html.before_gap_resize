          const fx = track?.effects[effectIndex];
          const active = fx ? fx.params.mf_active : true;
          n.mfNode.gain.setValueAtTime(active ? value : 0, currentTime);
        }
        if (param === 'mf_q') n.mfNode.Q.setValueAtTime(value, currentTime);
        if (param === 'mf_active') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const gain = fx ? fx.params.mf_gain : 0;
          n.mfNode.gain.setValueAtTime(value ? gain : 0, currentTime);
        }

        if (param === 'hmf_freq') n.hmfNode.frequency.setValueAtTime(value, currentTime);
        if (param === 'hmf_gain') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const active = fx ? fx.params.hmf_active : true;
          n.hmfNode.gain.setValueAtTime(active ? value : 0, currentTime);
        }
        if (param === 'hmf_q') n.hmfNode.Q.setValueAtTime(value, currentTime);
        if (param === 'hmf_active') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const gain = fx ? fx.params.hmf_gain : 0;
          n.hmfNode.gain.setValueAtTime(value ? gain : 0, currentTime);
        }

        if (param === 'hf_freq') n.hfNode.frequency.setValueAtTime(value, currentTime);
        if (param === 'hf_gain') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const active = fx ? fx.params.hf_active : true;
          n.hfNode.gain.setValueAtTime(active ? value : 0, currentTime);
        }
        if (param === 'hf_active') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const gain = fx ? fx.params.hf_gain : 0;
          n.hfNode.gain.setValueAtTime(value ? gain : 0, currentTime);
        }

        if (param === 'hc_freq') n.hcNode.frequency.setValueAtTime(value, currentTime);
        if (param === 'hc_q') n.hcNode.Q.setValueAtTime(value, currentTime);
        if (param === 'hc_active') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const activeFreq = fx ? fx.params.hc_freq : 20000;
          n.hcNode.frequency.setValueAtTime(value ? activeFreq : 22000, currentTime);
        }
      }
      else if (effectNode.type === 'eq') {
        if (param === 'bass') nodes.lowNode.gain.setValueAtTime(value, currentTime);
        if (param === 'mid') nodes.midNode.gain.setValueAtTime(value, currentTime);
        if (param === 'treble') nodes.highNode.gain.setValueAtTime(value, currentTime);
      } 
      else if (effectNode.type === 'delay') {
        if (param === 'delayTime') nodes.delayNode.delayTime.setValueAtTime(value, currentTime);
        if (param === 'feedback') nodes.feedbackGain.gain.setValueAtTime(value, currentTime);
        if (param === 'mix') {
          nodes.wetGain.gain.setValueAtTime(value, currentTime);
          nodes.dryGain.gain.setValueAtTime(1.0 - value, currentTime);
        }
      } 
      else if (effectNode.type === 'reverb') {

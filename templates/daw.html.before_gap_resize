          dropTime = Math.max(0, dropTime);

          // Find target track under Y drop position
          let targetTrack = null;
          if (offsetY > 36) {            let cumulativeHeight = 36;
            let trackIdx = -1;
            for (let i = 0; i < tracks.length; i++) {
              cumulativeHeight += tracks[i].height || 120;
              if (offsetY < cumulativeHeight) { trackIdx = i; break; }

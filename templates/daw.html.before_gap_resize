    async function importarArquivoDeAudioParaTrilha(file, trackId, clientX, trackRow) {
      if (!file.type.startsWith('audio/')) {
        mostrarStatus("⚠️ Por favor, arraste apenas arquivos de áudio!", 4000);
        return;
      }

      mostrarStatus(`⏳ Carregando e decodificando "${file.name}"...`, 0);

      try {
        const arrayBuffer = await file.arrayBuffer();
        const decoded = await audioCtx.decodeAudioData(arrayBuffer);

        const bufferKey = `file-${Date.now()}`;
        audioBufferCache.set(bufferKey, decoded);

        // Calcular tempo do drop relativo à linha
        const rect = trackRow.getBoundingClientRect();
        const offsetX = clientX - rect.left;
        let dropTime = offsetX / PX_PER_SECOND;

        // Snapping
        const snap = document.getElementById('selectSnap').value;
        if (snap !== "none") {
          const secondsPerBeat = 60.0 / bpm;
          const interval = secondsPerBeat * parseFloat(snap);
          dropTime = Math.round(dropTime / interval) * interval;
        }
        dropTime = Math.max(0, dropTime);

        const track = tracks.find(t => t.id === trackId);
        if (track) {
          saveHistory();
          track.regions.push({
            id: `region-${Date.now()}`,
            name: file.name.replace(/\.[^/.]+$/, ""),
            startTime: dropTime,
            duration: decoded.duration,
            offset: 0,
            bufferKey: bufferKey,
            buffer: decoded
          });
          songEnd = dropTime + decoded.duration;
          loopEnd = dropTime + decoded.duration;
          updateMarkersPosition();
          renderDAW();
          mostrarStatus(`✅ "${file.name}" importado com sucesso!`, 4000);
        }
      } catch (err) {
        mostrarStatus(`❌ Erro ao importar: ${err.message}`, 5000);
      }
    }


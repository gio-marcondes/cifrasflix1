  <!-- JavaScript Principal do Motor DAW -->
  <script>
    // =========================================================================
    // 🎧 MODAL CONTROLLER
    // =========================================================================
    function fecharModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
            modal.style.display = 'none';
        }
    }

    function fecharModalFx() {
        fecharModal('modalFxRack');
    }

    let statusTimeout = null;
    function mostrarStatus(mensagem, duracao = 4000) {
      const statusEl = document.getElementById('footerStatus');
      if (!statusEl) return;
      statusEl.textContent = mensagem;
      statusEl.style.display = 'inline-block';
      
      if (duracao > 0) {
        if (statusTimeout) clearTimeout(statusTimeout);
        statusTimeout = setTimeout(() => {
          statusEl.style.display = 'none';
        }, duracao);
      }
    }

    // Adiciona listeners para fechar modais
    document.querySelectorAll('.modal-daw').forEach(modal => {
        // Fechar ao clicar no fundo
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                fecharModal(modal.id);
            }
        });
        // Fechar com a tecla Esc
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal.style.display === 'flex') {
                fecharModal(modal.id);
            }
        });
    });

    // Inicialização da API Web Audio com latência interativa
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)({
      latencyHint: 'interactive'
    });
    
    // Nós do Mixer Master
    const masterGain = audioCtx.createGain();
    const compressorNode = audioCtx.createDynamicsCompressor();
    const dawSpectrumAnalyser = audioCtx.createAnalyser();
    dawSpectrumAnalyser.fftSize = 2048;
    
    // Equalizador 3 Bandas
    const eqLow = audioCtx.createBiquadFilter();
    eqLow.type = 'lowshelf';
    eqLow.frequency.value = 220; // limite de graves

    const eqMid = audioCtx.createBiquadFilter();
    eqMid.type = 'peaking';
    eqMid.frequency.value = 1000;
    eqMid.Q.value = 1.0;

    const eqHigh = audioCtx.createBiquadFilter();
    eqHigh.type = 'highshelf';
    eqHigh.frequency.value = 4500; // limite de agudos

    // Reverb Convolver
    const reverbNode = audioCtx.createConvolver();
    const reverbGainNode = audioCtx.createGain();
    const reverbDryNode = audioCtx.createGain();

    // Estado Geral da DAW
    let bpm = 120;
    let loop = false;
    let metronome = false;
    let autoScroll = true;
    let cutMode = false;
    let regionMode = false;
    let regionSelectionActive = false;
    let selectionStart = null;
    let selectionEnd = null;
    let selectionTrackId = null;
    let selectionTrackRowElement = null;
    let isSelectingRegion = false;
    let activeInputDeviceId = "";
    let activeOutputDeviceId = "";
    let disableBrowserAudioProcessing = true; // Por padrão, remove eco/ruído/gain control para gravação de estúdio

    function getAudioConstraints() {
      const constraints = {
        audio: {}
      };
      if (activeInputDeviceId) {
        constraints.audio.deviceId = { exact: activeInputDeviceId };
      }
      if (disableBrowserAudioProcessing) {
        constraints.audio.echoCancellation = false;
        constraints.audio.noiseSuppression = false;
        constraints.audio.autoGainControl = false;
      } else {
        constraints.audio.echoCancellation = true;
        constraints.audio.noiseSuppression = true;
        constraints.audio.autoGainControl = true;
      }
      return constraints;
    }
    let timelinePosition = 0; // Posição atual do cursor (em segundos)
    let playbackStartTime = 0; // Hora de início do contexto de áudio
    let isPlaying = false;
    let tracks = [];
    let activeNodes = [];
    let activeMonitors = new Map(); // trackId -> { stream, sourceNode, monitorGain, monitorPanner, analyser, chain }
    let playbackAnalysers = new Map(); // trackId -> AnalyserNode
    let vuAnimationId = null;
    let undoHistory = [];
    let redoHistory = [];
    let metronomeTimer = null;
    let activeTrackChains = {};
    let activeFxTrackId = null;
    let selectedTrackId = null;
    let selectedRegionId = null;
    let selectedRegionTrackId = null;
    let selectedRegionIds = new Set();
    let clipboardRegion = null;
    let tomAtual = 'C';
    const TONE_ORDER = ['C', 'C#', 'D', 'Eb', 'E', 'F', 'F#', 'G', 'Ab', 'A', 'Bb', 'B'];

    // Cache local de áudio buffers
    const audioBufferCache = new Map();

    // Gravação via Microfone
    let mediaRecorder = null;
    let recordedChunks = [];
    let activeRecordTrackId = null;
    let recordStartTime = 0;
    let recAnalyser = null;
    let activeEditingEffectIndex = 0;
    let fxSnapshotBackup = null;

    // Pro EQ (Visual) Frequências Logarítmicas e cache de filtros
    const PRO_EQ_BINS = 150;
    const proEqFrequencies = new Float32Array(PRO_EQ_BINS);
    for (let i = 0; i < PRO_EQ_BINS; i++) {
      const minF = 20;
      const maxF = 20000;
      proEqFrequencies[i] = minF * Math.pow(maxF / minF, i / (PRO_EQ_BINS - 1));
    }
    let cachedProEqFilters = null;
    function getCachedProEqFilters() {
      if (!cachedProEqFilters) {
        cachedProEqFilters = [
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter(),
          audioCtx.createBiquadFilter()
        ];
      }
      return cachedProEqFilters;
    }
    function getXForFreq(freq, w) {
      const minF = 20;
      const maxF = 20000;
      return w * (Math.log(freq / minF) / Math.log(maxF / minF));
    }

    function getPlaybackRate() {
        const bpmBase = 120; // ou um valor base do projeto
        const bpmAtual = parseInt(document.getElementById('inputBpm').value, 10);
        return bpmAtual / bpmBase;
    }

    function getPitchShiftRate(baseTone = 'C') {
        const diff = TONE_ORDER.indexOf(tomAtual) - TONE_ORDER.indexOf(baseTone);
        return Math.pow(2, diff / 12);
    }


    // Dimensões Visuais da Grid da Timeline
    let PX_PER_SECOND = 40; // Zoom da grid (1 segundo = 40 pixels)
    const TRACK_GAP = 8;

    // Variáveis Globais de limites e repetição (song/loop bounds)
    let songStart = 0;
    let songEnd = 30; // 30s padrão para ficar mais perto
    let loopStart = 5;
    let loopEnd = 15; // 10s de loop padrão

    function updateMarkersPosition() {
      drawTimeline();
    }

    function setupMarkerDragging() {
      // Handled by the canvas state machine
    }


    // Configurando conexões Master
    // Cadeia: EQ Low -> EQ Mid -> EQ High -> Compressor -> MasterGain -> Destination
    // Roteamento Reverb: EQ High divide para reverb e dry, que se juntam no Compressor
    eqLow.connect(eqMid);
    eqMid.connect(eqHigh);
    
    // Roteamento Dry/Wet para Reverb
    eqHigh.connect(reverbDryNode);
    eqHigh.connect(reverbNode);
    reverbNode.connect(reverbGainNode);

    reverbDryNode.connect(compressorNode);
    reverbGainNode.connect(compressorNode);

    compressorNode.connect(masterGain);
    masterGain.connect(audioCtx.destination);
    masterGain.connect(dawSpectrumAnalyser);

    // Ajustando estados iniciais do Mixer Master
    reverbDryNode.gain.value = 1.0;
    reverbGainNode.gain.value = 0.0; // reverb desligado inicialmente

    // =========================================================================
    // 🎧 UTILS & AUXILIARES
    // =========================================================================

    // Sintetizar resposta de impulso para o Reverb de Sala
    function generateReverbImpulse(duration, decay) {
      return generateReverbImpulseWithContext(audioCtx, duration, decay);
    }

    function generateReverbImpulseWithContext(context, duration, decay) {
      const sampleRate = context.sampleRate;
      const length = sampleRate * duration;
      const impulse = context.createBuffer(2, length, sampleRate);
      for (let ch = 0; ch < 2; ch++) {
        const channelData = impulse.getChannelData(ch);
        for (let i = 0; i < length; i++) {
          channelData[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / length, decay);
        }
      }
      return impulse;
    }

    // Gerar curva de distorção de overdrive
    function makeDistortionCurve(amount) {
      const k = typeof amount === 'number' ? amount : 50;
      const n_samples = 44100;
      const curve = new Float32Array(n_samples);
      const deg = Math.PI / 180;
      for (let i = 0; i < n_samples; ++i) {
        const x = (i * 2) / n_samples - 1;
        curve[i] = ((3 + k) * x * 20 * deg) / (Math.PI + k * Math.abs(x));
      }
      return curve;
    }

    // Converter AudioBuffer para WAV (Blob)
    function bufferToWav(buffer) {
      let numOfChan = buffer.numberOfChannels,
          length = buffer.length * numOfChan * 2 + 44,
          bufferArr = new ArrayBuffer(length),
          view = new DataView(bufferArr),
          channels = [], i, sample,
          offset = 0,
          pos = 0;

      // RIFF
      setUint32(0x46464952);
      setUint32(length - 8);
      // WAVE
      setUint32(0x45564157);
      // fmt
      setUint32(0x20746d66);
      setUint32(16);
      setUint16(1);
      setUint16(numOfChan);
      setUint32(buffer.sampleRate);
      setUint32(buffer.sampleRate * 2 * numOfChan);
      setUint16(numOfChan * 2);
      setUint16(16);
      // data
      setUint32(0x61746164);
      setUint32(length - pos - 4);

      for (i = 0; i < buffer.numberOfChannels; i++) {
        channels.push(buffer.getChannelData(i));
      }

      while (pos < length) {
        for (i = 0; i < numOfChan; i++) {
          sample = Math.max(-1, Math.min(1, channels[i][offset]));
          sample = (sample < 0 ? sample * 0x8000 : sample * 0x7FFF);
          view.setInt16(pos, sample, true);
          pos += 2;
        }
        offset++;
      }

      return new Blob([bufferArr], { type: "audio/wav" });

      function setUint16(data) {
        view.setUint16(pos, data, true);
        pos += 2;
      }
      function setUint32(data) {
        view.setUint32(pos, data, true);
        pos += 4;
      }
    }

    // Converter AudioBuffer para MP3 (Blob) usando lamejs
    function bufferToMp3(audioBuffer) {
      const channels = audioBuffer.numberOfChannels;
      const sampleRate = audioBuffer.sampleRate;
      const mp3encoder = new lamejs.Mp3Encoder(channels, sampleRate, 128); // 128 kbps
      const mp3Data = [];

      const sampleBlockSize = 1152;
      const left = audioBuffer.getChannelData(0);
      const right = channels > 1 ? audioBuffer.getChannelData(1) : new Float32Array(left.length);

      // Converter Float32Array PCM para Int16Array PCM
      const leftInt = new Int16Array(left.length);
      const rightInt = new Int16Array(right.length);
      for (let i = 0; i < left.length; i++) {
        leftInt[i] = Math.min(1, Math.max(-1, left[i])) * 32767;
        rightInt[i] = Math.min(1, Math.max(-1, right[i])) * 32767;
      }

      for (let i = 0; i < left.length; i += sampleBlockSize) {
        const leftChunk = leftInt.subarray(i, i + sampleBlockSize);
        const rightChunk = rightInt.subarray(i, i + sampleBlockSize);
        let mp3buf;
        if (channels === 2) {
          mp3buf = mp3encoder.encodeBuffer(leftChunk, rightChunk);
        } else {
          mp3buf = mp3encoder.encodeBuffer(leftChunk);
        }
        if (mp3buf.length > 0) {
          mp3Data.push(mp3buf);
        }
      }

      const mp3buf = mp3encoder.flush();
      if (mp3buf.length > 0) {
        mp3Data.push(mp3buf);
      }

      return new Blob(mp3Data, { type: 'audio/mp3' });
    }


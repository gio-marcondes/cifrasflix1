    function drawProEqCurve(canvas, params) {
      const ctx = canvas.getContext('2d');
      const w = canvas.width;
      const h = canvas.height;

      ctx.fillStyle = '#0a0d18';
      ctx.fillRect(0, 0, w, h);

      const filters = getCachedProEqFilters();
      
      filters[0].type = 'highpass';
      filters[0].frequency.value = params.lc_active ? params.lc_freq : 10;
      filters[0].Q.value = params.lc_q;

      filters[1].type = 'lowshelf';
      filters[1].frequency.value = params.lf_freq;
      filters[1].gain.value = params.lf_active ? params.lf_gain : 0;
      filters[1].Q.value = params.lf_q;

      filters[2].type = 'peaking';
      filters[2].frequency.value = params.lmf_freq;
      filters[2].gain.value = params.lmf_active ? params.lmf_gain : 0;
      filters[2].Q.value = params.lmf_q;

      filters[3].type = 'peaking';
      filters[3].frequency.value = params.mf_freq;
      filters[3].gain.value = params.mf_active ? params.mf_gain : 0;
      filters[3].Q.value = params.mf_q;

      filters[4].type = 'peaking';
      filters[4].frequency.value = params.hmf_freq;
      filters[4].gain.value = params.hmf_active ? params.hmf_gain : 0;
      filters[4].Q.value = params.hmf_q;

      filters[5].type = 'highshelf';
      filters[5].frequency.value = params.hf_freq;
      filters[5].gain.value = params.hf_active ? params.hf_gain : 0;
      filters[5].Q.value = params.hf_q;

      filters[6].type = 'lowpass';
      filters[6].frequency.value = params.hc_active ? params.hc_freq : 22000;
      filters[6].Q.value = params.hc_q;

      const bins = PRO_EQ_BINS;
      const magResponse = new Float32Array(bins);
      const phaseResponse = new Float32Array(bins);
      
      const totalMag = new Float32Array(bins);
      totalMag.fill(1.0);

      filters.forEach(filter => {
        filter.getFrequencyResponse(proEqFrequencies, magResponse, phaseResponse);
        for (let i = 0; i < bins; i++) {
          totalMag[i] *= magResponse[i];
        }
      });

      // Grid Y (dB: 18, 12, 6, 0, -6, -12, -18)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
      ctx.lineWidth = 1;
      
      const dbLines = [18, 12, 6, 0, -6, -12, -18];
      dbLines.forEach(db => {
        const y = h / 2 - (db / 24) * (h / 2);
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(w, y);
        ctx.stroke();

        ctx.fillStyle = 'rgba(255, 255, 255, 0.35)';
        ctx.font = '8px monospace';
        ctx.fillText(`${db > 0 ? '+' : ''}${db}dB`, 5, y - 2);
      });

      // Grid X (Hz: 50, 100, 200, 500, 1000, 2000, 5000, 10000)
      const hzLines = [50, 100, 200, 500, 1000, 2000, 5000, 10000];
      hzLines.forEach(hz => {
        const x = getXForFreq(hz, w);
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, h);
        ctx.stroke();

        ctx.fillStyle = 'rgba(255, 255, 255, 0.35)';
        const text = hz >= 1000 ? `${hz / 1000}k` : `${hz}`;
        ctx.fillText(text, x + 2, h - 5);
      });

      // Draw response curve
      ctx.beginPath();
      for (let i = 0; i < bins; i++) {
        const f = proEqFrequencies[i];
        const x = getXForFreq(f, w);
        const db = 20 * Math.log10(Math.max(1e-5, totalMag[i]));
        const y = h / 2 - (db / 24) * (h / 2);
        
        if (i === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }

      ctx.strokeStyle = '#22d3ee'; // Neon cyan
      ctx.lineWidth = 2;
      ctx.stroke();

      // Draw dots
      const bands = [
        { name: 'LC', freq: params.lc_freq, active: params.lc_active, color: '#f97316' },
        { name: 'LF', freq: params.lf_freq, active: params.lf_active, color: '#eab308' },
        { name: 'LMF', freq: params.lmf_freq, active: params.lmf_active, color: '#22c55e' },
        { name: 'MF', freq: params.mf_freq, active: params.mf_active, color: '#3b82f6' },
        { name: 'HMF', freq: params.hmf_freq, active: params.hmf_active, color: '#a855f7' },
        { name: 'HF', freq: params.hf_freq, active: params.hf_active, color: '#ec4899' },
        { name: 'HC', freq: params.hc_freq, active: params.hc_active, color: '#ffffff' }
      ];

      bands.forEach(band => {
        if (!band.active) return;
        const x = getXForFreq(band.freq, w);
        
        let totalMagAtFreq = 1.0;
        const fArr = new Float32Array([band.freq]);
        const mArr = new Float32Array(1);
        const pArr = new Float32Array(1);
        
        filters.forEach(filter => {
          filter.getFrequencyResponse(fArr, mArr, pArr);
          totalMagAtFreq *= mArr[0];
        });
        
        const db = 20 * Math.log10(Math.max(1e-5, totalMagAtFreq));
        const y = h / 2 - (db / 24) * (h / 2);

        ctx.beginPath();
        ctx.arc(x, y, 4, 0, 2 * Math.PI);
        ctx.fillStyle = band.color;
        ctx.fill();
        ctx.strokeStyle = '#0a0d18';
        ctx.lineWidth = 1;
        ctx.stroke();

        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 8px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(band.name, x, y - 6);
      });
    }


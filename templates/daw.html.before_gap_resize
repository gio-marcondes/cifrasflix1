    // =========================================================================
    // 🎚️ SISTEMA DE MONITORAMENTO DE ENTRADA & VU METERS
    // =========================================================================

    async function toggleMonitor(trackId) {
      const track = tracks.find(t => t.id === trackId);
      if (!track) return;

      track.monitoring = !track.monitoring;
      const monitorBtn = document.querySelector(`.monitor-btn[data-track-id="${trackId}"]`);
      if (monitorBtn) {
        monitorBtn.classList.toggle('active', track.monitoring);
      }

      if (track.monitoring) {
        await startMonitoring(track);
      } else {
        stopMonitoring(track.id);
      }
    }

    async function startMonitoring(track) {
      if (activeMonitors.has(track.id)) return;

      try {
        const constraints = getAudioConstraints();
        const stream = await navigator.mediaDevices.getUserMedia(constraints);

        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }

        const sourceNode = audioCtx.createMediaStreamSource(stream);

        const monitorGain = audioCtx.createGain();
        monitorGain.gain.value = track.volume / 100;

        const monitorPanner = audioCtx.createStereoPanner();
        monitorPanner.pan.value = track.pan / 100;

        sourceNode.connect(monitorGain);
        monitorGain.connect(monitorPanner);

        // Analisador para o VU meter em tempo real
        const monitorAnalyser = audioCtx.createAnalyser();
        monitorAnalyser.fftSize = 256;
        monitorPanner.connect(monitorAnalyser);

        // Conecta à cadeia de efeitos da trilha
        const chain = buildTrackSignalChain(track, monitorAnalyser, audioCtx, eqLow);

        activeMonitors.set(track.id, {
          stream,
          sourceNode,
          monitorGain,
          monitorPanner,
          analyser: monitorAnalyser,
          chain
        });

        checkStartVULoop();
      } catch (err) {
        console.error("Erro ao iniciar monitoramento:", err);
        track.monitoring = false;
        const monitorBtn = document.querySelector(`.monitor-btn[data-track-id="${track.id}"]`);
        if (monitorBtn) monitorBtn.classList.remove('active');
        alert("Não foi possível acessar o microfone para monitoramento: " + err.message);
      }
    }

    function stopMonitoring(trackId) {
      const monitor = activeMonitors.get(trackId);
      if (monitor) {
        try {
          monitor.stream.getTracks().forEach(t => t.stop());
        } catch(e){}
        try { monitor.sourceNode.disconnect(); } catch (e) {}
        try { monitor.monitorGain.disconnect(); } catch (e) {}
        try { monitor.monitorPanner.disconnect(); } catch (e) {}
        activeMonitors.delete(trackId);
      }
    }

    function rebuildMonitorSignalChains() {
      activeMonitors.forEach((monitor, trackId) => {
        const track = tracks.find(t => t.id === trackId);
        if (track) {
          stopMonitoring(trackId);
          startMonitoring(track);
        }
      });
    }

    function calculateLufs(analyserNode) {
      if (!analyserNode) return -Infinity;
      const data = new Float32Array(analyserNode.fftSize);
      analyserNode.getFloatTimeDomainData(data);
      
      let sum = 0;
      for (let i = 0; i < data.length; i++) {
        const sample = data[i];
        sum += sample * sample;
      }
      
      const rms = Math.sqrt(sum / data.length);
      const rmsDb = 20 * Math.log10(rms + 0.000001);
      return rmsDb - 3.0;
    }

    function updateAllTrackLufsMeters() {
      const displays = document.querySelectorAll('.sidebar-lufs-display');
      displays.forEach(display => {
        const trackId = display.dataset.trackId;
        const effectIndex = parseInt(display.dataset.effectIndex, 10);
        
        let chain = activeTrackChains[trackId];
        if (!chain && activeMonitors.has(trackId)) {
          chain = activeMonitors.get(trackId).chain;
        }

        const valueEl = display.querySelector('.track-lufs-value');
        const fillEl = display.querySelector('.lufs-meter-bar-fill');
        
        if (!chain || !chain.effects || !chain.effects[effectIndex] || chain.effects[effectIndex].bypassed) {
          if (valueEl) {
            valueEl.style.color = 'var(--text-muted)';
            valueEl.textContent = '--';
          }
          if (fillEl) fillEl.style.width = '0%';
          return;
        }

        const effectNode = chain.effects[effectIndex];
        const analyser = effectNode.nodes ? effectNode.nodes.analyserNode : null;
        if (!analyser) return;

        const lufsApprox = calculateLufs(analyser);

        if (lufsApprox > -100) {
          const track = tracks.find(t => t.id === trackId);
          const effect = track?.effects[effectIndex];
          if (effect) {
            if (effect.lufsSmooth === undefined || effect.lufsSmooth === -14) {
              effect.lufsSmooth = lufsApprox;
            } else {
              effect.lufsSmooth = effect.lufsSmooth * 0.95 + lufsApprox * 0.05;
            }

            if (valueEl) {
              if (effect.lufsSmooth <= -13 && effect.lufsSmooth >= -15) {
                valueEl.style.color = '#00ff88';
              } else if (effect.lufsSmooth > -10) {
                valueEl.style.color = '#ff4444';
              } else {
                valueEl.style.color = '#ffaa00';
              }
              valueEl.textContent = effect.lufsSmooth.toFixed(1) + ' LUFS';
            }

            if (fillEl) {
              let pct = 0;
              if (effect.lufsSmooth > -60) {
                pct = ((effect.lufsSmooth + 60) / 60) * 100;
              }
              pct = Math.min(100, Math.max(0, pct));
              fillEl.style.width = `${pct}%`;
            }
          }
        } else {
          if (valueEl) {
            valueEl.style.color = 'var(--text-muted)';
            valueEl.textContent = '--';
          }
          if (fillEl) fillEl.style.width = '0%';
        }
      });
    }

    function updateAllVUMeters() {
      tracks.forEach(track => {
        const bar = document.getElementById(`vu-bar-${track.id}`);
        if (!bar) return;

        let maxVal = 0;

        // 1. Monitoramento ativo
        const monitor = activeMonitors.get(track.id);
        if (monitor && monitor.analyser) {
          maxVal = getAnalyserVolume(monitor.analyser);
        }

        // 2. Playback ativo
        const playbackAnalyser = playbackAnalysers.get(track.id);
        if (playbackAnalyser) {
          const playbackVal = getAnalyserVolume(playbackAnalyser);
          if (playbackVal > maxVal) maxVal = playbackVal;
        }

        // 3. Gravação ativa
        if (activeRecordTrackId === track.id && recAnalyser) {
          const recVal = getAnalyserVolume(recAnalyser);
          if (recVal > maxVal) maxVal = recVal;
        }

        // Converter volume para porcentagem (escala de 0 a 140 para máxima sensibilidade)
        const percentage = Math.min(100, Math.max(0, (maxVal / 140) * 100));
        bar.style.height = `${percentage}%`;
      });

      // Update master LUFS meter
      const masterLufs = calculateLufs(dawSpectrumAnalyser);
      if (masterLufs > -100) {
        if (!window.masterLufsSmooth || window.masterLufsSmooth === -14) {
          window.masterLufsSmooth = masterLufs;
        } else {
          window.masterLufsSmooth = window.masterLufsSmooth * 0.95 + masterLufs * 0.05;
        }
        const masterLufsEl = document.getElementById('masterLufsValue');
        if (masterLufsEl) {
          if (window.masterLufsSmooth <= -13 && window.masterLufsSmooth >= -15) {
            masterLufsEl.style.color = '#00ff88';
          } else if (window.masterLufsSmooth > -10) {
            masterLufsEl.style.color = '#ff4444';
          } else {
            masterLufsEl.style.color = '#ffaa00';
          }
          masterLufsEl.textContent = window.masterLufsSmooth.toFixed(1) + ' LUFS';
        }
      } else {
        const masterLufsEl = document.getElementById('masterLufsValue');
        if (masterLufsEl) {
          masterLufsEl.style.color = 'var(--text-muted)';
          masterLufsEl.textContent = '--';
        }
      }

      // Update individual track LUFS meters
      updateAllTrackLufsMeters();

      if (isPlaying || activeMonitors.size > 0 || (mediaRecorder && mediaRecorder.state === "recording")) {
        vuAnimationId = requestAnimationFrame(updateAllVUMeters);
      } else {
        // Reset das barras para 0%
        tracks.forEach(track => {
          const bar = document.getElementById(`vu-bar-${track.id}`);
          if (bar) bar.style.height = '0%';
        });
        
        // Reset master LUFS value
        const masterLufsEl = document.getElementById('masterLufsValue');
        if (masterLufsEl) {
          masterLufsEl.style.color = 'var(--text-muted)';
          masterLufsEl.textContent = '--';
        }
        window.masterLufsSmooth = -14;

        // Reset individual track LUFS meters
        document.querySelectorAll('.sidebar-lufs-display').forEach(display => {
          const valueEl = display.querySelector('.track-lufs-value');
          const fillEl = display.querySelector('.lufs-meter-bar-fill');
          if (valueEl) {
            valueEl.style.color = 'var(--text-muted)';
            valueEl.textContent = '--';
          }
          if (fillEl) fillEl.style.width = '0%';
          
          const trackId = display.dataset.trackId;
          const effectIndex = parseInt(display.dataset.effectIndex, 10);
          const track = tracks.find(t => t.id === trackId);
          const effect = track?.effects[effectIndex];
          if (effect) {
            effect.lufsSmooth = -14;
          }
        });

        vuAnimationId = null;
      }
    }

    function getAnalyserVolume(analyser) {
      const dataArray = new Uint8Array(analyser.frequencyBinCount);
      analyser.getByteFrequencyData(dataArray);
      let sum = 0;
      for (let i = 0; i < dataArray.length; i++) {
        sum += dataArray[i];
      }
      return sum / dataArray.length;
    }

    function checkStartVULoop() {
      if (!vuAnimationId) {
        updateAllVUMeters();
      }
    }

    // =========================================================================
    // 🎙️ SISTEMA DE GRAVAÇÃO DO MICROFONE (● REC)
    // =========================================================================

    async function toggleRecord(trackId) {
      if (mediaRecorder && mediaRecorder.state === "recording") {
        // Se já está gravando, para a gravação
        mediaRecorder.stop();
        if (isPlaying) pauseDAW();
        return;
      }

      try {
        let stream;
        const monitor = activeMonitors.get(trackId);
        if (monitor && monitor.stream) {
          stream = monitor.stream;
        } else {
          const constraints = getAudioConstraints();
          stream = await navigator.mediaDevices.getUserMedia(constraints);
        }
        
        // Garante que o AudioContext está rodando
        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }

        mediaRecorder = new MediaRecorder(stream);
        recordedChunks = [];
        activeRecordTrackId = trackId;
        recordStartTime = timelinePosition;

        // Configura Analisador de Áudio para Waveform em tempo real
        try {
          const sourceNode = audioCtx.createMediaStreamSource(stream);
          recAnalyser = audioCtx.createAnalyser();
          recAnalyser.fftSize = 2048;
          sourceNode.connect(recAnalyser);
        } catch (e) {
          console.warn("Erro ao configurar analisador para waveform:", e);
        }

        mediaRecorder.ondataavailable = (event) => {
          if (event.data.size > 0) {
            recordedChunks.push(event.data);
          }
        };

        mediaRecorder.onstop = async () => {
          // Desliga microfone APENAS se não estiver monitorando
          const targetTrack = tracks.find(t => t.id === activeRecordTrackId);
          if (!targetTrack || !targetTrack.monitoring) {
            stream.getTracks().forEach(track => track.stop()); // Desliga microfone
          }
          recAnalyser = null;
          
          const blob = new Blob(recordedChunks, { type: 'audio/webm' });
          const arrayBuffer = await blob.arrayBuffer();
          const recordedBuffer = await audioCtx.decodeAudioData(arrayBuffer);

          // Salvar buffer no cache local
          const bufferKey = `rec-${Date.now()}`;
          audioBufferCache.set(bufferKey, recordedBuffer);

          // Criar nova região na trilha ativa
          if (targetTrack) {
            saveHistory();
            targetTrack.regions.push({
              id: `region-${Date.now()}`,
              name: `Gravado ${formatDigitalTime(recordStartTime)}`,
              startTime: recordStartTime,
              duration: recordedBuffer.duration,
              offset: 0,
              bufferKey: bufferKey,
              buffer: recordedBuffer
            });
            songEnd = recordStartTime + recordedBuffer.duration;
            loopEnd = recordStartTime + recordedBuffer.duration;
            updateMarkersPosition();
            renderDAW();
          }

          // Limpar status de gravação
          const recBtn = document.querySelector(`.rec-btn[data-track-id="${activeRecordTrackId}"]`);
          if (recBtn) recBtn.classList.remove('active');
          document.getElementById('btnPlay').classList.remove('active');
          mediaRecorder = null;
        };

        // Iniciar
        mediaRecorder.start();
        checkStartVULoop();
        
        // Mudar estado dos botões
        const recBtn = document.querySelector(`.rec-btn[data-track-id="${trackId}"]`);
        if (recBtn) recBtn.classList.add('active');

        // Força renderização para instanciar o preview de gravação
        renderDAW();

        // Começar tocar playback em sync para gravação simultânea
        playDAW();

      } catch (err) {
        alert("Não foi possível acessar seu microfone: " + err.message);
      }
    }

    // =========================================================================
    // ⬇️ RENDERIZAR E EXPORTAR MIX COMPLETA (OFFLINE AUDIO CONTEXT)
    // =========================================================================

    async function exportMixdown(format = 'wav') {
      const totalDuration = songEnd - songStart;

      if (totalDuration <= 0) {
        mostrarStatus("⚠️ Adicione algum áudio na timeline antes de exportar!", 4000);
        return;
      }

      mostrarStatus(`⏳ Preparando exportação (${format.toUpperCase()}) de ${Math.round(totalDuration)} segundos...`, 0);

      // 2. Criar contexto offline
      const sampleRate = audioCtx.sampleRate;
      const offlineCtx = new OfflineAudioContext(2, sampleRate * totalDuration, sampleRate);

      // 3. Replicar mixer e efeitos no contexto offline
      const offlineMasterGain = offlineCtx.createGain();
      offlineMasterGain.gain.value = masterGain.gain.value;

      // EQ offline
      const offEqLow = offlineCtx.createBiquadFilter();
      offEqLow.type = 'lowshelf';
      offEqLow.frequency.value = eqLow.frequency.value;
      offEqLow.gain.value = eqLow.gain.value;

      const offEqMid = offlineCtx.createBiquadFilter();
      offEqMid.type = 'peaking';
      offEqMid.frequency.value = eqMid.frequency.value;
      offEqMid.gain.value = eqMid.gain.value;

      const offEqHigh = offlineCtx.createBiquadFilter();
      offEqHigh.type = 'highshelf';
      offEqHigh.frequency.value = eqHigh.frequency.value;
      offEqHigh.gain.value = eqHigh.gain.value;

      offEqLow.connect(offEqMid);
      offEqMid.connect(offEqHigh);
      offEqHigh.connect(offlineMasterGain);
      offlineMasterGain.connect(offlineCtx.destination);

      const temSolo = tracks.some(t => t.soloed);

      // 4. Agendar fontes
      tracks.forEach(track => {
        if (track.muted) return;
        if (temSolo && !track.soloed) return;

        const trackGain = offlineCtx.createGain();
        trackGain.gain.value = track.volume / 100;

        const trackPanner = offlineCtx.createStereoPanner();
        trackPanner.pan.value = track.pan / 100;

        trackGain.connect(trackPanner);
        buildTrackSignalChain(track, trackPanner, offlineCtx, offEqLow);

        track.regions.forEach(region => {
          if (!region.buffer) return;

          let delay = region.startTime - songStart;
          let offset = region.offset || 0;
          let durationToPlay = region.duration;

          if (delay < 0) {
            // O clipe começa antes do songStart
            offset += Math.abs(delay);
            durationToPlay -= Math.abs(delay);
            delay = 0;
          }

          // Se o clipe se estende além do songEnd, limitamos a duração de reprodução
          const clipEndTime = region.startTime + region.duration;
          if (clipEndTime > songEnd) {
            const excess = clipEndTime - songEnd;
            durationToPlay -= excess;
          }

          if (durationToPlay <= 0) return;

          const source = offlineCtx.createBufferSource();
          source.buffer = region.buffer;

          const clipGainNode = offlineCtx.createGain();
          const finalGain = region.gain !== undefined ? region.gain : 1.0;
          const fadeInTime = region.fadeIn || 0.0;
          const fadeOutTime = region.fadeOut || 0.0;
          const startTime = delay;
          const endTime = startTime + durationToPlay;

          clipGainNode.gain.setValueAtTime(0, 0);

          const clipOffsetInPlay = offset - (region.offset || 0);

          if (clipOffsetInPlay < fadeInTime && fadeInTime > 0) {
            const startFadeGain = (clipOffsetInPlay / fadeInTime) * finalGain;
            clipGainNode.gain.setValueAtTime(startFadeGain, startTime);
            clipGainNode.gain.linearRampToValueAtTime(finalGain, startTime + (fadeInTime - clipOffsetInPlay));
          } else {
            clipGainNode.gain.setValueAtTime(finalGain, startTime);
          }

          if (fadeOutTime > 0) {
            const fadeOutStartOffsetFromClipStart = region.duration - fadeOutTime;
            const fadeOutStartTimeOnTimeline = region.startTime + fadeOutStartOffsetFromClipStart;
            let delayToFadeOut = fadeOutStartTimeOnTimeline - songStart;

            if (delayToFadeOut < 0) {
              const timeInFadeOut = Math.abs(delayToFadeOut);
              const currentFadeOutGain = finalGain * (1 - (timeInFadeOut / fadeOutTime));
              clipGainNode.gain.setValueAtTime(currentFadeOutGain, startTime);
              clipGainNode.gain.linearRampToValueAtTime(0, endTime);
            } else {
              clipGainNode.gain.setValueAtTime(finalGain, startTime + delayToFadeOut);
              clipGainNode.gain.linearRampToValueAtTime(0, endTime);
            }
          } else {
            clipGainNode.gain.setValueAtTime(finalGain, endTime);
          }

          source.connect(clipGainNode);
          clipGainNode.connect(trackGain);

          source.start(startTime, offset, durationToPlay);
        });
      });

      // 5. Renderizar
      try {
        const renderedBuffer = await offlineCtx.startRendering();
        let exportBlob;
        let ext = format.toLowerCase();

        if (ext === 'mp3') {
          // Carrega lamejs dinamicamente caso nao esteja em memoria
          if (typeof lamejs === 'undefined') {
            await new Promise((resolve, reject) => {
              const script = document.createElement('script');
              script.src = 'https://cdnjs.cloudflare.com/ajax/libs/lamejs/1.2.0/lame.min.js';
              script.onload = resolve;
              script.onerror = reject;
              document.head.appendChild(script);
            });
          }
          exportBlob = bufferToMp3(renderedBuffer);
        } else {
          exportBlob = bufferToWav(renderedBuffer);
        }

        // Disparar Download
        const link = document.createElement('a');
        link.href = URL.createObjectURL(exportBlob);
        link.download = `mixdown_${Date.now()}.${ext}`;
        link.click();
        
        mostrarStatus(`✔️ Mixagem exportada com sucesso em formato ${ext.toUpperCase()}!`, 4000);
      } catch (err) {
        mostrarStatus("❌ Falha no processo de mixdown: " + err.message, 5000);
      }
    }


    // =========================================================================
    // 🎧 LOCAL WEB AUDIO DSP SIGNAL CHAINS
    // =========================================================================

    function buildTrackSignalChain(track, lastNode, context, destinationNode) {
      const chain = {
        effects: []
      };

      if (!track.effects || !track.effects.length) {
        lastNode.connect(destinationNode);
        return chain;
      }

      let currentNode = lastNode;

      track.effects.forEach((effect, index) => {
        if (!effect.active) {
          chain.effects.push({ type: effect.type, bypassed: true });
          return;
        }

        if (effect.type === 'pitch_shift') {
          chain.effects.push({
            type: 'pitch_shift',
            bypassed: false,
            semitones: parseFloat(effect.params.semitones || 0)
          });
        }
        else if (effect.type === 'eq') {
          const lowNode = context.createBiquadFilter();
          lowNode.type = 'lowshelf';
          lowNode.frequency.value = 220;
          lowNode.gain.value = effect.params.bass;

          const midNode = context.createBiquadFilter();
          midNode.type = 'peaking';
          midNode.frequency.value = 1000;
          midNode.Q.value = 1.0;
          midNode.gain.value = effect.params.mid;

          const highNode = context.createBiquadFilter();
          highNode.type = 'highshelf';
          highNode.frequency.value = 4500;
          highNode.gain.value = effect.params.treble;

          currentNode.connect(lowNode);
          lowNode.connect(midNode);
          midNode.connect(highNode);

          currentNode = highNode;

          chain.effects.push({
            type: 'eq',
            bypassed: false,
            nodes: { lowNode, midNode, highNode }
          });
        } 
        else if (effect.type === 'pro_eq') {
          const lcNode = context.createBiquadFilter();
          lcNode.type = 'highpass';
          lcNode.frequency.value = effect.params.lc_active ? effect.params.lc_freq : 10;
          lcNode.Q.value = effect.params.lc_q;

          const lfNode = context.createBiquadFilter();
          lfNode.type = 'lowshelf';
          lfNode.frequency.value = effect.params.lf_freq;
          lfNode.gain.value = effect.params.lf_active ? effect.params.lf_gain : 0;
          lfNode.Q.value = effect.params.lf_q;

          const lmfNode = context.createBiquadFilter();
          lmfNode.type = 'peaking';
          lmfNode.frequency.value = effect.params.lmf_freq;
          lmfNode.Q.value = effect.params.lmf_q;
          lmfNode.gain.value = effect.params.lmf_active ? effect.params.lmf_gain : 0;

          const mfNode = context.createBiquadFilter();
          mfNode.type = 'peaking';
          mfNode.frequency.value = effect.params.mf_freq;
          mfNode.Q.value = effect.params.mf_q;
          mfNode.gain.value = effect.params.mf_active ? effect.params.mf_gain : 0;

          const hmfNode = context.createBiquadFilter();
          hmfNode.type = 'peaking';
          hmfNode.frequency.value = effect.params.hmf_freq;
          hmfNode.Q.value = effect.params.hmf_q;
          hmfNode.gain.value = effect.params.hmf_active ? effect.params.hmf_gain : 0;

          const hfNode = context.createBiquadFilter();
          hfNode.type = 'highshelf';
          hfNode.frequency.value = effect.params.hf_freq;
          hfNode.gain.value = effect.params.hf_active ? effect.params.hf_gain : 0;
          hfNode.Q.value = effect.params.hf_q;

          const hcNode = context.createBiquadFilter();
          hcNode.type = 'lowpass';
          hcNode.frequency.value = effect.params.hc_active ? effect.params.hc_freq : 22000;
          hcNode.Q.value = effect.params.hc_q;

          currentNode.connect(lcNode);
          lcNode.connect(lfNode);
          lfNode.connect(lmfNode);
          lmfNode.connect(mfNode);
          mfNode.connect(hmfNode);
          hmfNode.connect(hfNode);
          hfNode.connect(hcNode);

          currentNode = hcNode;

          chain.effects.push({
            type: 'pro_eq',
            bypassed: false,
            nodes: { lcNode, lfNode, lmfNode, mfNode, hmfNode, hfNode, hcNode }
          });
        }
        else if (effect.type === 'delay') {
          const inputNode = context.createGain();
          const outputNode = context.createGain();

          const delayNode = context.createDelay(1.0);
          delayNode.delayTime.value = effect.params.delayTime;

          const feedbackGain = context.createGain();
          feedbackGain.gain.value = effect.params.feedback;

          const dryGain = context.createGain();
          dryGain.gain.value = 1.0 - effect.params.mix;

          const wetGain = context.createGain();
          wetGain.gain.value = effect.params.mix;

          currentNode.connect(inputNode);
          
          inputNode.connect(dryGain);
          inputNode.connect(delayNode);
          
          delayNode.connect(feedbackGain);
          feedbackGain.connect(delayNode);
          
          delayNode.connect(wetGain);
          
          dryGain.connect(outputNode);
          wetGain.connect(outputNode);

          currentNode = outputNode;

          chain.effects.push({
            type: 'delay',
            bypassed: false,
            nodes: { inputNode, outputNode, delayNode, feedbackGain, dryGain, wetGain }
          });
        } 
        else if (effect.type === 'reverb') {
          const inputNode = context.createGain();
          const outputNode = context.createGain();

          const convolverNode = context.createConvolver();
          const size = effect.params.size;
          convolverNode.buffer = generateReverbImpulseWithContext(context, size, 2.5);

          const dryGain = context.createGain();
          dryGain.gain.value = 1.0 - effect.params.mix;

          const wetGain = context.createGain();
          wetGain.gain.value = effect.params.mix;

          currentNode.connect(inputNode);
          
          inputNode.connect(dryGain);
          inputNode.connect(convolverNode);
          
          convolverNode.connect(wetGain);
          
          dryGain.connect(outputNode);
          wetGain.connect(outputNode);

          currentNode = outputNode;

          chain.effects.push({
            type: 'reverb',
            bypassed: false,
            nodes: { inputNode, outputNode, convolverNode, dryGain, wetGain }
          });
        } 
        else if (effect.type === 'distortion') {
          const shaperNode = context.createWaveShaper();
          shaperNode.curve = makeDistortionCurve(effect.params.drive);
          shaperNode.oversample = '4x';

          const filterNode = context.createBiquadFilter();
          filterNode.type = 'lowpass';
          filterNode.frequency.value = effect.params.tone;

          const gainNode = context.createGain();
          gainNode.gain.value = effect.params.level;

          currentNode.connect(shaperNode);
          shaperNode.connect(filterNode);
          filterNode.connect(gainNode);

          currentNode = gainNode;

          chain.effects.push({
            type: 'distortion',
            bypassed: false,
            nodes: { shaperNode, filterNode, gainNode }
          });
        }
        else if (effect.type === 'lufs_meter') {
          const analyserNode = context.createAnalyser();
          analyserNode.fftSize = 2048;

          currentNode.connect(analyserNode);
          currentNode = analyserNode;

          chain.effects.push({
            type: 'lufs_meter',
            bypassed: false,
            nodes: { analyserNode }
          });
        }
      });

      currentNode.connect(destinationNode);
      return chain;
    }

    function updateActiveEffectNodeParam(trackId, effectIndex, param, value) {
      const chain = activeTrackChains[trackId];
      if (!chain || !chain.effects || !chain.effects[effectIndex]) return;

      const effectNode = chain.effects[effectIndex];
      if (effectNode.bypassed) return;

      const nodes = effectNode.nodes;
      const currentTime = audioCtx.currentTime;

      if (effectNode.type === 'pro_eq') {
        const n = nodes;
        if (param === 'lc_freq') n.lcNode.frequency.setValueAtTime(value, currentTime);
        if (param === 'lc_q') n.lcNode.Q.setValueAtTime(value, currentTime);
        if (param === 'lc_active') {
          const track = tracks.find(t => t.id === trackId);
          const fx = track?.effects[effectIndex];
          const activeFreq = fx ? fx.params.lc_freq : 20;
          n.lcNode.frequency.setValueAtTime(value ? activeFreq : 10, currentTime);
        }

        if (param === 'lf_freq') n.lfNode.frequency.setValueAtTime(value, currentTime);
        if (param === 'lf_gain') {

    function scheduleAudioPlayback() {
      // Parar qualquer som ativo antes de reiniciar
      stopActiveSources();

      // Agendar a reprodução de cada Clip de cada trilha
      const temSolo = tracks.some(t => t.soloed);
      activeTrackChains = {};

      tracks.forEach(track => {
        if (track.muted) return;
        if (temSolo && !track.soloed) return;

        // Criar nó de Ganho e Panner para esta trilha
        const trackGain = audioCtx.createGain();
        trackGain.gain.value = track.volume / 100;

        const trackPanner = audioCtx.createStereoPanner();
        trackPanner.pan.value = track.pan / 100;

        trackGain.connect(trackPanner);

        // Criar analisador de playback para o VU meter
        const playAnalyser = audioCtx.createAnalyser();
        playAnalyser.fftSize = 256;
        trackPanner.connect(playAnalyser);

        // Conecta a cadeia de efeitos local da trilha
        const chain = buildTrackSignalChain(track, playAnalyser, audioCtx, eqLow);
        activeTrackChains[track.id] = chain;
        playbackAnalysers.set(track.id, playAnalyser);

        const playbackRate = getPlaybackRate();
        const finalRate = playbackRate;

        track.regions.forEach(region => {
          if (!region.buffer) return;

          const clipEndTime = region.startTime + region.duration;
          
          // Se o clipe está no futuro ou se o playhead cruza o clipe atualmente
          if (clipEndTime > timelinePosition) {
            const source = audioCtx.createBufferSource();
            source.buffer = region.buffer;
            source.playbackRate.value = finalRate;

            const clipGainNode = audioCtx.createGain();
            const finalGain = region.gain !== undefined ? region.gain : 1.0;
            const fadeInTime = region.fadeIn || 0.0;
            const fadeOutTime = region.fadeOut || 0.0;

            let delay = region.startTime - timelinePosition;
            let offset = region.offset || 0;
            let durationToPlay = region.duration;

            if (delay < 0) {
              // O cursor está no meio do clipe
              offset += Math.abs(delay);
              durationToPlay -= Math.abs(delay);
              delay = 0;
            }

            const startTime = audioCtx.currentTime + delay;
            const endTime = startTime + durationToPlay;

            // Configuração da Automação de Fades e Ganho
            clipGainNode.gain.setValueAtTime(0, audioCtx.currentTime); // silêncio inicial

            const clipOffsetInPlay = offset - (region.offset || 0);

            if (clipOffsetInPlay < fadeInTime && fadeInTime > 0) {
              const startFadeGain = (clipOffsetInPlay / fadeInTime) * finalGain;
              clipGainNode.gain.setValueAtTime(startFadeGain, startTime);
              clipGainNode.gain.linearRampToValueAtTime(finalGain, startTime + (fadeInTime - clipOffsetInPlay));
            } else {
              clipGainNode.gain.setValueAtTime(finalGain, startTime);
            }

            if (fadeOutTime > 0) {
              const fadeOutStartOffsetFromClipStart = region.duration - fadeOutTime;
              const fadeOutStartTimeOnTimeline = region.startTime + fadeOutStartOffsetFromClipStart;
              let delayToFadeOut = fadeOutStartTimeOnTimeline - timelinePosition;

              if (delayToFadeOut < 0) {
                const timeInFadeOut = Math.abs(delayToFadeOut);
                const currentFadeOutGain = finalGain * (1 - (timeInFadeOut / fadeOutTime));
                clipGainNode.gain.setValueAtTime(currentFadeOutGain, startTime);
                clipGainNode.gain.linearRampToValueAtTime(0, endTime);
              } else {
                clipGainNode.gain.setValueAtTime(finalGain, startTime + delayToFadeOut);
                clipGainNode.gain.linearRampToValueAtTime(0, endTime);
              }
            }

            source.connect(clipGainNode);
            clipGainNode.connect(trackGain);

            source.start(startTime, offset, durationToPlay);
            activeNodes.push({ source, trackGain, trackPanner, trackId: track.id, clipGainNode });
          }
        });
      });
    }

    // Iniciar Reprodução
    function playDAW() {
      if (isPlaying) {
        pauseDAW();
        return;
      }

      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      saveHistory();
      isPlaying = true;
      playbackStartTime = audioCtx.currentTime;
      document.getElementById('btnPlay').textContent = "⏸️ Pausar";
      document.getElementById('btnPlay').classList.add('active');

      scheduleAudioPlayback();

      // Acionar loop visual
      updatePlayheadVisual();
      checkStartVULoop();

      // Iniciar Metrônomo
      if (metronome) startMetronome();
      
      atualizarTransportePlayState();
    }

    // Pausar Reprodução
    function pauseDAW() {
      if (isPlaying) {
        const delta = audioCtx.currentTime - playbackStartTime;
        timelinePosition += delta;
      }
      isPlaying = false;
      stopActiveSources();
      stopMetronome();
      document.getElementById('btnPlay').textContent = "▶ Reproduzir";
      document.getElementById('btnPlay').classList.remove('active');
      
      atualizarTransportePlayState();
      atualizarTransporteMasterDAW(timelinePosition);
    }

    // Parar Completamente e voltar ao início
    function stopDAW() {
      isPlaying = false;
      stopActiveSources();
      stopMetronome();
      timelinePosition = songStart; // Volta para o songStart definido pelo ticker azul
      
      // Animar e atualizar o playhead e relógio visualmente
      animarSaltoPlayhead();
      
      const posPx = timelinePosition * PX_PER_SECOND;
      const playhead = document.getElementById('playheadLine');
      if (playhead) playhead.style.left = `${posPx}px`;
      
      const playheadM = document.getElementById('playheadMarker');
      if (playheadM) playheadM.style.left = `${posPx}px`;
      
      const displayTime = document.getElementById('displayTime');
      if (displayTime) displayTime.textContent = formatDigitalTime(timelinePosition);

      document.getElementById('btnPlay').textContent = "▶ Reproduzir";
      document.getElementById('btnPlay').classList.remove('active');
      
      atualizarTransportePlayState();
      atualizarTransporteMasterDAW(timelinePosition);
    }

    // Parar nós de fontes de áudio ativas
    function stopActiveSources() {
      activeNodes.forEach(node => {
        try {
          node.source.stop();
        } catch(e) {}
      });
      activeNodes = [];
      playbackAnalysers.clear();
    }

    /* =========================================================================
       NEW: Playhead Animation and Bottom Transport Sync Helpers
       ========================================================================= */
    let playheadAnimationTimer = null;
    function animarSaltoPlayhead() {
      const playheadM = document.getElementById('playheadMarker');
      const playheadL = document.getElementById('playheadLine');
      
      if (playheadM) playheadM.classList.remove('is-animated');

                                <span style="font-size: 11px; cursor: pointer; padding: 2px; opacity: 0.8;" onclick="event.stopPropagation(); toggleEfeitoBypassModal(${idx});" title="Ligar/Desligar">
                                  ${effect.active ? '⏻' : '⏸'}
                                </span>

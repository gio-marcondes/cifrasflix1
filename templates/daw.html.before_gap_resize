    function toggleExpandEfeitoSidebar(index, event) {
      abrirModalFx(index);
    }

    function toggleEfeitoBypassSidebar(index) {
      const track = tracks.find(t => t.id === selectedTrackId);
      if (!track || !track.effects[index]) return;
      track.effects[index].active = !track.effects[index].active;
      renderTrackInspector();
      renderDAW();
      if (isPlaying) rebuildSignalChains();
    }

    function removerEfeitoSidebar(index) {
      const track = tracks.find(t => t.id === selectedTrackId);
      if (!track) return;
      saveHistory();
      track.effects.splice(index, 1);
      renderTrackInspector();
      renderDAW();
      if (isPlaying) rebuildSignalChains();
    }

    function mudarBandaEqSidebar(effectIndex, band, event) {
      event.stopPropagation();
      const track = tracks.find(t => t.id === selectedTrackId);
      if (!track || !track.effects[effectIndex]) return;
      track.effects[effectIndex].selectedBand = band;
      renderTrackInspector();
    }

    function redesenharEqSidebar(index) {
      const track = tracks.find(t => t.id === selectedTrackId);
      if (!track || !track.effects[index]) return;
      const canvas = document.getElementById(`proEqCanvasSidebar-${index}`);
      if (canvas) {
        drawProEqCurve(canvas, track.effects[index].params);
      }
    }

    function selecionarTrilha(trackId) {
      selectedTrackId = trackId;
      renderDAW();
    }


    // =========================================================================
    // 🎨 RENDERIZAÇÃO DA INTERFACE & INTERATIVIDADE
    // =========================================================================

    const timelineCanvas = document.getElementById('timelineCanvas');
    const timelineScrollContainer = document.getElementById('timelineScrollContainer');
    const timelineScrollDummy = document.getElementById('timelineScrollDummy');

    // Caching Peaks downsampling algorithm
    function getRegionPeaks(region) {
      if (region.peaks) return region.peaks;
      if (!region.buffer) return null;
      
      const channelData = region.buffer.getChannelData(0);
      const length = channelData.length;
      const numPeaks = 1000;
      const step = Math.floor(length / numPeaks) || 1;
      const peaks = new Float32Array(numPeaks * 2);
      
      for (let i = 0; i < numPeaks; i++) {
        let min = 1.0;
        let max = -1.0;
        const start = i * step;
        const end = Math.min(start + step, length);
        for (let j = start; j < end; j++) {
          const val = channelData[j];
          if (val < min) min = val;
          if (val > max) max = val;
        }
        if (min === 1.0) min = 0;
        if (max === -1.0) max = 0;
        peaks[i * 2] = min;
        peaks[i * 2 + 1] = max;
      }
      
      region.peaks = peaks;
      return peaks;
    }

    function updateScrollDummy() {
      if (!timelineScrollDummy) return;
      const totalWidth = getProjectDuration() * PX_PER_SECOND;
      let totalHeight = 36;
      if (tracks.length > 0) {
        const sumHeights = tracks.reduce((sum, t) => sum + (t.height || 120), 0);
        totalHeight += sumHeights + (tracks.length - 1) * TRACK_GAP;      }
      totalHeight = Math.max(300, totalHeight);
      timelineScrollDummy.style.width = `${totalWidth}px`;
      timelineScrollDummy.style.height = `${totalHeight}px`;
    }

    function resizeTimelineCanvas() {
      if (!timelineCanvas || !timelineScrollContainer) return;
      const rect = timelineScrollContainer.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      
      timelineCanvas.width = rect.width * dpr;
      timelineCanvas.height = rect.height * dpr;
      timelineCanvas.style.width = `${rect.width}px`;
      timelineCanvas.style.height = `${rect.height}px`;
      
      const ctx = timelineCanvas.getContext('2d');
      ctx.scale(dpr, dpr);
      
      drawTimeline();
    }

    // Scroll container positioning and scroll sync
    if (timelineScrollContainer) {
      timelineScrollContainer.addEventListener('scroll', () => {
        const headersList = document.getElementById('trackHeadersList');
        if (headersList) {
          headersList.scrollTop = timelineScrollContainer.scrollTop;
        }
        
        timelineCanvas.style.left = `${timelineScrollContainer.scrollLeft}px`;
        timelineCanvas.style.top = `${timelineScrollContainer.scrollTop}px`;
        drawTimeline();
      });
    }

    // Renderizar a DAW completa (Mixer esquerdo + Grid da timeline)
    function renderDAW() {
      updateScrollDummy();
      
      const headersList = document.getElementById('trackHeadersList');
      if (!headersList) return;
      headersList.innerHTML = "";

      if (!selectedTrackId && tracks.length > 0) {
        selectedTrackId = tracks[0].id;
      }

      tracks.forEach(track => {
        const headerDiv = document.createElement('div');
        headerDiv.className = `track-header ${selectedTrackId === track.id ? 'selected' : ''}`;        headerDiv.style.height = `${track.height || 120}px`;
        headerDiv.style.borderLeft = `4px solid ${track.color || '#8b5cf6'}`;
        headerDiv.dataset.trackId = track.id;
        headerDiv.setAttribute('draggable', 'true');

        headerDiv.addEventListener('dragstart', (e) => {
          if (
            e.target.tagName === 'INPUT' || 
            e.target.tagName === 'BUTTON' || 
            e.target.closest('.track-toggles') || 
            e.target.closest('.track-delete-btn') ||
            e.target.closest('.track-faders') ||
            e.target.closest('.pan-knob')
          ) {
            e.preventDefault();
            return;
          }
          e.dataTransfer.setData('text/plain', track.id);
          headerDiv.classList.add('dragging-header');
        });

        headerDiv.addEventListener('mousedown', (e) => {
          if (
            e.target.tagName === 'INPUT' || 
            e.target.tagName === 'BUTTON' || 
            e.target.closest('.track-toggles') || 
            e.target.closest('.track-delete-btn') ||
            e.target.closest('.track-faders') ||
            e.target.closest('.pan-knob')
          ) {
            headerDiv.setAttribute('draggable', 'false');
          } else {
            headerDiv.setAttribute('draggable', 'true');
          }
        });

        headerDiv.addEventListener('mouseup', () => {
          headerDiv.setAttribute('draggable', 'true');
        });

        headerDiv.addEventListener('mouseleave', () => {
          headerDiv.setAttribute('draggable', 'true');
        });

        headerDiv.addEventListener('dragend', () => {
          headerDiv.classList.remove('dragging-header');
          document.querySelectorAll('.track-header').forEach(h => h.classList.remove('drag-over'));
        });

        headerDiv.addEventListener('dragover', (e) => {
          e.preventDefault();
          headerDiv.classList.add('drag-over');
        });

        headerDiv.addEventListener('dragleave', () => {
          headerDiv.classList.remove('drag-over');
        });

        headerDiv.addEventListener('drop', (e) => {
          e.preventDefault();
          headerDiv.classList.remove('drag-over');
          const draggedTrackId = e.dataTransfer.getData('text/plain');
          if (!draggedTrackId || draggedTrackId === track.id) return;

          saveHistory();

          const draggedIdx = tracks.findIndex(t => t.id === draggedTrackId);
          const targetIdx = tracks.findIndex(t => t.id === track.id);

          if (draggedIdx !== -1 && targetIdx !== -1) {
            const [draggedTrack] = tracks.splice(draggedIdx, 1);
            tracks.splice(targetIdx, 0, draggedTrack);
            renderDAW();
            if (isPlaying) {
              stopActiveSources();
              playDAW();
            }
          }
        });
        
        headerDiv.innerHTML = `
          <div class="track-header-content" style="flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; height: 100%;">
            <div class="track-title-row">
              <span class="track-color-badge" style="display:inline-block; width:10px; height:10px; border-radius:50%; background-color:${track.color || '#8b5cf6'}; margin-right:4px; flex-shrink:0; border: 1px solid rgba(255,255,255,0.2);"></span>
              <input type="text" class="track-name-input" value="${track.name}" data-track-id="${track.id}">
              <button class="track-delete-btn" onclick="deleteTrack('${track.id}')" title="Apagar trilha">&times;</button>
            </div>
            <div class="track-faders">
              <div class="fader-group">
                <label>Vol <span>${track.volume}%</span></label>
                <input type="range" class="vol-slider" min="0" max="150" value="${track.volume}" data-track-id="${track.id}">
              </div>
              <div class="fader-group" style="align-items: center; justify-content: center;">
                <label style="width: 100%; justify-content: space-between;">Pan</label>
                <div style="display: flex; align-items: center; gap: 8px; margin-top: 2px;">
                  <div class="pan-knob" data-track-id="${track.id}" style="width: 20px; height: 20px; border-radius: 50%; background: #11131a; border: 2px solid rgba(255, 255, 255, 0.2); position: relative; cursor: ns-resize; box-shadow: inset 0 2px 4px rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; transition: border-color 0.2s;">
                    <div class="pan-knob-indicator" style="width: 2px; height: 6px; background: var(--accent); position: absolute; top: 2px; transform-origin: bottom center; transform: rotate(${(track.pan / 100) * 135}deg); border-radius: 1px;"></div>
                  </div>
                  <span class="pan-value-text" style="font-size: 10px; color: #fff; font-weight: bold; min-width: 25px; display: inline-block; text-align: left;">${track.pan === 0 ? 'C' : (track.pan < 0 ? 'L'+Math.abs(track.pan) : 'R'+track.pan)}</span>
                </div>
              </div>
            </div>
            <div class="track-toggles">
              <button class="btn-toggle mute-btn ${track.muted ? 'active' : ''}" data-track-id="${track.id}">M</button>
              <button class="btn-toggle solo-btn ${track.soloed ? 'active' : ''}" data-track-id="${track.id}">S</button>
              <button class="btn-toggle rec-btn ${activeRecordTrackId === track.id ? 'active' : ''}" data-track-id="${track.id}">●</button>
              <button class="btn-toggle monitor-btn ${track.monitoring ? 'active' : ''}" data-track-id="${track.id}" title="Monitorar Entrada">🔊</button>
              <button class="btn-toggle fx-btn ${track.effects && track.effects.some(e => e.active) ? 'active-fx' : ''}" data-track-id="${track.id}" title="Rack de Efeitos">
                FX${track.effects && track.effects.length ? ` (${track.effects.length})` : ''}
              </button>
            </div>
          </div>
          
          <!-- NEW: Vertical Segmented VU Meter -->
          <div class="track-vu-meter-v" style="width: 14px; height: 100%; display: flex; flex-direction: column-reverse; background: rgba(0,0,0,0.5); border-radius: 3px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); position: relative; padding: 1px; box-sizing: border-box; flex-shrink: 0;">
            <div class="vu-meter-fill-v" id="vu-bar-${track.id}" style="width: 100%; height: 0%; background: linear-gradient(to top, #22c55e 0%, #22c55e 65%, #eab308 80%, #ef4444 95%, #ef4444 100%); transition: height 0.05s ease-out; border-radius: 1px;"></div>
<div class="vu-meter-mask-v" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: repeating-linear-gradient(to bottom, transparent, transparent 4px, rgba(15, 23, 42, 0.95) 4px, rgba(15, 23, 42, 0.95) 6px); pointer-events: none;"></div>
          </div>
        `;

        const resizeHandle = document.createElement('div');
        resizeHandle.className = 'track-resize-handle';
        resizeHandle.dataset.trackId = track.id;
        headerDiv.appendChild(resizeHandle);

        resizeHandle.addEventListener('mousedown', (e) => {
            e.preventDefault();
            e.stopPropagation();

            const startY = e.clientY;
            const initialHeight = track.height || 120;

            function onMouseMove(moveEvent) {
                const deltaY = moveEvent.clientY - startY;
                const newHeight = Math.max(60, Math.min(400, initialHeight + deltaY));
                track.height = newHeight;

                headerDiv.style.height = `${newHeight}px`;
                
                updateScrollDummy();
                drawTimeline();
            }

            function onMouseUp() {
                window.removeEventListener('mousemove', onMouseMove);
                window.removeEventListener('mouseup', onMouseUp);
                if (isPlaying) {
                    rebuildSignalChains();
                }
            }

            window.addEventListener('mousemove', onMouseMove);
            window.addEventListener('mouseup', onMouseUp);
        });

        headerDiv.addEventListener('click', (e) => {
          if (e.target.closest('.fx-btn')) {
            selecionarTrilha(track.id);
            abrirModalFx();
            return;
          }
          if (
            e.target.tagName === 'INPUT' || 
            e.target.tagName === 'BUTTON' || 
            e.target.closest('.track-toggles') || 
            e.target.closest('.track-delete-btn')
          ) {
            return;
          }
          selecionarTrilha(track.id);
        });

        headersList.appendChild(headerDiv);
      });

      setupTimelineInteractions();
      renderTrackInspector();
      atualizarTransporteMasterDAW();
      drawTimeline();
    }

    let dragTarget = null;
    let marqueeCurrentX = 0;
    let marqueeCurrentY = 0;
    let isDraggingMarquee = false;

    function getTimelineMouseCoords(e) {
      if (!timelineCanvas) return null;
      const rect = timelineCanvas.getBoundingClientRect();
      const canvasX = e.clientX - rect.left;
      const canvasY = e.clientY - rect.top;
      const scrollX = timelineScrollContainer ? timelineScrollContainer.scrollLeft : 0;
      const scrollY = timelineScrollContainer ? timelineScrollContainer.scrollTop : 0;
      
      const timelineX = canvasX + scrollX;
      const timelineY = canvasY + scrollY;
      const time = timelineX / PX_PER_SECOND;
      
      let trackIdx = -1;
      if (timelineY > 36) {
        let cumulativeHeight = 36;
        for (let i = 0; i < tracks.length; i++) {
          cumulativeHeight += tracks[i].height || 120;
          if (timelineY < cumulativeHeight) { trackIdx = i; break; }
        }
      }
      const track = (trackIdx >= 0 && trackIdx < tracks.length) ? tracks[trackIdx] : null;
      
      return { canvasX, canvasY, timelineX, timelineY, time, trackIdx, track };
    }

    function getClipElementAt(coords) {
      const { time, track, timelineY } = coords;
      if (!track) return null;
      
      let trackY = 36;
      for (let i = 0; i < tracks.indexOf(track); i++) {
        trackY += tracks[i].height || 120;
      }
      const clipY = trackY + ( (track.height || 120) - 80) / 2;
      const clipH = 80;
      
      if (timelineY < clipY || timelineY > clipY + clipH) return null;
      
      for (let i = track.regions.length - 1; i >= 0; i--) {
        const region = track.regions[i];
        const start = region.startTime;
        const end = region.startTime + region.duration;
        
        if (time >= start && time <= end) {
          return { region, track, start, end, clipY, clipH };
        }
      }
      return null;
    }

    function handleTimelineMouseDown(e) {
      const coords = getTimelineMouseCoords(e);
      if (!coords) return;

      const { canvasX, canvasY, timelineX, timelineY, time, trackIdx, track } = coords;

      if (canvasY <= 36) {
        e.preventDefault();
        
        const markerTolerance = 8 / PX_PER_SECOND;
        if (Math.abs(time - loopStart) <= markerTolerance) {
          dragTarget = { type: 'marker', markerName: 'loopStart', initialValue: loopStart };
        } else if (Math.abs(time - loopEnd) <= markerTolerance) {
          dragTarget = { type: 'marker', markerName: 'loopEnd', initialValue: loopEnd };
        } else if (Math.abs(time - songStart) <= markerTolerance) {
          dragTarget = { type: 'marker', markerName: 'songStart', initialValue: songStart };
        } else if (Math.abs(time - songEnd) <= markerTolerance) {
          dragTarget = { type: 'marker', markerName: 'songEnd', initialValue: songEnd };
        } else {
          dragTarget = { type: 'playhead' };
          timelinePosition = Math.max(0, time);
          animarSaltoPlayhead();
          atualizarPlayheadVisualPositions();
          
          if (isPlaying) {
            stopActiveSources();
            playbackStartTime = audioCtx.currentTime;
            scheduleAudioPlayback();
          }
        }
        drawTimeline();
        return;
      }

      if (cutMode) {
        const clipInfo = getClipElementAt(coords);
        if (clipInfo) {
          splitClip(clipInfo.track.id, clipInfo.region.id, time);
        }
        return;
      }

      if (regionMode) {
        if (!track) return;
        e.preventDefault();
        dragTarget = { type: 'range-select', trackId: track.id, startX: timelineX };
        selectionTrackId = track.id;
        selectionStart = time;
        selectionEnd = time;
        regionSelectionActive = true;
        isSelectingRegion = true;
        atualizarOverlaySelecao();
        return;
      }

      const clipInfo = getClipElementAt(coords);
      if (clipInfo) {
        const { region, track, start, end, clipY, clipH } = clipInfo;
        
        if (e.shiftKey) {
          if (selectedRegionIds.has(region.id)) {
            selectedRegionIds.delete(region.id);
            if (selectedRegionId === region.id) {
              selectedRegionId = selectedRegionIds.size > 0 ? Array.from(selectedRegionIds)[0] : null;
            }
          } else {
            selectedRegionIds.add(region.id);
            selectedRegionId = region.id;
            selectedRegionTrackId = track.id;
            selectedTrackId = track.id;
          }
        } else {
          if (!selectedRegionIds.has(region.id)) {
            selectedRegionIds.clear();
            selectedRegionIds.add(region.id);
            selectedRegionId = region.id;
            selectedRegionTrackId = track.id;
            selectedTrackId = track.id;
          }
        }
        renderDAWHeadersListSelection();

        const fadeInPx = (region.fadeIn || 0) * PX_PER_SECOND;
        const fadeOutPx = (region.fadeOut || 0) * PX_PER_SECOND;
        const startPx = start * PX_PER_SECOND;
        const endPx = end * PX_PER_SECOND;

        if (Math.abs(timelineX - (startPx + fadeInPx)) <= 6 && Math.abs(timelineY - clipY) <= 8) {
          e.preventDefault();
          dragTarget = { type: 'clip-fade-left', region, initialFadeIn: region.fadeIn || 0, startX: timelineX };
          return;
        }

        if (Math.abs(timelineX - (endPx - fadeOutPx)) <= 6 && Math.abs(timelineY - clipY) <= 8) {
          e.preventDefault();
          dragTarget = { type: 'clip-fade-right', region, initialFadeOut: region.fadeOut || 0, startX: timelineX };
          return;
        }

        if (timelineX - startPx <= 8) {
          e.preventDefault();
          dragTarget = {
            type: 'clip-trim-left',
            region,
            track,
            initialStartTime: region.startTime,
            initialOffset: region.offset || 0,
            initialDuration: region.duration,
            startX: timelineX
          };
          return;
        }

        if (endPx - timelineX <= 8) {
          e.preventDefault();
          dragTarget = {
            type: 'clip-trim-right',
            region,
            track,
            initialDuration: region.duration,
            startX: timelineX
          };
          return;
        }

        const gainVal = region.gain ?? 1.0;
        const gainY = clipY + clipH * (1 - gainVal / 2.0);
        if (Math.abs(timelineY - gainY) <= 5) {
          e.preventDefault();
          dragTarget = { type: 'clip-gain', region, initialGain: gainVal, startY: timelineY };
          return;
        }

        e.preventDefault();
        
        const draggedRegions = [];
        selectedRegionIds.forEach(rId => {
          let foundRegion = null;
          let foundTrack = null;
          for (const t of tracks) {
            const r = t.regions.find(reg => reg.id === rId);
            if (r) {
              foundRegion = r;
              foundTrack = t;
              break;
            }
          }
          if (foundRegion && foundTrack) {
            draggedRegions.push({
              region: foundRegion,
              initialTrack: foundTrack,
              initialStartTime: foundRegion.startTime,
              initialTrackIdx: tracks.indexOf(foundTrack)
            });
          }
        });

        dragTarget = {
          type: 'clip-move',
          region,
          track,
          initialStartTime: region.startTime,
          initialTrackIdx: tracks.indexOf(track),
          startX: timelineX,
          startY: timelineY,
          draggedRegions,
          deltaTime: 0,
          deltaTrackIdx: 0,
          hasDragged: false,
          historySaved: false
        };
        drawTimeline();
      } else {
        e.preventDefault();
        selectedRegionIds.clear();
        selectedRegionId = null;
        selectedRegionTrackId = null;
        renderDAWHeadersListSelection();

        isDraggingMarquee = true;
        dragTarget = {
          type: 'marquee',
          startX: timelineX,
          startY: timelineY
        };
        marqueeCurrentX = timelineX;
        marqueeCurrentY = timelineY;
        drawTimeline();
      }
    }

    function handleTimelineMouseMove(e) {
      const coords = getTimelineMouseCoords(e);
      if (!coords) return;

      const { canvasX, canvasY, timelineX, timelineY, time, trackIdx, track } = coords;

      if (!dragTarget) {
        if (canvasY <= 36) {
          const markerTolerance = 8 / PX_PER_SECOND;
          if (Math.abs(time - loopStart) <= markerTolerance || 
              Math.abs(time - loopEnd) <= markerTolerance || 
              Math.abs(time - songStart) <= markerTolerance || 
              Math.abs(time - songEnd) <= markerTolerance) {
            timelineCanvas.style.cursor = 'ew-resize';
          } else {
            timelineCanvas.style.cursor = 'pointer';
          }
        } else if (cutMode) {
          timelineCanvas.style.cursor = 'cell';
        } else if (regionMode) {
          timelineCanvas.style.cursor = 'crosshair';
        } else {
          const clipInfo = getClipElementAt(coords);
          if (clipInfo) {
            const { region, start, end, clipY, clipH } = clipInfo;
            const fadeInPx = (region.fadeIn || 0) * PX_PER_SECOND;
            const fadeOutPx = (region.fadeOut || 0) * PX_PER_SECOND;
            const startPx = start * PX_PER_SECOND;
            const endPx = end * PX_PER_SECOND;

            if (Math.abs(timelineX - (startPx + fadeInPx)) <= 6 && Math.abs(timelineY - clipY) <= 8) {
              timelineCanvas.style.cursor = 'ew-resize';
            } else if (Math.abs(timelineX - (endPx - fadeOutPx)) <= 6 && Math.abs(timelineY - clipY) <= 8) {
              timelineCanvas.style.cursor = 'ew-resize';
            } else if (timelineX - startPx <= 8) {
              timelineCanvas.style.cursor = 'w-resize';
            } else if (endPx - timelineX <= 8) {
              timelineCanvas.style.cursor = 'e-resize';
            } else {
              const gainVal = region.gain ?? 1.0;
              const gainY = clipY + clipH * (1 - gainVal / 2.0);
              if (Math.abs(timelineY - gainY) <= 5) {
                timelineCanvas.style.cursor = 'ns-resize';
              } else {
                timelineCanvas.style.cursor = 'grab';
              }
            }
          } else {
            timelineCanvas.style.cursor = 'default';
          }
        }
        return;
      }

      if (dragTarget.type === 'playhead') {
        timelinePosition = Math.max(0, time);
        atualizarPlayheadVisualPositions();
        
        if (isPlaying) {
          stopActiveSources();
          playbackStartTime = audioCtx.currentTime;
          scheduleAudioPlayback();
        }
        drawTimeline();
      } else if (dragTarget.type === 'marker') {
        const newTime = Math.max(0, time);
        if (dragTarget.markerName === 'loopStart') {
          loopStart = Math.min(newTime, loopEnd - 0.1);
        } else if (dragTarget.markerName === 'loopEnd') {
          loopEnd = Math.max(newTime, loopStart + 0.1);
        } else if (dragTarget.markerName === 'songStart') {
          songStart = Math.min(newTime, songEnd - 0.1);
        } else if (dragTarget.markerName === 'songEnd') {
          songEnd = Math.max(newTime, songStart + 0.1);
        }
        drawTimeline();
      } else if (dragTarget.type === 'clip-fade-left') {
        const deltaPx = timelineX - dragTarget.startX;
        const deltaTime = deltaPx / PX_PER_SECOND;
        dragTarget.region.fadeIn = Math.max(0, Math.min(dragTarget.region.duration / 2, dragTarget.initialFadeIn + deltaTime));
        drawTimeline();
      } else if (dragTarget.type === 'clip-fade-right') {
        const deltaPx = dragTarget.startX - timelineX;
        const deltaTime = deltaPx / PX_PER_SECOND;
        dragTarget.region.fadeOut = Math.max(0, Math.min(dragTarget.region.duration / 2, dragTarget.initialFadeOut + deltaTime));
        drawTimeline();
      } else if (dragTarget.type === 'clip-trim-left') {
        if (!dragTarget.historySaved) {
          saveHistory();
          dragTarget.historySaved = true;
        }
        const deltaPx = timelineX - dragTarget.startX;
        const deltaTime = deltaPx / PX_PER_SECOND;
        const maxLeftShift = dragTarget.initialDuration - 0.2;
        let timeShift = Math.max(-dragTarget.initialOffset, Math.min(maxLeftShift, deltaTime));
        
        dragTarget.region.startTime = dragTarget.initialStartTime + timeShift;
        dragTarget.region.offset = dragTarget.initialOffset + timeShift;
        dragTarget.region.duration = dragTarget.initialDuration - timeShift;
        
        dragTarget.region.peaks = null;
        drawTimeline();
      } else if (dragTarget.type === 'clip-trim-right') {
        if (!dragTarget.historySaved) {
          saveHistory();
          dragTarget.historySaved = true;
        }
        const deltaPx = timelineX - dragTarget.startX;
        const deltaTime = deltaPx / PX_PER_SECOND;
        const bufferDuration = dragTarget.region.buffer ? dragTarget.region.buffer.duration : 1000;
        const maxDuration = bufferDuration - (dragTarget.region.offset || 0);
        
        dragTarget.region.duration = Math.max(0.2, Math.min(maxDuration, dragTarget.initialDuration + deltaTime));
        
        dragTarget.region.peaks = null;
        drawTimeline();
      } else if (dragTarget.type === 'clip-gain') {
        if (!dragTarget.historySaved) {
          saveHistory();
          dragTarget.historySaved = true;
        }
        const deltaY = timelineY - dragTarget.startY;
        let newGain = dragTarget.initialGain - (deltaY * 0.015);
        dragTarget.region.gain = Math.max(0.0, Math.min(2.0, newGain));
        drawTimeline();
      } else if (dragTarget.type === 'range-select') {
        selectionEnd = time;
        atualizarOverlaySelecao();
      } else if (dragTarget.type === 'marquee') {
        marqueeCurrentX = timelineX;
        marqueeCurrentY = timelineY;
        
        const x1 = Math.min(dragTarget.startX, marqueeCurrentX);
        const x2 = Math.max(dragTarget.startX, marqueeCurrentX);
        const y1 = Math.min(dragTarget.startY, marqueeCurrentY);
        const y2 = Math.max(dragTarget.startY, marqueeCurrentY);

        tracks.forEach((t, tIdx) => {
          const trackY = 36 + tIdx * 120;
          const clipY1 = trackY + 20;
          const clipY2 = trackY + 100;

          const vertOverlap = (y1 < clipY2 && y2 > clipY1);
          if (vertOverlap) {
            t.regions.forEach(r => {
              const rStart = r.startTime * PX_PER_SECOND;
              const rEnd = (r.startTime + r.duration) * PX_PER_SECOND;
              const horOverlap = (x1 < rEnd && x2 > rStart);
              
              if (horOverlap) {
                selectedRegionIds.add(r.id);
              } else if (!e.shiftKey) {
                selectedRegionIds.delete(r.id);
              }
            });
          } else if (!e.shiftKey) {
            t.regions.forEach(r => selectedRegionIds.delete(r.id));
          }
        });

        if (selectedRegionIds.size > 0) {
          const arr = Array.from(selectedRegionIds);
          selectedRegionId = arr[arr.length - 1];
          selectedRegionTrackId = tracks.find(t => t.regions.some(r => r.id === selectedRegionId))?.id;
        } else {
          selectedRegionId = null;
          selectedRegionTrackId = null;
        }
        drawTimeline();
      } else if (dragTarget.type === 'clip-move') {
        dragTarget.hasDragged = true;
        if (!dragTarget.historySaved) {
          saveHistory();
          dragTarget.historySaved = true;
        }

        const deltaPx = timelineX - dragTarget.startX;
        let deltaTime = deltaPx / PX_PER_SECOND;

        const snap = document.getElementById('selectSnap').value;
        if (snap !== "none") {
          const secondsPerBeat = 60.0 / bpm;
          const interval = secondsPerBeat * parseFloat(snap);
          const pivotSmoothTime = dragTarget.initialStartTime + deltaTime;
          let pivotSnappedTime = Math.round(pivotSmoothTime / interval) * interval;
          pivotSnappedTime = Math.max(0, pivotSnappedTime);
          deltaTime = pivotSnappedTime - dragTarget.initialStartTime;
        }

        const minInitialStartTime = Math.min(...dragTarget.draggedRegions.map(dr => dr.initialStartTime));
        const minAllowedDeltaTime = -minInitialStartTime;
        deltaTime = Math.max(minAllowedDeltaTime, deltaTime);

        let targetTrackIdx = dragTarget.initialTrackIdx;
        if (timelineY > 36) {
          let cumulativeHeight = 36;
          for (let i = 0; i < tracks.length; i++) {
            cumulativeHeight += tracks[i].height || 120;
            if (timelineY < cumulativeHeight) { targetTrackIdx = i; break; }
          }
        } 

        const trackIndices = dragTarget.draggedRegions.map(dr => dr.initialTrackIdx);
        const minTrackIdx = Math.min(...trackIndices);
        const maxTrackIdx = Math.max(...trackIndices);
        
        let deltaTrackIdx = targetTrackIdx - dragTarget.initialTrackIdx;
        const minAllowedDelta = -minTrackIdx;
        const maxAllowedDelta = tracks.length - maxTrackIdx;
        
        deltaTrackIdx = Math.max(minAllowedDelta, Math.min(maxAllowedDelta, deltaTrackIdx));

        dragTarget.deltaTime = deltaTime;
        dragTarget.deltaTrackIdx = deltaTrackIdx;
        drawTimeline();
      }
    }

    function handleTimelineMouseUp(e) {
      if (!dragTarget) return;

      if (dragTarget.type === 'clip-move') {
        if (dragTarget.hasDragged) {
          const isCopying = e.altKey;
          let newTrack = null;

          const needsNewTrack = dragTarget.draggedRegions.some(dr => {
            return (dr.initialTrackIdx + dragTarget.deltaTrackIdx) === tracks.length;
          });

          if (needsNewTrack) {
            const newTrackId = `track-${Date.now()}-${Math.floor(Math.random() * 1000)}`;
            newTrack = {
              id: newTrackId,
              name: `Trilha ${tracks.length + 1}`,
              type: 'audio',
              color: '#8b5cf6',
              volume: 100,
              pan: 0,
              muted: false,
              soloed: false,
              monitoring: false,
              effects: [],
              regions: [],
              midiClips: [],
              instrument: null
            };
            tracks.push(newTrack);
          }

          if (isCopying) {
            const newSelectedIds = new Set();
            dragTarget.draggedRegions.forEach(dr => {
              const destIdx = dr.initialTrackIdx + dragTarget.deltaTrackIdx;
              const destTrack = (destIdx === tracks.length - 1 && newTrack) ? newTrack : tracks[destIdx];

              if (destTrack) {
                const newRegionId = `region-${Date.now()}-${Math.floor(Math.random() * 1000)}`;
                const duplicatedRegion = {
                  ...dr.region,
                  id: newRegionId,
                  name: dr.region.name + " (Cópia)",
                  startTime: dr.initialStartTime + dragTarget.deltaTime,
                  peaks: dr.region.peaks
                };
                destTrack.regions.push(duplicatedRegion);
                newSelectedIds.add(newRegionId);
              }
            });

            if (newSelectedIds.size > 0) {
              selectedRegionIds = newSelectedIds;
              selectedRegionId = Array.from(newSelectedIds)[0];
              selectedRegionTrackId = tracks.find(t => t.regions.some(r => r.id === selectedRegionId))?.id;
            }
          } else {
            dragTarget.draggedRegions.forEach(dr => {
              const destIdx = dr.initialTrackIdx + dragTarget.deltaTrackIdx;
              const destTrack = (destIdx === tracks.length - 1 && newTrack) ? newTrack : tracks[destIdx];

              if (destTrack) {
                dr.region.startTime = dr.initialStartTime + dragTarget.deltaTime;

                if (dr.initialTrack.id !== destTrack.id) {
                  const idx = dr.initialTrack.regions.indexOf(dr.region);
                  if (idx !== -1) {
                    dr.initialTrack.regions.splice(idx, 1);
                    destTrack.regions.push(dr.region);
                  }
                }
              }
            });
            
            if (selectedRegionId) {
              selectedRegionTrackId = tracks.find(t => t.regions.some(r => r.id === selectedRegionId))?.id;
            }
          }

          renderDAW();
          if (isPlaying) {
            stopActiveSources();
            playDAW();
          }
        }
      } else if (dragTarget.type === 'range-select') {
        isSelectingRegion = false;
        if (Math.abs(selectionStart - selectionEnd) < 0.05) {
          const beatDuration = 60 / bpm;
          selectionEnd = selectionStart + beatDuration;
          atualizarOverlaySelecao();
        }
      } else if (dragTarget.type === 'marquee') {
        isDraggingMarquee = false;
      } else if (dragTarget.type === 'clip-gain' || dragTarget.type === 'clip-trim-left' || dragTarget.type === 'clip-trim-right' || dragTarget.type === 'clip-fade-left' || dragTarget.type === 'clip-fade-right') {
        if (isPlaying) {
          stopActiveSources();
          playDAW();
        }
      }

      dragTarget = null;
      drawTimeline();
    }

    function handleTimelineMouseLeave() {
      if (dragTarget && dragTarget.type === 'marquee') {
        isDraggingMarquee = false;
        dragTarget = null;
      }
      drawTimeline();
    }

    function atualizarPlayheadVisualPositions() {
      const posPx = timelinePosition * PX_PER_SECOND;
      const playhead = document.getElementById('playheadLine');
      if (playhead) playhead.style.left = `${posPx}px`;
      const playheadM = document.getElementById('playheadMarker');
      if (playheadM) playheadM.style.left = `${posPx}px`;
      
      document.getElementById('displayTime').textContent = formatDigitalTime(timelinePosition);
      atualizarTransporteMasterDAW(timelinePosition);
    }

    function renderDAWHeadersListSelection() {
      document.querySelectorAll('.track-header').forEach(h => {
        h.classList.toggle('selected', h.dataset.trackId === selectedTrackId);
      });
    }

    function setupTimelineInteractions() {
      document.querySelectorAll('.menu-dropdown a').forEach(link => {
        link.addEventListener('click', () => {
          const dropdown = link.closest('.menu-dropdown');
          if (dropdown) dropdown.classList.add('closed');
        });
      });

      document.querySelectorAll('.menu-item').forEach(item => {
        item.addEventListener('mouseleave', () => {
          const dropdown = item.querySelector('.menu-dropdown');
          if (dropdown) dropdown.classList.remove('closed');
        });
      });

      document.querySelectorAll('.vol-slider').forEach(s => {
        s.addEventListener('input', (e) => {
          const tId = e.target.dataset.trackId;
          const val = e.target.value;
          const track = tracks.find(t => t.id === tId);
          if (track) {
            track.volume = val;
            e.target.previousElementSibling.querySelector('span').textContent = `${val}%`;
            
            activeNodes.filter(n => n.trackId === tId).forEach(n => {
              n.trackGain.gain.setValueAtTime(val / 100, audioCtx.currentTime);
            });

            const monitor = activeMonitors.get(tId);
            if (monitor && monitor.monitorGain) {
              monitor.monitorGain.gain.setValueAtTime(val / 100, audioCtx.currentTime);
            }
          }
        });
      });

      document.querySelectorAll('.pan-knob').forEach(knob => {
        knob.addEventListener('mousedown', (e) => {
          e.preventDefault();
          const tId = knob.dataset.trackId;
          const track = tracks.find(t => t.id === tId);
          if (!track) return;

          const startY = e.clientY;
          const startPan = parseInt(track.pan, 10);

          function onMouseMove(moveEvent) {
            const deltaY = startY - moveEvent.clientY;
            let newPan = startPan + deltaY;
            newPan = Math.max(-100, Math.min(100, newPan));
            track.pan = newPan;

            const indicator = knob.querySelector('.pan-knob-indicator');
            if (indicator) {
              indicator.style.transform = `rotate(${(newPan / 100) * 135}deg)`;
            }

            const labelText = knob.nextElementSibling;
            if (labelText) {
              labelText.textContent = newPan === 0 ? 'C' : (newPan < 0 ? 'L' + Math.abs(newPan) : 'R' + newPan);
            }

            activeNodes.filter(n => n.trackId === tId).forEach(n => {
              if (n.trackPanner) n.trackPanner.pan.setValueAtTime(newPan / 100, audioCtx.currentTime);
            });

            const monitor = activeMonitors.get(tId);
            if (monitor && monitor.monitorPanner) {
              monitor.monitorPanner.pan.setValueAtTime(newPan / 100, audioCtx.currentTime);
            }
          }

          function onMouseUp() {
            window.removeEventListener('mousemove', onMouseMove);
            window.removeEventListener('mouseup', onMouseUp);
          }

          window.addEventListener('mousemove', onMouseMove);
          window.addEventListener('mouseup', onMouseUp);
        });
      });

      document.querySelectorAll('.mute-btn').forEach(b => {
        b.addEventListener('click', (e) => {
          const t = tracks.find(x => x.id === e.target.dataset.trackId);
          if (t) {
            t.muted = !t.muted;
            e.target.classList.toggle('active', t.muted);
            if (isPlaying) {
              stopActiveSources();
              playDAW();
            }
          }
        });
      });

      document.querySelectorAll('.solo-btn').forEach(b => {
        b.addEventListener('click', (e) => {
          const t = tracks.find(x => x.id === e.target.dataset.trackId);
          if (t) {
            t.soloed = !t.soloed;
            e.target.classList.toggle('active', t.soloed);
            if (isPlaying) {
              stopActiveSources();
              playDAW();
            }
          }
        });
      });

      document.querySelectorAll('.rec-btn').forEach(b => {
        b.addEventListener('click', (e) => {
          toggleRecord(e.target.dataset.trackId);
        });
      });

      document.querySelectorAll('.monitor-btn').forEach(b => {
        b.addEventListener('click', (e) => {
          const trackId = e.currentTarget.dataset.trackId;
          toggleMonitor(trackId);
        });
      });

      document.querySelectorAll('.track-name-input').forEach(i => {
        i.addEventListener('change', (e) => {
          const t = tracks.find(x => x.id === e.target.dataset.trackId);
          if (t) t.name = e.target.value;
        });
      });

      if (timelineCanvas) {
        timelineCanvas.removeEventListener('mousedown', handleTimelineMouseDown);
        timelineCanvas.removeEventListener('mousemove', handleTimelineMouseMove);
        timelineCanvas.removeEventListener('mouseup', handleTimelineMouseUp);
        timelineCanvas.removeEventListener('mouseleave', handleTimelineMouseLeave);

        timelineCanvas.addEventListener('mousedown', handleTimelineMouseDown);
        timelineCanvas.addEventListener('mousemove', handleTimelineMouseMove);
        timelineCanvas.addEventListener('mouseup', handleTimelineMouseUp);
        timelineCanvas.addEventListener('mouseleave', handleTimelineMouseLeave);
      }
    }

    function getProjectDuration() {
      let maxTime = 300; // 5 minutos padrão
      tracks.forEach(track => {
        (track.regions || []).forEach(region => {
          const end = region.startTime + region.duration;
          if (end > maxTime) maxTime = end;
        });
      });
      if (songEnd > maxTime) maxTime = songEnd;
      if (loopEnd > maxTime) maxTime = loopEnd;
      return maxTime + 30; // Margem extra para arrastar
    }

    function updateTimelineLayout() {
      updateScrollDummy();
      resizeTimelineCanvas();
    }

    function drawTimeline() {
      if (!timelineCanvas) return;
      const ctx = timelineCanvas.getContext('2d');
      if (!ctx) return;

      const dpr = window.devicePixelRatio || 1;
      const width = timelineCanvas.width / dpr;
      const height = timelineCanvas.height / dpr;

      ctx.clearRect(0, 0, width, height);

      const scrollLeft = timelineScrollContainer ? timelineScrollContainer.scrollLeft : 0;
      const scrollTop = timelineScrollContainer ? timelineScrollContainer.scrollTop : 0;

      const RULER_HEIGHT = 36;
      const visibleTracksCount = tracks.length;

      let currentY = RULER_HEIGHT;
      // Draw Track Lanes
      for (let i = 0; i < visibleTracksCount; i++) {
        const track = tracks[i];
        const trackHeight = track.height || 120;
        const trackY = currentY;
        const drawY = trackY - scrollTop;

        currentY += trackHeight + TRACK_GAP;
        // Skip if outside viewport vertically
        if (drawY + trackHeight < RULER_HEIGHT && i < visibleTracksCount - 1) {
          continue;
        }

        // Track Lane background
        ctx.fillStyle = (selectedTrackId === track.id) ? 'rgba(139, 92, 246, 0.05)' : (i % 2 === 0 ? '#11131a' : '#0d0f14');
        ctx.fillRect(0, Math.max(RULER_HEIGHT, drawY), width, trackHeight);

        // Track border separator
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.06)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, drawY + trackHeight);
        ctx.lineTo(width, drawY + trackHeight);
        ctx.stroke();

        // Arm/Record warning vertical line on the left side
        if (activeRecordTrackId === track.id) {
          ctx.fillStyle = 'rgba(239, 68, 68, 0.2)';
          ctx.fillRect(0, Math.max(RULER_HEIGHT, drawY), 6, trackHeight);
        }
      }

      // Draw Vertical Grid Lines
      const duration = getProjectDuration();
      const snapVal = document.getElementById('selectSnap') ? document.getElementById('selectSnap').value : '0.25';
      let stepSeconds = 1.0;
      if (snapVal !== 'none') {
        const beatValue = parseFloat(snapVal) || 0.25;
        const secondsPerBeat = 60 / bpm;
        stepSeconds = beatValue * secondsPerBeat;
      }
      
      let pixelDist = stepSeconds * PX_PER_SECOND;
      let multiplier = 1;
      if (pixelDist < 25) {
        multiplier = Math.ceil(25 / pixelDist);
      }
      const finalStep = stepSeconds * multiplier;
      const totalSteps = Math.ceil(duration / finalStep);

      const showGrid = document.getElementById('btnToggleGrid')?.classList.contains('active') ?? true;
      if (showGrid) {
        ctx.lineWidth = 1;
        for (let i = 0; i <= totalSteps; i++) {
          const timePos = i * finalStep;
          const xPos = timePos * PX_PER_SECOND - scrollLeft;
          if (xPos < 0 || xPos > width) continue;

          let isMajor = false;
          if (snapVal === 'none') {
            isMajor = Math.round(timePos) % 5 === 0;
          } else {
            const currentBeat = timePos / (60 / bpm);
            isMajor = Math.abs(currentBeat - Math.round(currentBeat)) < 0.01 && Math.round(currentBeat) % 1 === 0;
          }

          ctx.strokeStyle = isMajor ? 'rgba(255, 255, 255, 0.08)' : 'rgba(255, 255, 255, 0.03)';
          ctx.beginPath();
          ctx.moveTo(xPos, RULER_HEIGHT);
          ctx.lineTo(xPos, height);
          ctx.stroke();
        }
      }

      // Draw Audio Clips (Regions)
      ctx.save();
      ctx.beginPath();
      ctx.rect(0, RULER_HEIGHT, width, height - RULER_HEIGHT);
      ctx.clip();

      let clipCurrentY = RULER_HEIGHT;
      for (let trackIdx = 0; trackIdx < visibleTracksCount; trackIdx++) {
        const track = tracks[trackIdx];
        const trackHeight = track.height || 120;
        const trackY = clipCurrentY;
        const drawY = trackY - scrollTop;

        (track.regions || []).forEach(region => {
          const clipStart = region.startTime * PX_PER_SECOND;
          const clipWidth = region.duration * PX_PER_SECOND;
          const x = clipStart - scrollLeft;
          const y = drawY + (trackHeight - 80) / 2; // Centraliza o clipe na faixa
          const w = clipWidth;
          const h = 80;

          if (x + w < 0 || x > width || y + h < RULER_HEIGHT || y > height) return;

          // Clip background gradient
          const grad = ctx.createLinearGradient(x, y, x + w, y);
          grad.addColorStop(0, 'rgba(6, 182, 212, 0.18)');
          grad.addColorStop(1, 'rgba(139, 92, 246, 0.18)');
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.roundRect(x, y, w, h, 6);
          ctx.fill();

          // Border outline
          const borderGrad = ctx.createLinearGradient(x, y, x + w, y);
          borderGrad.addColorStop(0, 'rgba(6, 182, 212, 0.6)');
          borderGrad.addColorStop(1, 'rgba(139, 92, 246, 0.6)');
          ctx.strokeStyle = borderGrad;
          ctx.lineWidth = 1;
          ctx.stroke();

          // Selection highlight border
          if (selectedRegionIds.has(region.id)) {
            ctx.strokeStyle = '#eab308';
            ctx.lineWidth = 2.5;
            ctx.stroke();
          }

          // Draw Waveform peaks
          const peaks = getRegionPeaks(region);
          if (peaks && peaks.length > 0) {
            ctx.save();
            ctx.beginPath();
            ctx.rect(x + 1, y + 1, w - 2, h - 2);
            ctx.clip();

            const waveGrad = ctx.createLinearGradient(0, y, 0, y + h);
            waveGrad.addColorStop(0, 'rgba(34, 211, 238, 0.85)');
            waveGrad.addColorStop(0.5, 'rgba(255, 255, 255, 0.95)');
            waveGrad.addColorStop(1, 'rgba(139, 92, 246, 0.85)');
            ctx.fillStyle = waveGrad;

            const numPeaks = peaks.length / 2;
            const amp = h / 2;

            ctx.beginPath();
            ctx.moveTo(x, y + amp);

            for (let p = 0; p < numPeaks; p++) {
              const xPos = x + (p / numPeaks) * w;
              const maxVal = peaks[p * 2 + 1];
              ctx.lineTo(xPos, y + amp + maxVal * amp * 0.95);
            }
            for (let p = numPeaks - 1; p >= 0; p--) {
              const xPos = x + (p / numPeaks) * w;
              const minVal = peaks[p * 2];
              ctx.lineTo(xPos, y + amp + minVal * amp * 0.95);
            }
            ctx.closePath();
            ctx.fill();
            ctx.restore();
          } else {
            ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
            ctx.font = '10px sans-serif';
            ctx.fillText('⏳ Carregando...', x + 10, y + 45);
          }

          // Draw Fade-in overlay
          if (region.fadeIn > 0) {
            const fadeInPx = region.fadeIn * PX_PER_SECOND;
            ctx.fillStyle = 'rgba(0, 0, 0, 0.5)';
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(x + fadeInPx, y);
            ctx.lineTo(x, y + h);
            ctx.closePath();
            ctx.fill();

            ctx.strokeStyle = 'rgba(255, 255, 255, 0.7)';
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.moveTo(x, y + h);
            ctx.lineTo(x + fadeInPx, y);
            ctx.stroke();

            ctx.fillStyle = '#ffffff';
            ctx.beginPath();
            ctx.arc(x + fadeInPx, y, 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = 'rgba(0,0,0,0.5)';
            ctx.stroke();
          }

          // Draw Fade-out overlay
          if (region.fadeOut > 0) {
            const fadeOutPx = region.fadeOut * PX_PER_SECOND;
            ctx.fillStyle = 'rgba(0, 0, 0, 0.5)';
            ctx.beginPath();
            ctx.moveTo(x + w - fadeOutPx, y);
            ctx.lineTo(x + w, y);
            ctx.lineTo(x + w, y + h);
            ctx.closePath();
            ctx.fill();

            ctx.strokeStyle = 'rgba(255, 255, 255, 0.7)';
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.moveTo(x + w - fadeOutPx, y);
            ctx.lineTo(x + w, y + h);
            ctx.stroke();

            ctx.fillStyle = '#ffffff';
            ctx.beginPath();
            ctx.arc(x + w - fadeOutPx, y, 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = 'rgba(0,0,0,0.5)';
            ctx.stroke();
          }

          // Draw Gain (Volume) Line
          const gainVal = region.gain ?? 1.0;
          const gainY = y + h * (1 - gainVal / 2.0);
          ctx.strokeStyle = 'rgba(234, 179, 8, 0.85)';
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.moveTo(x + 2, gainY);
          ctx.lineTo(x + w - 2, gainY);
          ctx.stroke();

          // Gain dB text
          const db = 20 * Math.log10(gainVal);
          const dbText = gainVal === 0 ? '-∞ dB' : `${db > 0 ? '+' : ''}${db.toFixed(1)} dB`;
          ctx.fillStyle = '#eab308';
          ctx.font = 'bold 9px monospace';
          ctx.fillText(dbText, x + w / 2 - 20, gainY - 3);

          // Draw Clip Name
          ctx.fillStyle = '#ffffff';
          ctx.font = 'bold 11px sans-serif';
          ctx.shadowColor = 'rgba(0, 0, 0, 0.8)';
          ctx.shadowBlur = 3;
          ctx.fillText(region.name, x + 8, y + 16);
          ctx.shadowBlur = 0;
        });
        clipCurrentY += trackHeight + TRACK_GAP;
      }

      // Draw Region selection range overlay
      if (regionSelectionActive && selectionStart !== null && selectionEnd !== null && selectionTrackId) {
        const trackIdx = tracks.findIndex(t => t.id === selectionTrackId);
        if (trackIdx !== -1) {
          let trackY = RULER_HEIGHT;
          for (let i = 0; i < trackIdx; i++) {
            trackY += tracks[i].height || 120;
          }
          const drawY = trackY - scrollTop;
          const trackHeight = tracks[trackIdx].height || 120;
          const overlayY = drawY + (trackHeight - 80) / 2;
          const overlayH = 80;
          const tStart = Math.min(selectionStart, selectionEnd);
          const tEnd = Math.max(selectionStart, selectionEnd);
          const leftPx = tStart * PX_PER_SECOND - scrollLeft;
          const widthPx = (tEnd - tStart) * PX_PER_SECOND;

          ctx.fillStyle = 'rgba(239, 68, 68, 0.25)';
          ctx.strokeStyle = 'rgba(239, 68, 68, 0.7)';
          ctx.lineWidth = 1.5;
          ctx.fillRect(leftPx, overlayY, widthPx, overlayH);
          ctx.strokeRect(leftPx, overlayY, widthPx, overlayH);
        }
      }

      // Draw Ghost Drag previews
      if (dragTarget && dragTarget.type === 'clip-move' && dragTarget.draggedRegions) {
        dragTarget.draggedRegions.forEach(dr => {
          const ghostStart = dr.initialStartTime + dragTarget.deltaTime;
          const destIdx = dr.initialTrackIdx + dragTarget.deltaTrackIdx;
          
          const x = ghostStart * PX_PER_SECOND - scrollLeft;
          
          let trackY = RULER_HEIGHT;
          for (let i = 0; i < Math.min(destIdx, tracks.length); i++) {
            trackY += tracks[i].height || 120;
          }
          const trackHeight = (destIdx < tracks.length) ? (tracks[destIdx].height || 120) : 120;
          const y = trackY + (trackHeight - 80) / 2 - scrollTop;
          
          const w = dr.region.duration * PX_PER_SECOND;
          const h = 80;

          ctx.strokeStyle = '#eab308';
          ctx.lineWidth = 2;
          ctx.setLineDash([6, 4]);
          ctx.fillStyle = 'rgba(234, 179, 8, 0.15)';
          ctx.beginPath();
          ctx.roundRect(x, y, w, h, 6);
          ctx.fill();
          ctx.stroke();
          ctx.setLineDash([]);
        });
      }

      // Draw virtual "Create New Track" row indicator
      if (dragTarget && dragTarget.type === 'clip-move') {
        const needsNewTrack = dragTarget.draggedRegions.some(dr => {
          return (dr.initialTrackIdx + dragTarget.deltaTrackIdx) === tracks.length;
        });
        if (needsNewTrack) {
          let totalTracksHeight = 0;
          for (let i = 0; i < tracks.length; i++) {
            totalTracksHeight += tracks[i].height || 120;
          }
          const drawY = RULER_HEIGHT + totalTracksHeight - scrollTop;
          const newTrackHeight = 120;
          ctx.fillStyle = 'rgba(139, 92, 246, 0.08)';
          ctx.strokeStyle = 'var(--accent)';
          ctx.lineWidth = 2;
          ctx.setLineDash([4, 4]);
          ctx.fillRect(0, drawY, width, newTrackHeight);
          ctx.strokeRect(0, drawY, width, newTrackHeight);
          ctx.setLineDash([]);

          ctx.fillStyle = 'var(--accent)';
          ctx.font = 'bold 13px sans-serif';
          ctx.textAlign = 'left';
          ctx.fillText('+ Criar Nova Trilha ao soltar', 20, drawY + newTrackHeight / 2 + 5);
        }
      }

      // Draw Lasso (Marquee) Selection Rectangle
      if (isDraggingMarquee && dragTarget && dragTarget.type === 'marquee') {
        const x1 = dragTarget.startX - scrollLeft;
        const y1 = dragTarget.startY - scrollTop;
        const x2 = marqueeCurrentX - scrollLeft;
        const y2 = marqueeCurrentY - scrollTop;

        ctx.fillStyle = 'rgba(139, 92, 246, 0.12)';
        ctx.strokeStyle = '#8b5cf6';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 3]);
        ctx.fillRect(x1, y1, x2 - x1, y2 - y1);
        ctx.strokeRect(x1, y1, x2 - x1, y2 - y1);
        ctx.setLineDash([]);
      }

      ctx.restore(); // end region-clip restriction

      // Draw Time Ruler
      ctx.fillStyle = '#0e111a';
      ctx.fillRect(0, 0, width, RULER_HEIGHT);

      ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(0, RULER_HEIGHT);
      ctx.lineTo(width, RULER_HEIGHT);
      ctx.stroke();

      if (loop) {
        const lStart = loopStart * PX_PER_SECOND - scrollLeft;
        const lEnd = loopEnd * PX_PER_SECOND - scrollLeft;
        ctx.fillStyle = 'rgba(234, 179, 8, 0.09)';
        ctx.fillRect(Math.max(0, lStart), 0, Math.min(width, lEnd) - Math.max(0, lStart), RULER_HEIGHT);
      }

      ctx.lineWidth = 1;
      ctx.font = '9px monospace';
      ctx.fillStyle = '#8fa5b7';

      const tickStep = finalStep;
      for (let i = 0; i <= totalSteps; i++) {
        const timePos = i * tickStep;
        const xPos = timePos * PX_PER_SECOND - scrollLeft;
        if (xPos < 0 || xPos > width) continue;

        let isMajor = false;
        if (snapVal === 'none') {
          isMajor = Math.round(timePos) % 5 === 0;
        } else {
          const currentBeat = timePos / (60 / bpm);
          isMajor = Math.abs(currentBeat - Math.round(currentBeat)) < 0.01 && Math.round(currentBeat) % 1 === 0;
        }

        ctx.strokeStyle = isMajor ? 'rgba(255, 255, 255, 0.4)' : 'rgba(255, 255, 255, 0.15)';
        ctx.beginPath();
        ctx.moveTo(xPos, RULER_HEIGHT);
        ctx.lineTo(xPos, isMajor ? RULER_HEIGHT - 10 : RULER_HEIGHT - 6);
        ctx.stroke();

        if (isMajor) {
          const mins = Math.floor(timePos / 60);
          const secs = Math.floor(timePos % 60);
          const label = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
          ctx.fillText(label, xPos - 14, 16);
        }
      }

      // Draw Ruler Markers (Flags)
      const drawFlag = (timeVal, color, labelText) => {
        const x = timeVal * PX_PER_SECOND - scrollLeft;
        if (x < -20 || x > width + 20) return;

        ctx.fillStyle = color;
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 1;

        ctx.beginPath();
        ctx.moveTo(x - 5, 22);
        ctx.lineTo(x + 5, 22);
        ctx.lineTo(x, 32);
        ctx.closePath();
        ctx.fill();
        ctx.stroke();

        ctx.font = 'bold 8px sans-serif';
        ctx.fillText(labelText, x - 12, 10);
      };

      drawFlag(songStart, '#22c55e', 'START');
      drawFlag(songEnd, '#ef4444', 'END');
      if (loop) {
        drawFlag(loopStart, '#eab308', 'L-START');
        drawFlag(loopEnd, '#eab308', 'L-END');
      }

      // Draw Playhead
      const currentPos = isPlaying ? timelinePosition + (audioCtx.currentTime - playbackStartTime) : timelinePosition;
      const playheadX = currentPos * PX_PER_SECOND - scrollLeft;

      if (playheadX >= 0 && playheadX <= width) {
        ctx.strokeStyle = '#ef4444';
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(playheadX, RULER_HEIGHT);
        ctx.lineTo(playheadX, height);
        ctx.stroke();

        ctx.fillStyle = '#ef4444';
        ctx.beginPath();
        ctx.moveTo(playheadX - 6, 20);
        ctx.lineTo(playheadX + 6, 20);
        ctx.lineTo(playheadX, 32);
        ctx.closePath();
        ctx.fill();
      }
    }


                  <button onclick="toggleEfeitoBypassSidebar(${index})" style="background: none; border: none; color: ${active ? 'var(--accent)' : '#6b7280'}; cursor: pointer; font-size: 13px; font-weight: bold; padding: 2px 4px; margin-top: 0; width: auto;" title="Bypass">⏻</button>

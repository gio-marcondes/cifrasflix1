    function renderTrackInspector() {
      const container = document.getElementById('trackInspectorSection');
      if (!container) return;

      const track = tracks.find(t => t.id === selectedTrackId);
      if (!track) {
        container.innerHTML = `
          <div style="text-align: center; padding: 20px; color: var(--text-muted); font-size: 13px;">
            Selecione uma trilha para gerenciar efeitos.
          </div>

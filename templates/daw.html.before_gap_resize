    function atualizarParametroEfeito(index, param, value) {
        const track = tracks.find(t => t.id === selectedTrackId);
        if (!track) return;

        const effect = track.effects[index];
        if (!effect) return;

        let valConverted;
        if (param.endsWith('_active')) {
            valConverted = (value === true || value === 'true' || value === '1' || value === 'on' || value === 'checked');
        } else if (param === 'key' || param === 'scale') {
            valConverted = value;
        } else {
            valConverted = parseFloat(value);
        }
        effect.params[param] = valConverted;

        // Atualizar UI
        const generalLabel = document.getElementById(`val-${param}-${index}`);
        if (generalLabel) {
            if (param.endsWith('_freq') || param === 'tone') {
                generalLabel.textContent = `${valConverted} Hz`;
            } else if (param.endsWith('_gain') || param === 'bass' || param === 'mid' || param === 'treble') {
                generalLabel.textContent = `${valConverted > 0 ? '+' : ''}${valConverted} dB`;
            } else if (param === 'mix' || param === 'feedback' || param === 'level' || param === 'drive') {
                if (param === 'mix' || param === 'feedback' || param === 'level') {
                    generalLabel.textContent = `${Math.round(valConverted * 100)}%`;
                } else {
                    generalLabel.textContent = `${Math.round(valConverted)}%`;
                }
            } else if (param === 'size' || param === 'delayTime') {
                if (param === 'delayTime') {
                    generalLabel.textContent = `${valConverted}s`;
                } else {
                    generalLabel.textContent = parseFloat(valConverted).toFixed(1);
                }
            } else {
                generalLabel.textContent = valConverted;
            }
        }

        const labelId = `valTrackPitch${param.charAt(0).toUpperCase() + param.slice(1)}-${index}`;
        const labelEl = document.getElementById(labelId);
        if (labelEl) {
            labelEl.textContent = `${valConverted}%`;
        }

        if (effect.type === 'pitch_correction') {
            if (param === 'intensity') document.getElementById(`valTrackPitchIntensity-${index}`).textContent = `${valConverted}%`;
            if (param === 'humanize') document.getElementById(`valTrackPitchHumanize-${index}`).textContent = `${valConverted}%`;
        }

        if (isPlaying) {
            updateActiveEffectNodeParam(track.id, index, param, valConverted);
        }
    }


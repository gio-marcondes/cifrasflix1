    function duplicarTrilhaSelecionada() {
      if (!selectedTrackId) return alert("Selecione uma trilha para duplicar!");
      const sourceTrack = tracks.find(t => t.id === selectedTrackId);
      if (!sourceTrack) return;

      saveHistory();

      const duplicatedTrack = {
        id: `track-${Date.now()}-${Math.floor(Math.random() * 1000)}`,
        name: `${sourceTrack.name} (Cópia)`,
        type: sourceTrack.type,
        color: sourceTrack.color,
        volume: sourceTrack.volume,
        pan: sourceTrack.pan,
        muted: sourceTrack.muted,
        soloed: sourceTrack.soloed,
        monitoring: false,
        effects: JSON.parse(JSON.stringify(sourceTrack.effects || [])),
        regions: (sourceTrack.regions || []).map(r => ({
          id: `region-${Date.now()}-${Math.floor(Math.random() * 1000)}`,
          name: r.name,
          startTime: r.startTime, 
          height: sourceTrack.height || 120,
          duration: r.duration,
          offset: r.offset ?? 0,
          bufferKey: r.bufferKey,
          gain: r.gain ?? 1.0,
          fadeIn: r.fadeIn ?? 0.0,
          fadeOut: r.fadeOut ?? 0.0,
          buffer: r.buffer
        })),
        midiClips: JSON.parse(JSON.stringify(sourceTrack.midiClips || [])),
        instrument: sourceTrack.instrument ? JSON.parse(JSON.stringify(sourceTrack.instrument)) : null
      };

      // Inserir logo após a trilha original
      const index = tracks.findIndex(t => t.id === selectedTrackId);
      if (index !== -1) {
        tracks.splice(index + 1, 0, duplicatedTrack);
      } else {
        tracks.push(duplicatedTrack);
      }

      selectedTrackId = duplicatedTrack.id;
      renderDAW();
    }

    function copiarRegiaoSelecionada() {
      if (!selectedRegionId || !selectedRegionTrackId) return;
      const track = tracks.find(t => t.id === selectedRegionTrackId);
      if (!track) return;
      const region = track.regions.find(r => r.id === selectedRegionId);
      if (!region) return;

      clipboardRegion = {
        name: region.name,
        duration: region.duration,
        offset: region.offset ?? 0,
        bufferKey: region.bufferKey,
        gain: region.gain ?? 1.0,
        fadeIn: region.fadeIn ?? 0.0,
        fadeOut: region.fadeOut ?? 0.0,
        buffer: region.buffer
      };
    }

    function recortarRegiaoSelecionada() {
      if (!selectedRegionId || !selectedRegionTrackId) return;
      copiarRegiaoSelecionada();

      const track = tracks.find(t => t.id === selectedRegionTrackId);
      if (!track) return;

      saveHistory();
      track.regions = track.regions.filter(r => r.id !== selectedRegionId);
      selectedRegionId = null;
      selectedRegionTrackId = null;

      renderDAW();
      if (isPlaying) {
        stopActiveSources();
        playDAW();
      }
    }

    function colarRegiao() {
      if (!clipboardRegion) return;
      if (!selectedTrackId) return alert("Selecione uma trilha para colar!");

      const targetTrack = tracks.find(t => t.id === selectedTrackId);
      if (!targetTrack) return;

      saveHistory();

      const newRegion = {
        id: `region-${Date.now()}-${Math.floor(Math.random() * 1000)}`,
        name: clipboardRegion.name + " (Colado)",
        startTime: timelinePosition, // Cola na posição atual da agulha (playhead)
        duration: clipboardRegion.duration,
        offset: clipboardRegion.offset,
        bufferKey: clipboardRegion.bufferKey,
        gain: clipboardRegion.gain,
        fadeIn: clipboardRegion.fadeIn,
        fadeOut: clipboardRegion.fadeOut,
        buffer: clipboardRegion.buffer
      };

      targetTrack.regions.push(newRegion);

      // Seleciona o clipe recém colado
      selectedRegionId = newRegion.id;
      selectedRegionTrackId = targetTrack.id;

      renderDAW();

      if (isPlaying) {
        stopActiveSources();
        playDAW();
      }
    }


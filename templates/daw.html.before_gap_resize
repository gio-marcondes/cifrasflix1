            <span style="font-size: 11px; background: ${track.color || 'var(--accent)'}; color: #fff; padding: 2px 8px; border-radius: 20px; font-weight: bold; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">

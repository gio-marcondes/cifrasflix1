      if (playheadM) void playheadM.offsetWidth;
      if (playheadL) void playheadL.offsetWidth;
      
      if (playheadM) playheadM.classList.add('is-animated');
      if (playheadL) playheadL.classList.add('is-animated');
      
      if (playheadAnimationTimer) {
        window.clearTimeout(playheadAnimationTimer);
      }
      playheadAnimationTimer = window.setTimeout(() => {
        if (playheadM) playheadM.classList.remove('is-animated');
        if (playheadL) playheadL.classList.remove('is-animated');
      }, 240);
    }

    function formatTimeDisplayCompact(seconds) {
      const total = Math.max(0, Number(seconds || 0));
      const minutos = Math.floor(total / 60);
      const resto = Math.floor(total % 60);
      return `${String(minutos).padStart(2, '0')}:${String(resto).padStart(2, '0')}`;
    }

    function atualizarTransporteMasterDAW(currentPos = null) {
      if (currentPos === null) {
        if (isPlaying) {
          const delta = audioCtx.currentTime - playbackStartTime;
          currentPos = timelinePosition + delta;
        } else {
          currentPos = timelinePosition;
        }
      }
      
      const duracao = getProjectDuration();
      
      const seekEl = document.getElementById('transportSeek');
      if (seekEl) {
        const valor = duracao > 0 ? Math.round((currentPos / duracao) * 1000) : 0;
        seekEl.value = Math.max(0, Math.min(1000, valor));
      }
      
      const currentEl = document.getElementById('transportCurrent');
      if (currentEl) {
        currentEl.textContent = formatTimeDisplayCompact(currentPos);
      }
      
      const durationEl = document.getElementById('transportDuration');
      if (durationEl) {
        durationEl.textContent = formatTimeDisplayCompact(duracao);
      }
    }

    function atualizarTransportePlayState() {
      const btn = document.getElementById('transportPlay');
      if (!btn) return;
      btn.classList.toggle('is-active', isPlaying);
      
      const svg = document.getElementById('svgPlayPause');
      if (svg) {
        if (isPlaying) {
          svg.innerHTML = `<rect x="8" y="6" width="4" height="16" fill="#fff"/><rect x="16" y="6" width="4" height="16" fill="#fff"/>`;
        } else {
          svg.innerHTML = `<polygon points="10,7 22,14 10,21" fill="#fff"/>`;
        }
      }
    }

    // Atualização visual do cursor de reprodução (Playhead)
    function updatePlayheadVisual() {
      if (!isPlaying) return;

      const delta = audioCtx.currentTime - playbackStartTime;
      const currentPos = timelinePosition + delta;

      // Atualizar preview visual da gravação se estiver ativo
      if (activeRecordTrackId && mediaRecorder && mediaRecorder.state === "recording") {
        const duration = currentPos - recordStartTime;
        const previewDiv = document.getElementById('recording-preview-clip');
        if (previewDiv) {
          previewDiv.style.width = `${Math.max(0, duration * PX_PER_SECOND)}px`;
          const durationSpan = document.getElementById('recording-preview-duration');
          if (durationSpan) {
            durationSpan.textContent = `${Math.max(0, duration).toFixed(2)}s`;
          }
          const canvas = document.getElementById('recording-waveform-canvas');
          if (canvas && recAnalyser) {
            drawLiveWaveform(canvas, recAnalyser);
          }
        }
      }

      // Loop do projeto (cinza) e fim da música (azul)
      if (loop && currentPos >= loopEnd) {
        timelinePosition = loopStart;
        playbackStartTime = audioCtx.currentTime;
        animarSaltoPlayhead();
        scheduleAudioPlayback();
        requestAnimationFrame(updatePlayheadVisual);
        return;
      }

      if (currentPos >= songEnd) {
        stopDAW();
        return;
      }

      // Mover playhead visualmente
      const posPx = currentPos * PX_PER_SECOND;
      const playheadLine = document.getElementById('playheadLine');
      if (playheadLine) playheadLine.style.left = `${posPx}px`;
      
      const playheadM = document.getElementById('playheadMarker');
      if (playheadM) playheadM.style.left = `${posPx}px`;

      atualizarTransporteMasterDAW(currentPos);

      // Auto-scroll conforme playhead avança
      if (autoScroll && timelineScrollContainer) {
        const scrollRightEdge = timelineScrollContainer.scrollLeft + timelineScrollContainer.clientWidth;
        if (posPx >= scrollRightEdge - 20) {
          timelineScrollContainer.scrollLeft = posPx - 100; // centraliza/mostra com folga
        } else if (posPx < timelineScrollContainer.scrollLeft) {
          timelineScrollContainer.scrollLeft = Math.max(0, posPx - 100);
        }
      }
      
      // Redraw canvas to animate playhead movement
      drawTimeline();

      // Atualizar relógio digital
      document.getElementById('displayTime').textContent = formatDigitalTime(currentPos);

      requestAnimationFrame(updatePlayheadVisual);
    }

    // Formatador digital: MM:SS.CC (minutos, segundos, centésimos)
    function formatDigitalTime(seconds) {
      const min = Math.floor(seconds / 60);
      const sec = Math.floor(seconds % 60);
      const ms = Math.floor((seconds % 1) * 100);
      return `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}.${String(ms).padStart(2, '0')}`;
    }

    // Desenhar a waveform em tempo real usando o AnalyserNode do microfone
    function drawLiveWaveform(canvas, analyser) {
      const ctx = canvas.getContext('2d');
      const width = canvas.offsetWidth;
      const height = canvas.offsetHeight;

      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }

      const bufferLength = analyser.frequencyBinCount;
      const dataArray = new Uint8Array(bufferLength);
      analyser.getByteTimeDomainData(dataArray);

      ctx.clearRect(0, 0, width, height);

      // Estilo da linha da waveform em tempo real (lilás/azul vibrante ou vermelho)
      ctx.lineWidth = 2.5;
      ctx.strokeStyle = '#ef4444'; 
      ctx.shadowBlur = 4;
      ctx.shadowColor = 'rgba(239, 68, 68, 0.5)';
      ctx.beginPath();

      const sliceWidth = width / bufferLength;
      let x = 0;

      for (let i = 0; i < bufferLength; i++) {
        const v = dataArray[i] / 128.0;
        const y = (v * height) / 2;

        if (i === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
        x += sliceWidth;
      }

      ctx.lineTo(width, height / 2);
      ctx.stroke();
      
      // Reseta shadow para outros desenhos
      ctx.shadowBlur = 0;
    }

    // =========================================================================
    // 🥁 SISTEMA DO METRÔNOMO
    // =========================================================================
    let nextMetronomeTickTime = 0.0;
    let currentBeat = 0;

    function startMetronome() {
      currentBeat = 0;
      nextMetronomeTickTime = audioCtx.currentTime;
      schedulerMetronome();
    }

    function stopMetronome() {
      clearTimeout(metronomeTimer);
    }

    function schedulerMetronome() {
      if (!isPlaying || !metronome) return;

      while (nextMetronomeTickTime < audioCtx.currentTime + 0.1) {
        scheduleTick(currentBeat, nextMetronomeTickTime);
        const secondsPerBeat = 60.0 / bpm;
        nextMetronomeTickTime += secondsPerBeat;
        currentBeat = (currentBeat + 1) % 4; // compasso 4/4
      }
      metronomeTimer = setTimeout(schedulerMetronome, 25);
    }

    function scheduleTick(beatNumber, time) {
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      
      osc.connect(gain);
      gain.connect(audioCtx.destination); // Metrônomo direto na saída física

      // Primeiro beat agudo, os outros mais graves
      osc.frequency.setValueAtTime(beatNumber === 0 ? 1000 : 500, time);
      
      gain.gain.setValueAtTime(0.3, time);
      gain.gain.exponentialRampToValueAtTime(0.001, time + 0.08);

      osc.start(time);
      osc.stop(time + 0.08);
    }

    // =========================================================================
    // ✂️ MODO CORTE & DRAG CLIPS
    // =========================================================================

    // Recortar clipe de áudio ao clicar em Modo Corte
    function splitClip(trackId, regionId, splitTimelineTime) {
      saveHistory();
      const track = tracks.find(t => t.id === trackId);
      if (!track) return;

      const regionIndex = track.regions.findIndex(r => r.id === regionId);
      if (regionIndex === -1) return;

      const region = track.regions[regionIndex];
      
      // Valida se o tempo de corte está de fato dentro da duração do clipe
      const splitTimeInClip = splitTimelineTime - region.startTime;
      if (splitTimeInClip <= 0 || splitTimeInClip >= region.duration) return;

      // Duplicar a região em duas partes
      const part1 = {
        id: `clip-${Date.now()}-1`,
        name: `${region.name} Pt1`,
        startTime: region.startTime,
        duration: splitTimeInClip,
        offset: region.offset,
        bufferKey: region.bufferKey,
        buffer: region.buffer
      };

      const part2 = {
        id: `clip-${Date.now()}-2`,
        name: `${region.name} Pt2`,
        startTime: splitTimelineTime,
        duration: region.duration - splitTimeInClip,
        offset: region.offset + splitTimeInClip,
        bufferKey: region.bufferKey,
        buffer: region.buffer
      };

      // Remover antiga e inserir as novas duas partes
      track.regions.splice(regionIndex, 1, part1, part2);
      renderDAW();
    }

    function cancelarSelecaoRegiao() {
      selectionStart = null;
      selectionEnd = null;
      selectionTrackId = null;
      selectionTrackRowElement = null;
      isSelectingRegion = false;
      const overlay = document.getElementById('selectionOverlay');
      if (overlay) overlay.style.display = 'none';
    }

    function apagarTrechoSelecionado() {
      if (selectionStart === null || selectionEnd === null) return;
      const tStart = Math.min(selectionStart, selectionEnd);
      const tEnd = Math.max(selectionStart, selectionEnd);
      if (tStart === tEnd) return;

      saveHistory();

      // Aplica apenas na trilha que foi arrastada
      const targetTracks = selectionTrackId ? tracks.filter(t => t.id === selectionTrackId) : (selectedTrackId ? tracks.filter(t => t.id === selectedTrackId) : tracks);

      targetTracks.forEach(track => {
        let newRegions = [];
        track.regions.forEach(reg => {
          const regStart = reg.startTime;
          const regEnd = reg.startTime + reg.duration;

          // Caso 1: Fora da área de seleção -> manter inalterada
          if (regEnd <= tStart || regStart >= tEnd) {
            newRegions.push(reg);
          }
          // Caso 2: Totalmente contido na seleção -> descartar
          else if (regStart >= tStart && regEnd <= tEnd) {
            // Descartado
          }
          // Caso 3: A seleção divide o clipe no meio
          else if (regStart < tStart && regEnd > tEnd) {
            // Clip 1 (antes da seleção)
            const dur1 = tStart - regStart;
            newRegions.push({
              ...reg,
              id: `region-${Date.now()}-${Math.floor(Math.random()*1000)}`,
              duration: dur1
            });
            // Clip 2 (depois da seleção)
            const dur2 = regEnd - tEnd;
            const off2 = (reg.offset || 0) + (tEnd - regStart);
            newRegions.push({
              ...reg,
              id: `region-${Date.now()}-${Math.floor(Math.random()*1000)}`,
              startTime: tEnd,
              duration: dur2,
              offset: off2
            });
          }
          // Caso 4: A seleção corta o início do clipe
          else if (regStart >= tStart && regStart < tEnd && regEnd > tEnd) {
            const cutAmount = tEnd - regStart;
            newRegions.push({
              ...reg,
              id: `region-${Date.now()}-${Math.floor(Math.random()*1000)}`,
              startTime: tEnd,
              duration: reg.duration - cutAmount,
              offset: (reg.offset || 0) + cutAmount
            });
          }
          // Caso 5: A seleção corta o fim do clipe
          else if (regStart < tStart && regEnd > tStart && regEnd <= tEnd) {
            const newDur = tStart - regStart;
            newRegions.push({
              ...reg,
              id: `region-${Date.now()}-${Math.floor(Math.random()*1000)}`,
              duration: newDur
            });
          }
        });
        track.regions = newRegions;
      });

      // Limpar seleção
      cancelarSelecaoRegiao();
      renderDAW();

      if (isPlaying) {
        stopActiveSources();
        playDAW();
      }
    }

    function setZoom(newPxPerSec) {

      // Renderiza as curvas de EQ logo após montar o HTML no DOM
      if (track && track.effects) {
        track.effects.forEach((effect, index) => {
          if (effect.type === 'pro_eq' && effect.expanded !== false) {
            redesenharEqSidebar(index);

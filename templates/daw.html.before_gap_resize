        html += `
          <div style="text-align: center; padding: 16px; border: 1px dashed rgba(255,255,255,0.1); border-radius: 8px; color: var(--text-muted); font-size: 12px; margin-bottom: 12px;">
            Nenhum efeito nesta trilha.
          </div>
        `;
      } else {
        track.effects.forEach((effect, index) => {
          let title = getEffectTitle(effect.type);
          let active = effect.active;
          let expanded = effect.expanded !== false;

          html += `
            <div class="sidebar-fx-slot" style="background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; overflow: hidden; transition: border-color 0.2s;">

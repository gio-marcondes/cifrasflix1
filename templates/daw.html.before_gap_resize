    async function carregarDispositivosAudio() {
      try {
        try {
          const tempStream = await navigator.mediaDevices.getUserMedia({ audio: true });
          tempStream.getTracks().forEach(track => track.stop());
        } catch (e) {
          console.warn("Permissão de áudio negada ou não concedida ainda:", e);
        }

        const devices = await navigator.mediaDevices.enumerateDevices();
        const micSelect = document.getElementById('selectInputDevice');
        const speakerSelect = document.getElementById('selectOutputDevice');
        
        if (!micSelect || !speakerSelect) return;

        micSelect.innerHTML = "";
        speakerSelect.innerHTML = "";

        let hasInputs = false;
        let hasOutputs = false;

        devices.forEach(device => {
          if (device.kind === 'audioinput') {
            hasInputs = true;
            const opt = document.createElement('option');
            opt.value = device.deviceId;
            opt.textContent = device.label || `Microfone (${device.deviceId.slice(0, 5)})`;
            if (device.deviceId === activeInputDeviceId) opt.selected = true;
            micSelect.appendChild(opt);
          } else if (device.kind === 'audiooutput') {
            hasOutputs = true;
            const opt = document.createElement('option');
            opt.value = device.deviceId;
            opt.textContent = device.label || `Saída de Áudio (${device.deviceId.slice(0, 5)})`;
            if (device.deviceId === activeOutputDeviceId) opt.selected = true;
            speakerSelect.appendChild(opt);
          }
        });

        if (!hasInputs) {
          micSelect.innerHTML = `<option value="">Nenhum microfone encontrado</option>`;
        }
        if (!hasOutputs) {
          speakerSelect.innerHTML = `<option value="">Saída padrão do sistema</option>`;
        }
      } catch (err) {
        console.error("Erro ao enumerar dispositivos:", err);
      }
    }


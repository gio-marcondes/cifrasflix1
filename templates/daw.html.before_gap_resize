<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CifrasFlix DAW - Estúdio Digital</title>
  
  <!-- Fontes Premium -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Orbitron:wght@700&display=swap" rel="stylesheet">
  
  <style>
    @keyframes pulse {
      0% { opacity: 0.6; }
      100% { opacity: 1; }
    }
    .recording-clip-preview {
      background: rgba(239, 68, 68, 0.25) !important;
      border: 2px dashed #ef4444 !important;
      z-index: 5;
    }

    :root {
      --bg-dark: #070b14;
      --panel-bg: rgba(22, 28, 45, 0.45);
      --panel-border: rgba(148, 163, 184, 0.12);
      --accent: #8b5cf6;
      --accent-glow: rgba(139, 92, 246, 0.3);
      --cyan: #06b6d4;
      --rose: #f43f5e;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --track-height: 120px;
    }

    * {
      box-sizing: border-box;
      user-select: none;
    }

    body {
      margin: 0;
      padding: 0;
      background-color: var(--bg-dark);
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(6, 182, 212, 0.06) 0%, transparent 40%);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      overflow: hidden;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Menu Superior (Menu de Arquivo) */
    .top-menu-bar {
      background: rgba(8, 10, 18, 0.95);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      padding: 6px 20px;
      font-size: 13px;
      user-select: none;
      z-index: 1000;
      position: relative;
      flex-shrink: 0;
    }

    .menu-item {
      position: relative;
      cursor: pointer;
    }

    .menu-trigger {
      padding: 6px 12px;
      color: var(--text-color);
      border-radius: 4px;
      display: inline-block;
      transition: background 0.15s, color 0.15s;
      font-weight: 500;
    }

    .menu-trigger:hover, .menu-item:hover .menu-trigger {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
    }

    .menu-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: #111424;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      min-width: 180px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      padding: 4px 0;
      z-index: 1010;
    }

    .menu-item:hover .menu-dropdown {
      display: block;
    }

    .menu-dropdown.closed {
      display: none !important;
    }

    .menu-dropdown a {
      color: #ccc;
      padding: 8px 16px;
      text-decoration: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      transition: background 0.15s, color 0.15s;
    }

    .menu-dropdown a:hover {
      background: var(--accent);
      color: #fff;
    }

    /* Submenu para Exportar */
    .menu-submenu-parent {
      position: relative;
    }

    .menu-submenu {
      display: none;
      position: absolute;
      top: 0;
      left: 100%;
      background: #111424;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      min-width: 180px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      padding: 4px 0;
      z-index: 1020;
    }

    .menu-submenu-parent:hover .menu-submenu {
      display: block;
    }

    /* Header e Barra de Ferramentas */
    header {
      background: rgba(10, 15, 30, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--panel-border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-shrink: 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-logo {
      font-size: 28px;
    }

    .brand-title h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 800;
      letter-spacing: 0.5px;
      background: linear-gradient(90deg, #a78bfa, #22d3ee);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .brand-title p {
      margin: 0;
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .transport-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid var(--panel-border);
      border-radius: 12px;
      padding: 6px 12px;
    }
    
    .transport-bar .tempo-stepper {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    
    .transport-bar .tempo-stepper .btn-daw {
      padding: 6px 8px;
    }

    .btn-daw {
      background: transparent;
      border: 1px solid transparent;
      color: var(--text);
      font-family: inherit;
      font-weight: 600;
      font-size: 13px;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s ease;
    }

    .btn-daw:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .btn-daw.active {
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent-glow);
    }

    .btn-play {
      color: #10b981;
    }
    .btn-play.active {
      background: #10b981;
      color: #fff;
      box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
    }

    .btn-rec {
      color: var(--rose);
    }
    .btn-rec.active {
      background: var(--rose);
      color: #fff;
      box-shadow: 0 0 12px rgba(244, 63, 94, 0.3);
      animation: flash 1.5s infinite;
    }

    @keyframes flash {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }

    .session-controls {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .bpm-control, .snap-control {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
    }

    .bpm-control input, .snap-control select {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid var(--panel-border);
      border-radius: 6px;
      color: var(--text);
      padding: 6px 8px;
      font-family: inherit;
      font-weight: bold;
      width: 64px;
      outline: none;
      transition: border-color 0.2s;
    }

    .bpm-control input:focus, .snap-control select:focus {
      border-color: var(--accent);
    }

    .bpm-control input.tempo-display {
      width: 50px;
      text-align: center;
      font-weight: 800;
    }

    .snap-control select {
      width: 90px;
    }

    .display-time {
      font-family: 'Orbitron', monospace;
      font-size: 18px;
      color: var(--cyan);
      letter-spacing: 1px;
      background: #020617;
      padding: 4px 12px;
      border-radius: 6px;
      border: 1px solid rgba(6, 182, 212, 0.15);
      width: 130px;
      flex-shrink: 0;
      display: inline-block;
      text-align: center;
    }

    /* Área Principal da DAW */
    .daw-workspace {
      display: flex;
      flex: 1;
      overflow: hidden;
      position: relative;
    }

    /* Painel do Mixer Esquerdo (Track Controls) */
    .mixer-panel {
      width: 280px;
      background: rgba(10, 15, 30, 0.6);
      border-right: 1px solid var(--panel-border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      z-index: 10;
    }

    .mixer-title {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      padding: 16px 20px 8px;
      margin: 0;
      border-bottom: 1px solid var(--panel-border);
    }

    .track-headers-list {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
    }

    .track-header {
      height: var(--track-height);
      border-bottom: 1px solid var(--panel-border);
      padding: 8px 12px;
      display: flex;
      flex-direction: row !important;
      align-items: stretch;
      gap: 10px;
      background: rgba(15, 23, 42, 0.25);
      transition: background 0.2s;
    }

    .track-header:hover {
      background: rgba(15, 23, 42, 0.4);
    }

    .track-header.selected {
      border-left: 3px solid var(--accent);
      background: rgba(139, 92, 246, 0.05);
    }

    .track-header.drag-over {
      border-top: 3px solid var(--accent) !important;
      background: rgba(139, 92, 246, 0.15) !important;
    }

    .track-resize-handle {
      position: absolute;
      bottom: -3px;
      left: 0;
      right: 0;
      height: 6px;
      cursor: ns-resize;
      z-index: 20;
      background: transparent;
      transition: background 0.2s;
    }
    .track-resize-handle:hover { background: rgba(139, 92, 246, 0.4); }

    .track-header.dragging-header {
      opacity: 0.4;
    }

    .track-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .track-name-input {
      background: transparent;
      border: 1px solid transparent;
      color: var(--text);
      font-family: inherit;
      font-weight: 600;
      font-size: 13px;
      width: 140px;
      outline: none;
      padding: 2px 4px;
      border-radius: 4px;
    }

    .track-name-input:focus {
      background: rgba(0, 0, 0, 0.3);
      border-color: var(--panel-border);
    }

    .track-delete-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 14px;
      padding: 4px;
      transition: color 0.2s;
    }

    .track-delete-btn:hover {
      color: var(--rose);
    }

    .track-faders {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .fader-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .fader-group label {
      font-size: 10px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: flex;
      justify-content: space-between;
    }

    .fader-group input[type="range"] {
      width: 100%;
      accent-color: var(--accent);
      background: rgba(0, 0, 0, 0.4);
      height: 4px;
      border-radius: 2px;
      outline: none;
    }

    .track-toggles {
      display: flex;
      gap: 4px;
    }

    .btn-toggle {
      min-width: 24px;
      padding: 0 4px;
      height: 20px;
      border-radius: 4px;
      border: 1px solid rgba(148, 163, 184, 0.15);
      background: rgba(10, 15, 30, 0.6);
      color: var(--text-muted);
      font-size: 10px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s;
      outline: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-toggle.mute-btn.active {
      background: #f59e0b;
      color: #fff;
      border-color: #f59e0b;
    }

    .btn-toggle.solo-btn.active {
      background: #06b6d4;
      color: #fff;
      border-color: #06b6d4;
    }

    .btn-toggle.rec-btn.active {
      background: var(--rose);
      color: #fff;
      border-color: var(--rose);
      animation: flash 1.2s infinite;
    }

    .btn-toggle.monitor-btn.active {
      background: #eab308;
      color: #12131a;
      border-color: #eab308;
      box-shadow: 0 0 8px rgba(234, 179, 8, 0.4);
    }

    .btn-toggle.fx-btn.active-fx {
      background: rgba(139, 92, 246, 0.25);
      color: #a78bfa;
      border-color: #8b5cf6;
      box-shadow: 0 0 8px var(--accent-glow);
    }

    .pan-knob:hover {
      border-color: var(--accent) !important;
      box-shadow: inset 0 2px 4px rgba(0,0,0,0.8), 0 0 4px var(--accent-glow);
    }

    /* Timeline e Grid de Trilhas */
    .timeline-container {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    /* Régua de Tempo */
    .timeline-ruler {
      height: 36px;
      background: rgba(10, 15, 30, 0.8);
      border-bottom: 1px solid var(--panel-border);
      position: relative;
      flex-shrink: 0;
      overflow: hidden;
    }

    .ruler-ticks {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 5000px; /* Expansível */
    }

    .ruler-tick {
      position: absolute;
      bottom: 0;
      border-left: 1px solid rgba(148, 163, 184, 0.25);
      height: 12px;
      color: var(--text-muted);
      font-size: 10px;
      font-family: monospace;
      padding-left: 4px;
    }

    .ruler-tick.major {
      height: 24px;
      border-left-color: rgba(148, 163, 184, 0.5);
    }

    /* Tickers de Régua e Linhas Verticais */
    .ruler-marker {
      position: absolute;
      top: 0;
      width: 14px;
      height: 24px;
      cursor: ew-resize;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: filter 0.1s;
    }
    .ruler-marker:hover {
      filter: brightness(1.25);
    }
    .ruler-marker::before {
      content: "";
      width: 0;
      height: 0;
      border-left: 7px solid transparent;
      border-right: 7px solid transparent;
      border-top: 14px solid currentColor;
      position: absolute;
      top: 0;
    }
    .ruler-marker.song-start {
      color: #3b82f6; /* Azul */
      margin-left: -7px;
    }
    .ruler-marker.song-end {
      color: #1d4ed8; /* Azul Escuro */
      margin-left: -7px;
    }
    .ruler-marker.loop-start {
      color: #94a3b8; /* Cinza */
      margin-left: -7px;
    }
    .ruler-marker.loop-end {
      color: #64748b; /* Cinza Escuro */
      margin-left: -7px;
    }
    .ruler-marker.playhead-marker {
      color: #ef4444; /* Vermelho */
      margin-left: -7px;
      z-index: 15;
    }
    .ruler-marker-line {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1px;
      pointer-events: none;
      z-index: 2;
    }
    .ruler-marker-line.song-start {
      border-left: 1px dashed rgba(59, 130, 246, 0.45);
    }
    .ruler-marker-line.song-end {
      border-left: 1px dashed rgba(29, 78, 216, 0.45);
    }
    .ruler-marker-line.loop-start {
      border-left: 1px dashed rgba(148, 163, 184, 0.45);
    }
    .ruler-marker-line.loop-end {
      border-left: 1px dashed rgba(100, 116, 139, 0.45);
    }


    /* Área de Faixas (Tracks Timeline View) */
    .tracks-timeline {
      flex: 1;
      overflow: auto;
      position: relative;
    }

    .timeline-grid-lines {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 5000px;
      pointer-events: none;
      z-index: 1;
    }

    .grid-line {
      position: absolute;
      top: 0;
      bottom: 0;
      border-left: 1px dashed rgba(148, 163, 184, 0.05);
    }

    .grid-line.major {
      border-left: 1px solid rgba(148, 163, 184, 0.1);
    }

    .tracks-list {
      position: relative;
      width: 5000px;
      z-index: 2;
    }

    .timeline-track-row {
      height: var(--track-height);
      border-bottom: 1px solid var(--panel-border);
      position: relative;
      background: rgba(255, 255, 255, 0.01);
    }

    .timeline-track-row.selected {
      background: rgba(139, 92, 246, 0.015);
    }

    .timeline-track-row.drag-file-over {
      background: rgba(139, 92, 246, 0.15) !important;
      border: 1px dashed var(--accent) !important;
    }

    .cut-mode-active .tracks-timeline,
    .cut-mode-active .audio-clip,
    .cut-mode-active .tracks-list,
    .cut-mode-active .timeline-track-row {
      cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><path d='M2 30 L10 22 L14 26 L6 30 Z' fill='%23cbd5e1' stroke='%230f172a' stroke-width='1.5'/><path d='M2 30 L6 30' stroke='%230f172a' stroke-width='1.5'/><path d='M10 22 L26 6 L30 10 L14 26 Z' fill='%23ffffff' stroke='%230f172a' stroke-width='1.5'/><line x1='15' y1='17' x2='19' y2='13' stroke='%2394a3b8' stroke-width='1'/></svg>") 2 30, pointer !important;
    }

    /* Estilos do Canvas do Timeline */
    #timelineCanvas {
      image-rendering: -moz-crisp-edges;
      image-rendering: -webkit-crisp-edges;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
    }

    /* Painel do Mixer Master Direito */
    .master-effects-panel {
      width: 300px;
      background: rgba(10, 15, 30, 0.8);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-left: 1px solid var(--panel-border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      z-index: 10;
      overflow-y: auto;
    }

    .panel-section {
      padding: 20px;
      border-bottom: 1px solid var(--panel-border);
    }

    .panel-section h3 {
      margin: 0 0 16px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--cyan);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .switch-effect {
      appearance: none;
      width: 32px;
      height: 18px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 9px;
      position: relative;
      cursor: pointer;
      outline: none;
      transition: background 0.3s;
    }

    .switch-effect::after {
      content: '';
      position: absolute;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #fff;
      top: 2px;
      left: 2px;
      transition: left 0.3s;
    }

    .switch-effect:checked {
      background: var(--accent);
    }

    .switch-effect:checked::after {
      left: 16px;
    }

    .slider-row {
      margin-bottom: 12px;
    }

    .slider-row label {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .slider-row input[type="range"] {
      width: 100%;
      accent-color: var(--cyan);
    }

    /* Rodapé e Ações */
    footer {
      background: rgba(10, 15, 30, 0.9);
      border-top: 1px solid var(--panel-border);
      padding: 10px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
    }

    .footer-left {
      display: flex;
      gap: 12px;
    }

    .footer-right {
      color: var(--text-muted);
      font-size: 12px;
    }

    /* Estilo do Input de File invisível */
    .file-input {
      display: none;
    }

    /* Modal FX Rack CifrasFlix */
    .modal-fx-content {
      background: rgba(15, 20, 35, 0.95);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 16px;
      padding: 24px;
      width: 800px;
      max-width: 95%;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6), 0 0 15px rgba(139, 92, 246, 0.15);
      backdrop-filter: blur(16px);
      display: flex;
      flex-direction: column;
      max-height: 90vh;
    }
    
    .fx-rack-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 12px;
    }
    
    .fx-rack-header h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 600;
      color: #fff;
      background: linear-gradient(90deg, #a78bfa, #22d3ee);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .fx-add-selector {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .fx-add-selector select {
      background: rgba(10, 15, 30, 0.8);
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 6px;
      color: #fff;
      padding: 6px 12px;
      font-family: inherit;
      font-size: 12px;
      outline: none;
    }

    .fx-add-selector button {
      background: var(--accent);
      border: none;
      color: #fff;
      padding: 6px 14px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
    }

    .fx-add-selector button:hover {
      background: #7c3aed;
      box-shadow: 0 0 8px var(--accent-glow);
    }
    
    .fx-slots-list {
      flex: 1;
      overflow-y: auto;
      margin-bottom: 16px;
      padding-right: 4px;
    }

    .fx-empty-state {
      text-align: center;
      color: var(--text-muted);
      font-size: 13px;
      padding: 40px 20px;
      border: 1px dashed rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.01);
    }

    .fx-slot-item {
      background: rgba(10, 15, 30, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 12px;
      position: relative;
      transition: border-color 0.2s;
    }

    .fx-slot-item:hover {
      border-color: rgba(139, 92, 246, 0.2);
    }

    .fx-slot-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      padding-bottom: 6px;
    }

    .fx-slot-title {
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--cyan);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .fx-slot-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .fx-slot-actions button {
      background: transparent;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 12px;
      padding: 4px;
      transition: color 0.2s;
    }

    .fx-slot-actions button:hover {
      color: var(--rose);
    }

    .fx-bypass-btn {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: rgba(10, 15, 30, 0.8);
      color: var(--text-muted);
      font-size: 11px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .fx-bypass-btn.active {
      background: #10b981;
      color: #fff;
      border-color: #10b981;
      box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
    }

    .fx-slot-controls {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .pro-eq-container {
      grid-column: 1 / span 2;
    }

    .fx-slider-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .fx-slider-group label {
      font-size: 11px;
      color: var(--text-muted);
      display: flex;
      justify-content: space-between;
    }

    .fx-slider-group input[type="range"] {
      width: 100%;
      accent-color: var(--cyan);
      background: rgba(0, 0, 0, 0.4);
      height: 4px;
      border-radius: 2px;
      outline: none;
    }

    .fx-slot-controls .fx-select-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .fx-slot-controls .fx-select-group label {
        font-size: 11px;
        color: var(--text-muted);
    }

    .fx-slot-controls .fx-select-group select {
        background: rgba(10, 15, 30, 0.8);
        border: 1px solid rgba(139, 92, 246, 0.3);
        border-radius: 6px;
        color: #fff;
        padding: 4px 8px;
        font-family: inherit;
        font-size: 12px;
        outline: none;
    }

    /* Modal Glassmorphism genérico */
    .modal-daw {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(8px);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background: rgba(20, 25, 45, 0.9);
      border: 1px solid var(--panel-border);
      border-radius: 16px;
      padding: 24px;
      width: 400px;
      max-width: 90%;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .modal-content button {
      background: var(--accent);
      border: none;
      color: #fff;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      width: 100%;
      margin-top: 16px;
    }

    .modal-close {
      float: right;
      cursor: pointer;
      font-size: 18px;
      color: var(--text-muted);
    }

    /* Floating Spectrum Panel */
    .floating-panel {
      position: absolute;
      top: 150px;
      left: 300px;
      width: 820px;
      background: rgba(11, 14, 28, 0.96);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(139, 92, 246, 0.4);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.7), 0 0 24px rgba(139, 92, 246, 0.2);
      border-radius: 12px;
      z-index: 1051;
      display: none;
      flex-direction: column;
      overflow: hidden;
      font-family: 'Inter', sans-serif;
      color: #e2e8f0;
    }

    .floating-panel-header {
      padding: 12px 16px;
      background: rgba(20, 25, 45, 0.85);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      cursor: move;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
    }

    .floating-panel-title {
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.5px;
      color: #a78bfa;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .floating-panel-close {
      cursor: pointer;
      font-size: 22px;
      color: #94a3b8;
      transition: color 0.15s;
      line-height: 1;
    }

    .floating-panel-close:hover {
      color: #ef4444;
    }

    .floating-panel-body {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .spectrumTooltip {
      pointer-events: none;
      transition: opacity 0.1s ease;
    }

    /* =========================================================================
       NEW: Compact Styles and Bottom Transport Player Styles
       ========================================================================= */
    /* Compactar botões do cabeçalho */
    .btn-daw {
      font-size: 11px !important;
      padding: 4px 8px !important;
      border-radius: 6px !important;
      gap: 4px !important;
    }
    header .session-controls .btn-daw {
      font-size: 16px !important;
      padding: 6px 10px !important;
      border-radius: 8px !important;
    }
    .transport-bar .tempo-stepper .btn-daw {
      padding: 4px 6px !important;
    }
    .tempo-display {
      font-size: 11px !important;
      padding: 2px 4px !important;
      height: 22px !important;
      width: 44px !important;
    }
    .snap-control select {
      font-size: 11px !important;
      padding: 2px 4px !important;
      height: 22px !important;
      width: 76px !important;
    }
    .snap-control label {
      font-size: 11px !important;
    }
    .display-time {
      font-size: 14px !important;
      padding: 2px 8px !important;
      width: 100px !important;
    }

    /* Sobrescrever marcador de playhead com setinha branca */
    .ruler-marker.playhead-marker {
      color: rgba(255, 255, 255, 0.96) !important;
      margin-left: -7px;
      z-index: 15;
      cursor: pointer;
      transition: left 0.05s linear;
    }
    .ruler-marker.playhead-marker::before {
      content: "" !important;
      width: 14px !important;
      height: 12px !important;
      background: rgba(255, 255, 255, 0.96) !important;
      clip-path: polygon(0 0, 100% 0, 100% 68%, 50% 100%, 0 68%) !important;
      position: absolute !important;
      top: 0 !important;
      left: 50% !important;
      transform: translate(-50%, 0) !important;
      border-left: none !important;
      border-right: none !important;
      border-top: none !important;
      box-shadow: 0 2px 6px rgba(255, 255, 255, 0.24) !important;
    }
    
    /* Playhead line custom styles */
    .playhead-line {
      background: rgba(255, 255, 255, 0.92) !important;
      box-shadow: 0 0 10px rgba(255, 255, 255, 0.45) !important;
      transition: left 0.05s linear;
    }
    
    /* Animação do Salto */
    .playhead-line.is-animated,
    .ruler-marker.playhead-marker.is-animated {
      transition-duration: .24s !important;
      transition-timing-function: cubic-bezier(.22, .8, .22, 1) !important;
    }

    /* Estilos do Player do Rodapé */
    .studio-transport {
      display: grid;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, .2);
      background: rgba(7, 10, 15, .95);
      max-width: 480px;
      width: 100%;
    }

    .transport-top {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 26px;
      max-width: 460px;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    }

    .transport-vol-wrap {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-right: 4px;
      position: relative;
    }

    .transport-icon-btn {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid rgba(148, 163, 184, .26);
      background: rgba(16, 20, 28, .9);
      color: #eafcff;
      font-size: 11px;
      line-height: 1;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: all 0.15s ease;
    }

    .transport-icon-btn:hover,
    .transport-icon-btn:focus-visible,
    .transport-icon-btn.is-active {
      border-color: rgba(57, 215, 230, .6);
      background: rgba(57, 215, 230, .12);
      outline: none;
    }

    .transport-play {
      width: 32px;
      height: 26px;
    }

    .transport-volume {
      width: 76px;
      margin: 0;
      accent-color: #9ca3af;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      position: absolute;
      left: 50%;
      top: 30px;
      transform: translateX(-50%);
      transition: opacity 0.18s;
      z-index: 10;
    }
    .transport-vol-wrap:hover .transport-volume,
    .transport-vol-wrap:focus-within .transport-volume {
      opacity: 1;
      pointer-events: auto;
    }

    .transport-bottom {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) 44px;
      gap: 8px;
      align-items: center;
    }

    .transport-seek {
      width: 100%;
      margin: 0;
      accent-color: #6b7280;
      cursor: pointer;
      transition: accent-color 0.18s;
      height: 6px;
      border-radius: 3px;
    }
    .transport-seek:hover,
    .transport-seek:focus {
      accent-color: #39d7e6;
    }

    .transport-time-side {
      font-size: 11px;
      color: rgba(226, 232, 240, .82);
      min-width: 44px;
      text-align: center;
      font-variant-numeric: tabular-nums;
    }
  </style>
</head>
<body>

  <!-- Menu Superior de Arquivo -->
  <div class="top-menu-bar" style="display: flex; gap: 10px;">
    <div class="menu-item">
      <span class="menu-trigger">Arquivo</span>
      <div class="menu-dropdown">
        <a href="#" onclick="abrirModalImportar(); return false;">📂 Abrir Projeto</a>
        <a href="#" onclick="salvarConfiguracoes(); return false;">💾 Salvar Projeto</a>
        <a href="#" onclick="document.getElementById('inputAudioFile').click(); return false;">📂 Importar Áudio</a>
        <div class="menu-submenu-parent">
          <a href="#" onclick="return false;">📤 Exportar <span style="font-size: 9px; opacity: 0.7;">▶</span></a>
          <div class="menu-submenu">
            <a href="#" onclick="exportMixdown('mp3'); return false;">🎵 MP3</a>
            <a href="#" onclick="exportMixdown('wav'); return false;">🎵 WAV</a>
          </div>
        </div>
      </div>
    </div>
    <div class="menu-item">
      <span class="menu-trigger">Editar</span>
      <div class="menu-dropdown">
        <a href="#" onclick="copiarRegiaoSelecionada(); return false;">📋 Copiar (Ctrl+C)</a>
        <a href="#" onclick="colarRegiao(); return false;">📥 Colar (Ctrl+V)</a>
        <a href="#" onclick="redoAction(); return false;">↷ Refazer (Ctrl+Shift+Z)</a>
        <a href="#" onclick="recortarRegiaoSelecionada(); return false;">✂️ Recortar (Ctrl+X)</a>
      </div>
    </div>
    <div class="menu-item">
      <span class="menu-trigger">Trilha</span>
      <div class="menu-dropdown">
        <a href="#" onclick="abrirModalNovaTrilha(); return false;">➕ Nova Trilha</a>
        <a href="#" onclick="duplicarTrilhaSelecionada(); return false;">👯 Duplicar Trilha</a>
        <a href="#" onclick="deletarTrilhaSelecionada(); return false;">❌ Apagar Trilha</a>
      </div>
    </div>
    <div class="menu-item">
      <span class="menu-trigger">Configurações</span>
      <div class="menu-dropdown">
        <a href="#" onclick="abrirModalConfiguracoes(); return false;">⚙️ Dispositivos de Áudio</a>
      </div>
    </div>
    
    <!-- Controle de Zoom no Menu Superior -->
    <div style="margin-left: auto; display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 11px; padding-right: 10px;">
      <span>🔍 Zoom:</span>
      <input type="range" id="sliderZoomTimeline" min="15" max="180" value="40" style="width: 120px; accent-color: var(--accent); cursor: pointer; background: rgba(255,255,255,0.05); height: 4px; border-radius: 2px;">
    </div>
  </div>

  <!-- Header -->
  <header>
    <div class="brand">
      <span class="brand-logo">🎛️</span>
      <div class="brand-title">
        <h1>CifrasFlix DAW</h1>
        <p>Online Studio Workstation</p>
      </div>
    </div>

    <!-- Controles de Tom e BPM -->
    <div class="transport-bar">
        <div class="tempo-stepper">
            <button id="tomDown" class="btn-daw" type="button" aria-label="Baixar tom">-</button>
            <span id="tomValue" class="bpm-control input tempo-display">C</span>
            <button id="tomUp" class="btn-daw" type="button" aria-label="Subir tom">+</button>
        </div>
        <div class="tempo-stepper">
            <button id="bpmDown" class="btn-daw" type="button" aria-label="Diminuir BPM">-</button>
            <input type="number" id="inputBpm" min="30" max="300" value="120" class="bpm-control input tempo-display">
            <button id="bpmUp" class="btn-daw" type="button" aria-label="Aumentar BPM">+</button>
        </div>
    </div>

    <!-- Exibição de Tempo e Configs Básicas -->
    <div class="session-controls">
      <div class="display-time" id="displayTime">00:00.00</div>

      <div class="snap-control">
        <label for="selectSnap">🧲 Snap</label>
        <select id="selectSnap">
          <option value="none">OFF</option>
          <option value="1">1 Beat</option>
          <option value="0.5">1/2 Beat</option>
          <option value="0.25" selected>1/4 Beat</option>
          <option value="0.125">1/8 Beat</option>
        </select>
      </div>
    </div>

    <!-- Modo de Edição e Ações de Arquivo (Apenas Ícones) -->
    <div class="session-controls">
      <button class="btn-daw active" id="btnPointerMode" title="Ferramenta Seleção / Ponteiro (Atalhos: 1 ou V)">↖️</button>
      <button class="btn-daw" id="btnRegionMode" title="Ferramenta Região (Atalho: R)">📐</button>
      <button class="btn-daw" id="btnCutMode" title="Ferramenta de Corte (Atalhos: 3 ou C)">✂️</button>
      <button class="btn-daw" id="btnUndo" title="Desfazer" disabled>↶</button>
      <button class="btn-daw" id="btnRedo" title="Refazer" disabled>↷</button>
      <button class="btn-daw" id="btnZoomOut" title="Diminuir Zoom" style="font-weight: bold; padding: 4px 8px;">🔍-</button>
      <button class="btn-daw" id="btnZoomIn" title="Aumentar Zoom" style="font-weight: bold; padding: 4px 8px;">🔍+</button>
      <button class="btn-daw active" id="btnToggleGrid" title="Ativar/Desativar Linhas de Grade">🌐</button>
      <button class="btn-daw" id="btnToggleSpectrum" title="Espectro de Frequência">📊</button>
    </div>
  </header>

  <!-- Legacy elements kept for JS compatibility but hidden -->
  <div style="display: none;">
    <button id="btnPlay"></button>
    <button id="btnStop"></button>
  </div>

  <!-- DAW Workspace Principal -->
  <div class="daw-workspace">

    <!-- Painel Mixer (Esquerda) -->
    <aside class="mixer-panel">
      <p class="mixer-title">Trilhas do Projeto</p>
      <div class="track-headers-list" id="trackHeadersList">
        <!-- Headers de Trilha inseridos via JS -->
      </div>
    </aside>

    <!-- Timeline Grid (Centro) - Canvas-based -->
    <div class="timeline-container" id="timelineContainer" style="position: relative; flex: 1; overflow: hidden; display: flex; flex-direction: column;">
      <div id="timelineScrollContainer" style="position: relative; flex: 1; overflow: auto;">
        <div id="timelineScrollDummy" style="width: 5000px; height: 1000px; pointer-events: none;"></div>
        <canvas id="timelineCanvas" style="position: absolute; top: 0; left: 0; display: block; z-index: 5; outline: none; cursor: default;"></canvas>
      </div>
      <button id="btnDeleteRegionSelect" style="display: none; position: absolute; top: 46px; left: 50%; transform: translateX(-50%); background: #ef4444; border: none; color: white; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; cursor: pointer; pointer-events: auto; box-shadow: 0 4px 8px rgba(0,0,0,0.3); z-index: 100;">Apagar Região (Del)</button>

      <!-- Compatibility Hidden Elements to prevent JS exceptions -->
      <div style="display: none;">
        <div id="playheadLine"></div>
        <div id="playheadMarker"></div>
        <div id="selectionOverlay"></div>
        <div id="mouseHoverGuide"></div>
        <div id="marqueeOverlay"></div>
      </div>
    </div>

    <!-- Painel de Efeitos Master (Direita) -->
    <aside class="master-effects-panel">
      <div class="panel-section" id="trackInspectorSection" style="border-bottom: 2px solid var(--accent); background: rgba(139, 92, 246, 0.02);">        
        <!-- Adicionar Inserção na barra lateral -->
        <div class="fx-add-selector" style="margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center; gap: 8px;">
          <select id="selectSidebarNewFx" style="flex: 1; min-width: 0; background: rgba(10, 15, 30, 0.8); border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 6px; color: #fff; padding: 6px; font-family: inherit; font-size: 12px; outline: none;">
            <option value="pro_eq">Pro EQ (Visual)</option>
            <option value="eq">Equalizador (EQ)</option>
            <option value="delay">Delay de Eco (Delay)</option>
            <option value="reverb">Reverb de Sala (Reverb)</option>
            <option value="pitch_correction">Pitch Correction (Auto-Tune)</option>
            <option value="distortion">Distorção / Overdrive</option>
            <option value="lufs_meter">Medidor de LUFS</option>
          </select>
          <button onclick="adicionarEfeitoSidebarTrilha()" style="background: var(--accent); border: none; color: #fff; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; white-space: nowrap;">➕ Inserir</button>
        </div>
      </div>

      <div class="panel-section">
        <h3>Master Volume</h3>
        <div class="slider-row">
          <label>Volume Principal <span id="valMasterVolume">100%</span></label>
          <input type="range" id="sliderMasterVolume" min="0" max="150" value="100">
        </div>
      </div>

      <div class="panel-section">
        <h3>🎛️ Efeitos Master</h3>
        
        <!-- Compressor -->
        <div style="margin-bottom: 20px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <strong style="font-size:12px; color:#fff;">Compressor Dinâmico</strong>
            <input type="checkbox" class="switch-effect" id="switchCompressor" checked>
          </div>
          <div class="slider-row">
            <label>Limiar (Threshold) <span id="valCompThreshold">-24dB</span></label>
            <input type="range" id="sliderCompThreshold" min="-60" max="0" value="-24">
          </div>
          <div class="slider-row">
            <label>Proporção (Ratio) <span id="valCompRatio">4:1</span></label>
            <input type="range" id="sliderCompRatio" min="1" max="20" value="4">
          </div>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--panel-border); margin: 16px 0;">

        <!-- Equalizador 3 Bandas -->
        <div style="margin-bottom: 20px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <strong style="font-size:12px; color:#fff;">Equalizador (EQ)</strong>
            <input type="checkbox" class="switch-effect" id="switchEq" checked>
          </div>
          <div class="slider-row">
            <label>Graves (Bass) <span id="valEqBass">0dB</span></label>
            <input type="range" id="sliderEqBass" min="-12" max="12" value="0">
          </div>
          <div class="slider-row">
            <label>Médios (Mids) <span id="valEqMids">0dB</span></label>
            <input type="range" id="sliderEqMids" min="-12" max="12" value="0">
          </div>
          <div class="slider-row">
            <label>Agudos (Treble) <span id="valEqTreble">0dB</span></label>
            <input type="range" id="sliderEqTreble" min="-12" max="12" value="0">
          </div>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--panel-border); margin: 16px 0;">

        <!-- Reverb Convolver -->
        <div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <strong style="font-size:12px; color:#fff;">Reverb de Sala</strong>
            <input type="checkbox" class="switch-effect" id="switchReverb">
          </div>
          <div class="slider-row">
            <label>Intensidade (Mix) <span id="valReverbMix">30%</span></label>
            <input type="range" id="sliderReverbMix" min="0" max="100" value="30">
          </div>
          <div class="slider-row">
            <label>Tamanho da Sala <span id="valReverbSize">2.0s</span></label>
            <input type="range" id="sliderReverbSize" min="5" max="50" value="20" step="1">
          </div>
        </div>
      </div>
    </aside>

  </div>

  <!-- Rodapé -->
  <footer>
    <div class="footer-left" style="display: flex; align-items: center; gap: 15px; min-width: 280px;">
      <input type="file" id="inputAudioFile" class="file-input" accept=".mp3,.wav,.flac,.m4a,.ogg">
      <div id="footerStatus" style="font-size: 12px; color: #a78bfa; font-weight: bold; display: none; transition: all 0.2s ease;"></div>

          mostrarStatus(`⏳ Carregando e decodificando "${file.name}"...`, 0);

          try {
            const arrayBuffer = await file.arrayBuffer();
            const decoded = await audioCtx.decodeAudioData(arrayBuffer);

            const bufferKey = `file-${Date.now()}`;
            audioBufferCache.set(bufferKey, decoded);

            targetTrack.regions.push({
              id: `region-${Date.now()}`,
              name: file.name.replace(/\.[^/.]+$/, ""),
              startTime: dropTime,
              duration: decoded.duration,
              offset: 0,
              bufferKey: bufferKey,
              buffer: decoded
            });
            
            const endBound = dropTime + decoded.duration;
            if (endBound > songEnd) {
              songEnd = endBound;
              loopEnd = endBound;

:root {
    --bg: #07090d;
    --panel: rgba(18, 22, 30, .94);
    --panel-2: rgba(27, 32, 42, .92);
    --panel-3: rgba(9, 13, 20, .96);
    --line: rgba(148, 163, 184, .17);
    --text: #f5f7fb;
    --muted: rgba(226, 232, 240, .68);
    --soft: rgba(226, 232, 240, .12);
    --accent: #39d7e6;
    --accent-2: #7c3aed;
    --ok: #36d399;
    --warn: #f59e0b;
    --danger: #ef4444;
    --shadow: 0 24px 90px rgba(0, 0, 0, .42);
}

.masterShell {
    max-width: 1240px;
    margin: 0 auto;
    padding: 28px;
    display: grid;
    gap: 16px;
    color: var(--text);
}

.masterHeroCard,
.masterPanel,
.playerPanel,
.quickPanel,
.artistStrip,
.iaCard,
.analysisPanel,
.advancedPanel {
    border: 1px solid var(--line);
    background: var(--panel);
    box-shadow: var(--shadow);
}

.masterHeroCard {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    padding: 22px;
    border-radius: 18px;
}

.masterHeroCard h1 {
    margin: 0 0 8px;
    font-size: clamp(30px, 4vw, 52px);
    line-height: 1;
    letter-spacing: 0;
}

.masterHeroCard p,
.artistStrip p,
.iaCard p,
.advancedPanel summary small {
    margin: 0;
    color: var(--muted);
}

.eyebrow {
    margin: 0 0 6px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
}

.masterStatusCard {
    display: grid;
    gap: 8px;
    min-width: 250px;
    padding: 14px;
    border-radius: 12px;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(148, 163, 184, .14);
}

.masterStatusCard span,
.panelHeader span,
.artistStrip > div:first-child span,
.iaCard > div span,
.mixGroup span,
.sectionTitle,
.settingGroup label,
.pitchStats span,
.tonalTextGrid span,
.meterItem span {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
}

.masterStatusCard strong {
    font-size: 16px;
}

.masterPanel {
    display: grid;
    gap: 14px;
    padding: 18px;
    border-radius: 18px;
}

.topWorkspace,
.coreLayout,
.toolRail {
    display: grid;
    gap: 12px;
}

.topWorkspace {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
}

.uploadPanel,
.exportPanel {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
}

.fileDrop {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 6px;
    padding: 10px 12px;
    border-radius: 12px;
    background: var(--panel-2);
    border: 1px solid rgba(148, 163, 184, .2);
}

.fileDrop span {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
}

.fileDrop input {
    width: 100%;
    color: var(--text);
    min-width: 0;
}

button,
select,
input {
    font-family: inherit;
}

.submitBtn,
.exportBtn,
.secondaryBtn,
.ghostBtn,
.presetBtn,
.ctlBtn,
.eqBtn,
.abBtn,
.btn-vibe,
.transportBtn,
.stem-toggle {
    min-height: 38px;
    border-radius: 10px;
    border: 1px solid rgba(148, 163, 184, .24);
    cursor: pointer;
    font-weight: 700;
    color: var(--text);
    background: rgba(255, 255, 255, .045);
    transition: border-color .18s ease, background .18s ease, transform .18s ease, opacity .18s ease;
}

.submitBtn {
    border: 0;
    padding: 0 16px;
    color: #021114;
    background: linear-gradient(135deg, var(--accent), #8be9f1);
}

.exportBtn {
    padding: 0 16px;
    color: #e7fbfd;
    background: rgba(57, 215, 230, .12);
}

.secondaryBtn,
.ghostBtn {
    padding: 0 14px;
}

.ghostBtn {
    min-height: 34px;
    color: #dffcff;
    background: rgba(57, 215, 230, .08);
}

button:hover:not(:disabled) {
    border-color: rgba(57, 215, 230, .55);
    transform: translateY(-1px);
}

button:disabled {
    opacity: .48;
    cursor: not-allowed;
}

.formatSelect {
    min-height: 38px;
    border: 1px solid rgba(148, 163, 184, .22);
    border-radius: 10px;
    background: var(--panel-2);
    color: var(--text);
    padding: 0 12px;
}

.coreLayout {
    grid-template-columns: minmax(360px, .95fr) minmax(420px, 1.05fr);
    align-items: start;
}

.playerPanel,
.quickPanel {
    border-radius: 14px;
    padding: 14px;
    display: grid;
    gap: 12px;
}

.playerPanel {
    background: var(--panel-3);
}

.transportTop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.transportBtn {
    width: 48px;
    min-height: 42px;
    background: rgba(57, 215, 230, .12);
}

.modeBadge {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, .2);
    background: rgba(255, 255, 255, .04);
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .06em;
    white-space: nowrap;
}

.successBadge {
    color: #a7ffd6;
    border-color: rgba(54, 211, 153, .55);
    background: rgba(54, 211, 153, .12);
}

.transportBottom {
    display: grid;
    grid-template-columns: 48px 1fr 48px;
    gap: 8px;
    align-items: center;
}

.seekBar,
.masterVolumePanel input,
.settingGroup input[type="range"],
.stem-fader input[type="range"] {
    width: 100%;
    margin: 0;
    accent-color: var(--accent);
}

.timeSide {
    font-size: 12px;
    color: rgba(226, 232, 240, .82);
    text-align: center;
    font-variant-numeric: tabular-nums;
}

.abComparisonContainer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px;
    border-radius: 10px;
    background: rgba(255, 255, 255, .03);
    border: 1px solid rgba(148, 163, 184, .11);
}

.abToggleGroup,
.eqActions,
.vibe-container {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.abBtn {
    padding: 0 14px;
    min-height: 32px;
}

.abBtn.active[data-source="original"] {
    color: #fbbf24;
    border-color: var(--warn);
    background: rgba(245, 158, 11, .16);
}

.abBtn.active[data-source="mastered"] {
    color: #a7fbff;
    border-color: var(--accent);
    background: rgba(57, 215, 230, .18);
}

.masterVolumePanel {
    display: grid;
    gap: 8px;
    padding: 10px;
    border-radius: 10px;
    background: rgba(255, 255, 255, .03);
    border: 1px solid rgba(148, 163, 184, .11);
}

.masterVolumePanel label {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    font-size: 13px;
}

.masterVolumePanel strong {
    color: var(--text);
}

.meterPanel {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
}

.meterItem {
    min-width: 0;
    padding: 12px;
    border-radius: 10px;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(57, 215, 230, .18);
}

.meterItem strong {
    display: block;
    margin-top: 6px;
    font-size: 22px;
    color: var(--accent);
}

.panelHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
}

.presetGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
}

.presetBtn {
    min-height: 42px;
    padding: 0 10px;
}

.presetBtn.is-on,
.ctlBtn.is-on,
.eqBtn.on,
.stem-toggle.is-active {
    color: #a7fbff;
    border-color: rgba(57, 215, 230, .65);
    background: rgba(57, 215, 230, .14);
}

.mixControls {
    display: grid;
    gap: 8px;
}

.mixGroup {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 10px;
    border: 1px solid rgba(148, 163, 184, .17);
    border-radius: 10px;
    background: rgba(255, 255, 255, .028);
}

.ctlBtn {
    min-height: 34px;
    padding: 0 12px;
}

.artistStrip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px;
    border-radius: 14px;
}

.btn-vibe {
    padding: 0 14px;
    min-height: 40px;
}

.queen-vibe:hover { border-color: #f4d35e; color: #f4d35e; }
.arctic-vibe:hover { border-color: var(--accent); color: #a7fbff; }
.zep-vibe:hover { border-color: var(--warn); color: #fbbf24; }

.toolRail {
    grid-template-columns: 1fr;
}

.iaCard {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(124, 58, 237, .12), rgba(57, 215, 230, .06));
}

.analysisPanel {
    padding: 14px;
    border-radius: 14px;
}

.freq-cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin-top: 10px;
}

.freq-card {
    display: grid;
    gap: 6px;
    padding: 12px;
    border-radius: 10px;
    text-align: center;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(148, 163, 184, .12);
}

.freq-card strong {
    color: var(--text);
}

.freq-card span,
#diagnosticoIA {
    color: var(--muted);
}

#diagnosticoIA {
    margin-top: 12px;
    padding: 12px;
    border-radius: 10px;
    background: rgba(255, 255, 255, .03);
}

.advancedStack {
    display: grid;
    gap: 10px;
}

.advancedPanel {
    border-radius: 14px;
    overflow: hidden;
}

.advancedPanel summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px;
    cursor: pointer;
    list-style: none;
}

.advancedPanel summary::-webkit-details-marker {
    display: none;
}

.advancedPanel summary span {
    font-weight: 800;
}

.advancedPanel[open] summary {
    border-bottom: 1px solid var(--line);
}

.eqPanel,
.spectrumPanel,
.viewSettingsPanel,
.pitchPanel,
.tonalPanel,
.masterStemsMixer {
    margin: 14px;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid rgba(148, 163, 184, .16);
    background: var(--panel-3);
}

.eqTop,
.masterStemsHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
}

.eqGrid {
    display: grid;
    grid-template-columns: repeat(10, minmax(42px, 1fr));
    gap: 8px;
    align-items: end;
    margin-top: 12px;
}

.eqBand {
    display: grid;
    gap: 8px;
    justify-items: center;
}

.eqVal {
    font-size: 11px;
    color: #9fe7ec;
    font-variant-numeric: tabular-nums;
}

.eqSlider {
    writing-mode: vertical-lr;
    direction: rtl;
    width: 34px;
    height: 154px;
    accent-color: var(--accent);
    cursor: pointer;
}

.eqLabel {
    font-size: 11px;
    color: var(--muted);
}

.spectrumModes {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
}

.spectrumModes span {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
}

.spectrumContainer {
    position: relative;
    width: 100%;
}

#spectrumCanvas {
    width: 100%;
    height: 220px;
    display: block;
    border-radius: 10px;
    background: #05070a;
    border: 1px solid rgba(57, 215, 230, .2);
}

.spectrumTooltip {
    position: absolute;
    display: none;
    background: #111827;
    color: #fff;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 12px;
    border: 1px solid var(--accent);
    pointer-events: none;
    box-shadow: 0 4px 12px rgba(0, 0, 0, .5);
    font-family: monospace;
    z-index: 10;
}

.lufsHistory {
    width: 100%;
    max-width: 500px;
    height: 96px;
    margin-top: 10px;
    border-radius: 10px;
    border: 1px solid rgba(148, 163, 184, .12);
    background: rgba(255, 255, 255, .02);
}

.settingsGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 12px;
}

.settingGroup {
    display: grid;
    gap: 8px;
}

.settingGroup label {
    display: flex;
    justify-content: space-between;
    gap: 8px;
}

.miniBadge {
    color: var(--accent);
    border: 1px solid rgba(57, 215, 230, .35);
    padding: 2px 6px;
    border-radius: 6px;
    font-family: monospace;
    letter-spacing: 0;
}

.progress-container {
    width: 100%;
    background: rgba(255, 255, 255, .05);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, .1);
    display: none;
}

.progress-bar {
    width: 0%;
    height: 5px;
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    transition: width .3s ease;
}

.spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, .25);
    border-radius: 50%;
    border-top-color: #fff;
    animation: spin .8s linear infinite;
    margin-right: 8px;
    vertical-align: middle;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.masterStemsMixer {
    display: grid;
    gap: 10px;
    margin-top: 14px;
}

.masterStemsMixer > h3,
.masterStemsMixer .stem-card {
    display: none;
}

.stem-grid {
    display: grid;
    gap: 8px;
    position: relative;
    padding-top: 10px;
}

.master-playhead,
.master-playhead-hit {
    position: absolute;
    left: 180px;
    right: 0;
}

.master-playhead {
    --playhead-pct: 0%;
    top: -2px;
    bottom: 0;
    pointer-events: none;
    z-index: 8;
}

.master-playhead-hit {
    top: -2px;
    height: 18px;
    cursor: pointer;
    z-index: 9;
    background: transparent;
}

.master-playhead::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--playhead-pct);
    width: 2px;
    background: rgba(255, 255, 255, .92);
    box-shadow: 0 0 10px rgba(255, 255, 255, .45);
    transform: translateX(-1px);
    transition: left .05s linear;
}

.master-playhead::before {
    content: '';
    position: absolute;
    top: 0;
    left: var(--playhead-pct);
    width: 14px;
    height: 12px;
    background: rgba(255, 255, 255, .96);
    clip-path: polygon(0 0,100% 0,100% 68%,50% 100%,0 68%);
    transform: translate(-50%, -1px);
}

.stem-row {
    width: 100%;
    display: grid;
    grid-template-columns: 170px minmax(0, 1fr);
    gap: 10px;
    align-items: center;
    color: inherit;
    transition: opacity .2s, background .18s;
}

.stem-row:hover {
    background: rgba(57, 215, 230, .08);
}

.stem-row.is-dim { opacity: .45; }
.stem-row.is-muted { opacity: .72; }

.stem-meta,
.stem-mix {
    display: grid;
    gap: 8px;
    min-width: 0;
}

.stem-name {
    margin: 0;
    font-size: 16px;
    line-height: 1;
}

.stem-controls {
    display: flex;
    align-items: center;
    gap: 8px;
}

.stem-toggle {
    width: 28px;
    min-height: 24px;
    font-size: 12px;
}

.stem-fx-btn {
    width: 34px;
    font-size: 10px;
    font-weight: 800;
}

.stem-pan-control {
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.stem-pan-knob {
    --angle: 0deg;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(148, 163, 184, .34);
    background: radial-gradient(circle at 30% 28%, #2f3a48 0%, #1a222d 62%, #10151d 100%);
    position: relative;
    cursor: pointer;
    transform: rotate(var(--angle));
}

.stem-pan-knob::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 50%;
    width: 2px;
    height: 9px;
    transform: translateX(-50%);
    border-radius: 2px;
    background: #d9f9ff;
}

.stem-pan-value,
.stem-fader output {
    font-size: 11px;
    color: #d6ecf1;
    font-variant-numeric: tabular-nums;
}

.stem-fader {
    display: grid;
    grid-template-columns: 28px 1fr 34px;
    align-items: center;
    gap: 6px;
    margin: 0;
}

.stem-fader span {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
}

.stem-wave-hit {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
    cursor: pointer;
    text-align: left;
    width: 100%;
}

.stem-wave-wrap {
    position: relative;
    height: 64px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, .12);
    background: rgba(5, 26, 31, .85);
}

.stem-row.active .stem-wave-wrap {
    border-color: rgba(57, 215, 230, .55);
    box-shadow: inset 0 0 0 1px rgba(57, 215, 230, .22);
}

.stem-row.is-muted .stem-wave-wrap,
.stem-row.is-dim .stem-wave-wrap {
    filter: grayscale(1) brightness(.7);
}

.stem-wave {
    width: 100%;
    height: 100%;
    display: block;
}

.stem-fx-modal {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px;
    background: rgba(0, 0, 0, .85);
    backdrop-filter: blur(4px);
}

.stem-fx-modal-content {
    width: min(920px, 100%);
    max-height: min(760px, calc(100vh - 36px));
    overflow: hidden;
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr) auto;
    color: var(--text);
    background: var(--card, #18181b);
    border: 1px solid var(--border, #262626);
    border-radius: 14px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, .5);
}

.stem-fx-head,
.stem-fx-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 18px;
    border-bottom: 1px solid var(--border, #262626);
}

.stem-fx-head h3 {
    margin: 0;
    min-width: 0;
    font-size: 20px;
    line-height: 1.2;
}

.stem-fx-close {
    width: 36px;
    min-height: 36px;
    border: 0;
    color: var(--muted);
    background: transparent;
    font-size: 28px;
    line-height: 1;
}

.stem-fx-tabs {
    display: flex;
    gap: 8px;
    padding: 12px 18px;
    overflow-x: auto;
    border-bottom: 1px solid rgba(148, 163, 184, .14);
}

.stem-fx-tab,
.stem-fx-enable {
    min-height: 34px;
    padding: 0 12px;
    border-radius: 9px;
    border: 1px solid rgba(148, 163, 184, .24);
    color: var(--text);
    background: rgba(255, 255, 255, .045);
    font-weight: 800;
    white-space: nowrap;
}

.stem-fx-tab.is-active,
.stem-fx-enable.is-on {
    color: #a7fbff;
    border-color: rgba(57, 215, 230, .65);
    background: rgba(57, 215, 230, .14);
}

.stem-fx-tab.has-fx-on {
    color: #051114;
    border-color: rgba(54, 211, 153, .8);
    background: linear-gradient(135deg, #36d399, #39d7e6);
}

.stem-fx-tab.has-fx-on.is-active {
    color: #021114;
    border-color: rgba(167, 251, 255, .95);
    box-shadow: 0 0 0 2px rgba(57, 215, 230, .2);
}

.stem-fx-body {
    min-height: 280px;
    overflow: auto;
    padding: 18px;
}

.stem-fx-eq-grid {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    overflow-x: auto;
    padding: 8px 0;
}

.stem-fx-panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    align-items: start;
}

.stem-fx-enable {
    width: fit-content;
    min-width: 108px;
}

.stem-fx-control {
    display: grid;
    gap: 10px;
    padding: 12px;
    border: 1px solid rgba(148, 163, 184, .16);
    border-radius: 10px;
    background: rgba(255, 255, 255, .035);
}

.stem-fx-control > span {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-size: 13px;
}

.stem-fx-control strong {
    color: #a7fbff;
    font-variant-numeric: tabular-nums;
}

.stem-fx-control input {
    width: 100%;
    accent-color: var(--accent);
}

.stem-fx-note {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
}

.stem-fx-footer {
    justify-content: flex-end;
    border-top: 1px solid var(--border, #262626);
    border-bottom: 0;
}

.pitchPanel {
    display: grid;
    gap: 14px;
}

.piano-container {
    overflow-x: auto;
    padding: 20px;
    border-radius: 12px;
    background: #111827;
    border: 1px solid rgba(148, 163, 184, .12);
}

.piano-keyboard {
    width: 280px;
    height: 120px;
    display: flex;
    position: relative;
    margin: 0 auto;
}

.piano-key {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    font-weight: 700;
    transition: background .1s ease;
}

.white-key {
    width: 40px;
    height: 120px;
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 0 0 4px 4px;
    color: #6b7280;
    font-size: 11px;
    padding-bottom: 8px;
}

.black-key {
    width: 24px;
    height: 75px;
    background: #1f2937;
    position: absolute;
    z-index: 2;
    border-radius: 0 0 3px 3px;
    color: #fff;
    font-size: 9px;
    padding-bottom: 6px;
}

.key-cs { left: 28px; }
.key-ds { left: 68px; }
.key-fs { left: 148px; }
.key-gs { left: 188px; }
.key-as { left: 228px; }

.pitchStats {
    display: grid;
    gap: 6px;
}

.pitchStats > div:first-child {
    display: flex;
    justify-content: space-between;
}

.confidenceTrack {
    width: 100%;
    height: 10px;
    background: rgba(255, 255, 255, .04);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, .1);
}

#pitchConfidenceBar {
    width: 0%;
    height: 100%;
    background: var(--accent);
    transition: width .1s ease;
}

.pitchReadout {
    padding: 18px;
    text-align: center;
    border-radius: 12px;
    background: rgba(255, 255, 255, .025);
    border: 1px solid rgba(148, 163, 184, .1);
}

.pitchReadout strong {
    display: block;
    font-size: 42px;
    color: var(--accent);
}

.pitchReadout span {
    color: var(--muted);
    font-family: monospace;
}

.centsMeter {
    position: relative;
    width: 100%;
    height: 16px;
    border-radius: 6px;
    background: linear-gradient(90deg, #ef4444 0%, #f59e0b 30%, #36d399 50%, #f59e0b 70%, #ef4444 100%);
}

.centsMeter::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 16px;
    background: rgba(0, 0, 0, .4);
}

#pitchCentsPointer {
    position: absolute;
    top: -4px;
    left: 50%;
    width: 4px;
    height: 24px;
    background: #fff;
    border-radius: 2px;
    box-shadow: 0 0 8px rgba(255, 255, 255, .8);
    transition: left .1s ease;
    z-index: 1;
}

.tonalPanel {
    display: grid;
    gap: 12px;
}

.tonalResults {
    padding: 14px;
    border-radius: 12px;
    background: rgba(255, 255, 255, .02);
    border: 1px solid rgba(148, 163, 184, .1);
}

.tonalGrid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 10px;
    margin-top: 10px;
}

.tonalMetric {
    padding: 16px;
    border-radius: 10px;
    text-align: center;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(148, 163, 184, .1);
}

.tonalMetric strong {
    display: block;
    font-size: 30px;
}

.tonalMetric.main strong {
    font-size: 38px;
}

.accentMetric {
    background: rgba(124, 58, 237, .08);
    border-color: rgba(124, 58, 237, .26);
}

.accentMetric strong {
    color: #a7fbff;
}

.tonalTextGrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 10px;
}

.tonalTextGrid > div {
    padding: 12px;
    border-radius: 10px;
    background: rgba(255, 255, 255, .03);
    border: 1px solid rgba(148, 163, 184, .08);
}

.tonalTextGrid div div {
    margin-top: 8px;
    color: #a7fbff;
    line-height: 1.5;
}

@media (max-width: 1040px) {
    .coreLayout {
        grid-template-columns: 1fr;
    }

    .presetGrid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }
}

@media (max-width: 820px) {
    .masterShell {
        padding: 14px;
    }

    .masterHeroCard,
    .topWorkspace,
    .artistStrip,
    .iaCard {
        grid-template-columns: 1fr;
        flex-direction: column;
        align-items: stretch;
    }

    .masterHeroCard {
        align-items: flex-start;
    }

    .masterStatusCard {
        min-width: 0;
        width: 100%;
    }

    .uploadPanel,
    .exportPanel {
        flex-direction: column;
        align-items: stretch;
    }

    .presetGrid,
    .freq-cards,
    .settingsGrid,
    .tonalGrid,
    .tonalTextGrid {
        grid-template-columns: 1fr;
    }

    .meterPanel {
        grid-template-columns: 1fr;
    }

    .eqGrid {
        grid-template-columns: repeat(5, minmax(42px, 1fr));
    }

    .stem-row {
        grid-template-columns: 1fr;
    }

    .master-playhead,
    .master-playhead-hit {
        left: 0;
    }

    .stem-fx-panel {
        grid-template-columns: 1fr;
    }
}
